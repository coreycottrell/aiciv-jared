[Unit]
Description=Aether BOOP Executor - Scheduled task daemon for AI Collective
After=network.target

[Service]
Type=simple
User=jared
WorkingDirectory=/home/jared/projects/AI-CIV/aether
ExecStart=/usr/bin/python3 /home/jared/projects/AI-CIV/aether/tools/boop_executor.py
Restart=always
RestartSec=30
StandardOutput=append:/home/jared/projects/AI-CIV/aether/logs/boop_executor.log
StandardError=append:/home/jared/projects/AI-CIV/aether/logs/boop_executor.log
Environment=HOME=/home/jared
Environment=PATH=/home/jared/.local/bin:/home/jared/.nvm/versions/node/v22.14.0/bin:/usr/local/bin:/usr/bin:/bin

[Install]
WantedBy=multi-user.target
