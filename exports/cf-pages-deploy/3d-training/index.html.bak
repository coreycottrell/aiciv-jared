<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PureBrain // Night 12 // Hexagonal Bokeh + Dynamic Caustics</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { background: #060606; overflow: hidden; width: 100vw; height: 100vh; }
canvas { display: block; width: 100%; height: 100%; }
#overlay {
  position: fixed; bottom: 40px; left: 40px;
  color: rgba(255,255,255,0.30);
  font-family: 'Inter', 'SF Pro', system-ui, sans-serif;
  font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
  pointer-events: none; user-select: none; z-index: 10;
  line-height: 1.8;
}
#info {
  position: fixed; top: 20px; right: 20px;
  color: rgba(255,255,255,0.20);
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase;
  pointer-events: none; user-select: none; z-index: 10;
  text-align: right; line-height: 1.6;
}
#title {
  position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
  color: rgba(255,255,255,0.04);
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 120px; font-weight: 100; letter-spacing: 0.3em;
  pointer-events: none; user-select: none; z-index: 5;
  text-transform: uppercase; white-space: nowrap;
}
#fps {
  position: fixed; top: 20px; left: 20px;
  color: rgba(255,255,255,0.15);
  font-family: monospace; font-size: 10px;
  pointer-events: none; z-index: 10;
}
</style>
</head>
<body>
<div id="overlay">
  PUREBRAIN // NIGHT 12<br>
  HEXAGONAL BOKEH DOF<br>
  DYNAMIC CAUSTIC PROJECTION<br>
  HALF-RES VOLUMETRICS
</div>
<div id="info">
  hex aperture bokeh shapes<br>
  geometry-linked caustics<br>
  bilateral upsample volumetrics<br>
  raymarched light cones<br>
  chromatic dispersion<br>
  scratch normal maps<br>
  film grain + vignette
</div>
<div id="title">PURE</div>
<div id="fps"></div>

<script type="importmap">
{
  "imports": {
    "three": "https://cdn.jsdelivr.net/npm/three@0.164.1/build/three.module.js",
    "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.164.1/examples/jsm/"
  }
}
</script>

<script type="module">
import * as THREE from 'three';
import { EffectComposer } from 'three/addons/postprocessing/EffectComposer.js';
import { RenderPass } from 'three/addons/postprocessing/RenderPass.js';
import { UnrealBloomPass } from 'three/addons/postprocessing/UnrealBloomPass.js';
import { ShaderPass } from 'three/addons/postprocessing/ShaderPass.js';

// ============================================================
// CONSTANTS
// ============================================================
const BLUE = new THREE.Color('#2a93c1');
const ORANGE = new THREE.Color('#f1420b');
const DARK_BG = '#080a12';
const PI = Math.PI;
const TWO_PI = PI * 2;

// ============================================================
// SCENE SETUP
// ============================================================
const scene = new THREE.Scene();
scene.background = new THREE.Color(DARK_BG);
scene.fog = new THREE.FogExp2(DARK_BG, 0.04);

const camera = new THREE.PerspectiveCamera(38, window.innerWidth / window.innerHeight, 0.1, 100);
camera.position.set(0, 3.5, 7);
camera.lookAt(0, 0.5, 0);

const renderer = new THREE.WebGLRenderer({ antialias: true, powerPreference: 'high-performance' });
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
renderer.toneMapping = THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure = 1.1;
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;
document.body.appendChild(renderer.domElement);

// FPS counter
const fpsEl = document.getElementById('fps');
let fpsFrames = 0, fpsTime = 0;

// ============================================================
// PROCEDURAL TEXTURES
// ============================================================

// Simplex noise implementation (compact)
const _p = new Uint8Array(512);
const _perm = [151,160,137,91,90,15,131,13,201,95,96,53,194,233,7,225,
  140,36,103,30,69,142,8,99,37,240,21,10,23,190,6,148,247,120,234,75,0,
  26,197,62,94,252,219,203,117,35,11,32,57,177,33,88,237,149,56,87,174,
  20,125,136,171,168,68,175,74,165,71,134,139,48,27,166,77,146,158,231,
  83,111,229,122,60,211,133,230,220,105,92,41,55,46,245,40,244,102,143,
  54,65,25,63,161,1,216,80,73,209,76,132,187,208,89,18,169,200,196,135,
  130,116,188,159,86,164,100,109,198,173,186,3,64,52,217,226,250,124,
  123,5,202,38,147,118,126,255,82,85,212,207,206,59,227,47,16,58,17,
  182,189,28,42,223,183,170,213,119,248,152,2,44,154,163,70,221,153,
  101,155,167,43,172,9,129,22,39,253,19,98,108,110,79,113,224,232,178,
  185,112,104,218,246,97,228,251,34,242,193,238,210,144,12,191,179,162,
  241,81,51,145,235,249,14,239,107,49,192,214,31,181,199,106,157,184,
  84,204,176,115,121,50,45,127,4,150,254,138,236,205,93,222,114,67,29,
  24,72,243,141,128,195,78,66,215,61,156,180];
for(let i=0;i<256;i++){_p[i]=_perm[i];_p[i+256]=_perm[i];}

function noise3D(x,y,z){
  const X=Math.floor(x)&255, Y=Math.floor(y)&255, Z=Math.floor(z)&255;
  x-=Math.floor(x); y-=Math.floor(y); z-=Math.floor(z);
  const u=x*x*(3-2*x), v=y*y*(3-2*y), w=z*z*(3-2*z);
  const A=_p[X]+Y, AA=_p[A]+Z, AB=_p[A+1]+Z;
  const B=_p[X+1]+Y, BA=_p[B]+Z, BB=_p[B+1]+Z;
  function grad(h,a,b,c){h=h&15;const u=h<8?a:b,v=h<4?b:h===12||h===14?a:c;return((h&1)===0?u:-u)+((h&2)===0?v:-v);}
  return lerp(w,lerp(v,lerp(u,grad(_p[AA],x,y,z),grad(_p[BA],x-1,y,z)),lerp(u,grad(_p[AB],x,y-1,z),grad(_p[BB],x-1,y-1,z))),
    lerp(v,lerp(u,grad(_p[AA+1],x,y,z-1),grad(_p[BA+1],x-1,y,z-1)),lerp(u,grad(_p[AB+1],x,y-1,z-1),grad(_p[BB+1],x-1,y-1,z-1))));
}
function lerp(t,a,b){return a+t*(b-a);}

function fbm(x, y, z, octaves = 4) {
  let val = 0, amp = 0.5, freq = 1;
  for (let i = 0; i < octaves; i++) {
    val += amp * noise3D(x * freq, y * freq, z * freq);
    amp *= 0.5; freq *= 2.0;
  }
  return val;
}

// Generate scratch normal map texture (micro-detail imperfections)
function generateScratchNormalMap(size = 512) {
  const canvas = document.createElement('canvas');
  canvas.width = size; canvas.height = size;
  const ctx = canvas.getContext('2d');
  const imageData = ctx.createImageData(size, size);
  const data = imageData.data;

  for (let i = 0; i < data.length; i += 4) {
    data[i] = 128; data[i+1] = 128; data[i+2] = 255; data[i+3] = 255;
  }

  for (let s = 0; s < 120; s++) {
    const x0 = Math.random() * size;
    const y0 = Math.random() * size;
    const angle = Math.random() * PI;
    const len = 20 + Math.random() * 80;
    const dx = Math.cos(angle);
    const dy = Math.sin(angle);
    const intensity = 8 + Math.random() * 20;

    for (let t = 0; t < len; t += 0.5) {
      const px = Math.round(x0 + dx * t);
      const py = Math.round(y0 + dy * t);
      if (px >= 0 && px < size && py >= 0 && py < size) {
        const idx = (py * size + px) * 4;
        data[idx]     = Math.max(0, Math.min(255, 128 + (-dy) * intensity));
        data[idx + 1] = Math.max(0, Math.min(255, 128 + dx * intensity));
      }
    }
  }

  for (let i = 0; i < data.length; i += 4) {
    const noise = (Math.random() - 0.5) * 6;
    data[i]     = Math.max(0, Math.min(255, data[i] + noise));
    data[i + 1] = Math.max(0, Math.min(255, data[i + 1] + noise));
  }

  ctx.putImageData(imageData, 0, 0);
  const tex = new THREE.CanvasTexture(canvas);
  tex.wrapS = tex.wrapT = THREE.RepeatWrapping;
  tex.repeat.set(2, 2);
  return tex;
}

// Generate caustic texture
function generateCausticBaseTexture(size = 256) {
  const canvas = document.createElement('canvas');
  canvas.width = size; canvas.height = size;
  const ctx = canvas.getContext('2d');

  const points = [];
  for (let i = 0; i < 30; i++) {
    points.push({ x: Math.random() * size, y: Math.random() * size });
  }

  const imageData = ctx.createImageData(size, size);
  const data = imageData.data;

  for (let y = 0; y < size; y++) {
    for (let x = 0; x < size; x++) {
      let d1 = Infinity, d2 = Infinity;
      for (const p of points) {
        let dx = Math.abs(x - p.x); if (dx > size/2) dx = size - dx;
        let dy = Math.abs(y - p.y); if (dy > size/2) dy = size - dy;
        const d = Math.sqrt(dx*dx + dy*dy);
        if (d < d1) { d2 = d1; d1 = d; }
        else if (d < d2) { d2 = d; }
      }
      const edge = d2 - d1;
      const caustic = Math.max(0, 1.0 - edge / 12.0);
      const bright = Math.pow(caustic, 3.0) * 255;

      const idx = (y * size + x) * 4;
      data[idx]     = Math.min(255, bright * 0.7);
      data[idx + 1] = Math.min(255, bright * 0.85);
      data[idx + 2] = Math.min(255, bright);
      data[idx + 3] = 255;
    }
  }

  ctx.putImageData(imageData, 0, 0);
  const tex = new THREE.CanvasTexture(canvas);
  tex.wrapS = tex.wrapT = THREE.RepeatWrapping;
  return tex;
}

const scratchNormalMap = generateScratchNormalMap(512);
const causticTexture = generateCausticBaseTexture(256);

// ============================================================
// LIGHTING
// ============================================================

const keyLight = new THREE.SpotLight(0xffa366, 40, 30, PI * 0.15, 0.6, 1.5);
keyLight.position.set(4, 8, 3);
keyLight.target.position.set(0, 0, 0);
keyLight.castShadow = true;
keyLight.shadow.mapSize.set(1024, 1024);
keyLight.shadow.camera.near = 1;
keyLight.shadow.camera.far = 20;
scene.add(keyLight, keyLight.target);

const fillLight = new THREE.SpotLight(0x2a93c1, 20, 25, PI * 0.2, 0.5, 1.5);
fillLight.position.set(-5, 6, 2);
fillLight.target.position.set(0, 0, 0);
scene.add(fillLight, fillLight.target);

const rimLight = new THREE.SpotLight(0xc0d0ff, 15, 20, PI * 0.18, 0.4, 1.5);
rimLight.position.set(0, 5, -6);
rimLight.target.position.set(0, 0, 0);
scene.add(rimLight, rimLight.target);

const ambientLight = new THREE.AmbientLight(0x0a0e18, 0.4);
scene.add(ambientLight);

const innerGlow = new THREE.PointLight(0x2a93c1, 8, 6, 2);
innerGlow.position.set(0, 1.2, 0);
scene.add(innerGlow);

const innerGlowOrange = new THREE.PointLight(0xf1420b, 3, 4, 2);
innerGlowOrange.position.set(0.5, 1.5, 0.5);
scene.add(innerGlowOrange);

// ============================================================
// ENVIRONMENT MAP (Procedural)
// ============================================================
const pmremGen = new THREE.PMREMGenerator(renderer);
const envScene = new THREE.Scene();
const envGeo = new THREE.SphereGeometry(50, 32, 16);
const envMat = new THREE.ShaderMaterial({
  side: THREE.BackSide,
  uniforms: {
    colorTop: { value: new THREE.Color(0x0a1628) },
    colorMid: { value: new THREE.Color(0x0a0e18) },
    colorBot: { value: new THREE.Color(0x060608) },
    highlight1: { value: new THREE.Color(0x2a93c1) },
    highlight2: { value: new THREE.Color(0xf1420b) }
  },
  vertexShader: `
    varying vec3 vWorldPos;
    void main() {
      vWorldPos = (modelMatrix * vec4(position, 1.0)).xyz;
      gl_Position = projectionMatrix * viewMatrix * vec4(vWorldPos, 1.0);
    }
  `,
  fragmentShader: `
    uniform vec3 colorTop, colorMid, colorBot, highlight1, highlight2;
    varying vec3 vWorldPos;
    void main() {
      vec3 dir = normalize(vWorldPos);
      float y = dir.y;
      vec3 col = y > 0.0 ? mix(colorMid, colorTop, y) : mix(colorMid, colorBot, -y);
      float h1 = smoothstep(0.8, 1.0, dot(dir, normalize(vec3(1, 0.5, 0.3))));
      float h2 = smoothstep(0.85, 1.0, dot(dir, normalize(vec3(-0.5, 0.3, -0.8))));
      col += highlight1 * h1 * 0.15 + highlight2 * h2 * 0.08;
      gl_FragColor = vec4(col, 1.0);
    }
  `
});
envScene.add(new THREE.Mesh(envGeo, envMat));
const envMap = pmremGen.fromScene(envScene, 0, 0.1, 100).texture;
scene.environment = envMap;
envScene.dispose();

// ============================================================
// NIGHT 12 PRIMARY: HEXAGONAL BOKEH DoF SHADER
// ============================================================
// Custom depth-of-field with hexagonal aperture mask
// Instead of gaussian blur, samples along a hexagonal kernel
// producing 6-sided bokeh highlights on specular points

const hexBokehShader = {
  uniforms: {
    tDiffuse: { value: null },
    tDepth: { value: null },
    cameraNear: { value: 0.1 },
    cameraFar: { value: 100.0 },
    focusDist: { value: 7.5 },
    focalLength: { value: 0.05 },
    aperture: { value: 0.012 },
    maxBlur: { value: 8.0 },
    resolution: { value: new THREE.Vector2(window.innerWidth, window.innerHeight) }
  },
  vertexShader: `
    varying vec2 vUv;
    void main() {
      vUv = uv;
      gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    }
  `,
  fragmentShader: `
    uniform sampler2D tDiffuse;
    uniform sampler2D tDepth;
    uniform float cameraNear, cameraFar, focusDist, focalLength, aperture, maxBlur;
    uniform vec2 resolution;
    varying vec2 vUv;

    float linearizeDepth(float d) {
      return cameraNear * cameraFar / (cameraFar - d * (cameraFar - cameraNear));
    }

    // Circle of confusion diameter
    float getCoC(float depth) {
      float S1 = focusDist;
      float S2 = depth;
      // Thin lens CoC formula: CoC = |aperture * focalLength * (S1 - S2) / (S2 * (S1 - focalLength))|
      float coc = abs(aperture * focalLength * (S1 - S2) / (S2 * (S1 - focalLength)));
      return min(coc * 1000.0, maxBlur); // scale to pixels
    }

    void main() {
      float depth = linearizeDepth(texture2D(tDepth, vUv).x);
      float coc = getCoC(depth);

      // If CoC is negligible, skip blur
      if (coc < 0.5) {
        gl_FragColor = texture2D(tDiffuse, vUv);
        return;
      }

      vec2 texel = 1.0 / resolution;

      // ---- HEXAGONAL BOKEH KERNEL ----
      // 6 directions at 60-degree intervals form a hexagon
      // We sample along each spoke and between spokes to fill the hex shape

      // 6 spoke directions (hexagonal vertices)
      vec2 hex[6];
      for (int i = 0; i < 6; i++) {
        float angle = float(i) * 3.14159265 / 3.0; // 60 degree steps
        hex[i] = vec2(cos(angle), sin(angle));
      }

      vec3 colorSum = vec3(0.0);
      float weightSum = 0.0;

      // Number of rings (controls bokeh shape resolution)
      const int RINGS = 4;

      // Center sample
      vec4 centerSample = texture2D(tDiffuse, vUv);
      colorSum += centerSample.rgb;
      weightSum += 1.0;

      for (int ring = 1; ring <= RINGS; ring++) {
        float ringRadius = coc * float(ring) / float(RINGS);
        float numSamplesOnRing = float(ring * 6); // 6, 12, 18, 24

        for (int s = 0; s < 24; s++) { // max 24 samples per ring
          if (float(s) >= numSamplesOnRing) break;

          float angle = float(s) / numSamplesOnRing * 6.28318530;

          // Hexagonal warping: push samples toward hexagonal shape
          // Find which sector (0-5) this angle falls in
          float sectorAngle = mod(angle, 1.0471975); // PI/3
          float sectorCenter = 0.5235988; // PI/6
          // Scale radius to create flat edges between hex vertices
          float hexScale = cos(sectorCenter) / cos(sectorAngle - sectorCenter);

          vec2 offset = vec2(cos(angle), sin(angle)) * ringRadius * hexScale * texel;

          vec2 sampleUv = vUv + offset;

          // Sample color
          vec4 samp = texture2D(tDiffuse, sampleUv);

          // Depth-aware: compare sample depth to current pixel depth
          float sampleDepth = linearizeDepth(texture2D(tDepth, sampleUv).x);
          float sampleCoC = getCoC(sampleDepth);

          // Weight: closer-to-focus samples bleed less into defocused areas
          float w = smoothstep(0.0, 2.0, sampleCoC);

          // Highlight boost: bright pixels get extra weight (airy bokeh feel)
          float lum = dot(samp.rgb, vec3(0.299, 0.587, 0.114));
          w *= 1.0 + smoothstep(0.7, 1.2, lum) * 3.0;

          colorSum += samp.rgb * w;
          weightSum += w;
        }
      }

      gl_FragColor = vec4(colorSum / weightSum, 1.0);
    }
  `
};

// ============================================================
// HALF-RESOLUTION VOLUMETRIC LIGHT CONES (Night 12 Performance)
// ============================================================
// Renders volumetric pass at 50% resolution, then bilateral upsamples
// This cuts volumetric cost by ~75% with minimal quality loss

const halfW = Math.floor(window.innerWidth / 2);
const halfH = Math.floor(window.innerHeight / 2);

const volumetricConeShader = {
  uniforms: {
    tDiffuse: { value: null },
    tDepth: { value: null },
    cameraNear: { value: camera.near },
    cameraFar: { value: camera.far },
    resolution: { value: new THREE.Vector2(halfW, halfH) },
    cameraPos: { value: camera.position.clone() },
    invProjectionMatrix: { value: new THREE.Matrix4() },
    invViewMatrix: { value: new THREE.Matrix4() },
    time: { value: 0 },
    lightPos1: { value: new THREE.Vector3(4, 8, 3) },
    lightDir1: { value: new THREE.Vector3(-4, -8, -3).normalize() },
    lightColor1: { value: new THREE.Color(0xffa366) },
    lightPos2: { value: new THREE.Vector3(-5, 6, 2) },
    lightDir2: { value: new THREE.Vector3(5, -6, -2).normalize() },
    lightColor2: { value: new THREE.Color(0x2a93c1) },
    density: { value: 0.035 },
    scatterStrength: { value: 0.7 },
    coneAngle: { value: Math.cos(PI * 0.15) }
  },
  vertexShader: `
    varying vec2 vUv;
    void main() {
      vUv = uv;
      gl_Position = vec4(position.xy, 0.0, 1.0);
    }
  `,
  fragmentShader: `
    uniform sampler2D tDiffuse;
    uniform sampler2D tDepth;
    uniform float cameraNear, cameraFar, time, density, scatterStrength, coneAngle;
    uniform vec2 resolution;
    uniform vec3 cameraPos;
    uniform mat4 invProjectionMatrix, invViewMatrix;
    uniform vec3 lightPos1, lightDir1, lightPos2, lightDir2;
    uniform vec3 lightColor1, lightColor2;
    varying vec2 vUv;

    float hash(vec3 p) {
      p = fract(p * 0.3183099 + vec3(0.1, 0.2, 0.3));
      p *= 17.0;
      return fract(p.x * p.y * p.z * (p.x + p.y + p.z));
    }

    float noise(vec3 p) {
      vec3 i = floor(p), f = fract(p);
      f = f * f * (3.0 - 2.0 * f);
      return mix(mix(mix(hash(i), hash(i + vec3(1,0,0)), f.x),
                     mix(hash(i + vec3(0,1,0)), hash(i + vec3(1,1,0)), f.x), f.y),
                 mix(mix(hash(i + vec3(0,0,1)), hash(i + vec3(1,0,1)), f.x),
                     mix(hash(i + vec3(0,1,1)), hash(i + vec3(1,1,1)), f.x), f.y), f.z);
    }

    float fbm(vec3 p) {
      float v = 0.0, a = 0.5;
      for (int i = 0; i < 3; i++) {
        v += a * noise(p);
        p *= 2.1; a *= 0.45;
      }
      return v;
    }

    float getDepth(vec2 uv) {
      float d = texture2D(tDepth, uv).x;
      return cameraNear * cameraFar / (cameraFar - d * (cameraFar - cameraNear));
    }

    float coneFactor(vec3 pos, vec3 lightPos, vec3 lightDir, float cosAngle) {
      vec3 toPoint = normalize(pos - lightPos);
      float cone = dot(toPoint, lightDir);
      float dist = length(pos - lightPos);
      float edge = smoothstep(cosAngle - 0.08, cosAngle + 0.02, cone);
      float atten = 1.0 / (1.0 + dist * 0.15 + dist * dist * 0.02);
      return edge * atten;
    }

    void main() {
      vec4 sceneColor = texture2D(tDiffuse, vUv);
      float sceneDepth = getDepth(vUv);

      vec4 clip = vec4(vUv * 2.0 - 1.0, -1.0, 1.0);
      vec4 viewRay = invProjectionMatrix * clip;
      viewRay.z = -1.0; viewRay.w = 0.0;
      vec3 rayDir = normalize((invViewMatrix * viewRay).xyz);

      // Night 12: Reduced step count for half-res (32 instead of 48)
      // Half-res means fewer pixels to compute, so we can afford the same visual quality
      const int STEPS = 40;
      float maxDist = min(sceneDepth, 20.0);
      float stepSize = maxDist / float(STEPS);

      vec3 volumeColor = vec3(0.0);
      float transmittance = 1.0;

      float dither = hash(vec3(gl_FragCoord.xy, time * 10.0)) * stepSize;

      for (int i = 0; i < STEPS; i++) {
        float t = float(i) * stepSize + dither;
        if (t > maxDist) break;

        vec3 pos = cameraPos + rayDir * t;
        float noiseVal = fbm(pos * 0.8 + vec3(time * 0.05, time * 0.03, time * 0.04));
        float localDensity = density * (0.6 + noiseVal * 0.8);

        float c1 = coneFactor(pos, lightPos1, lightDir1, coneAngle);
        float c2 = coneFactor(pos, lightPos2, lightDir2, coneAngle);

        float cosTheta1 = dot(rayDir, lightDir1);
        float phase1 = 0.25 / (1.0 + 4.0 * pow(1.0 - cosTheta1, 2.0));
        float cosTheta2 = dot(rayDir, lightDir2);
        float phase2 = 0.25 / (1.0 + 4.0 * pow(1.0 - cosTheta2, 2.0));

        vec3 scatter = lightColor1 * c1 * phase1 * scatterStrength
                     + lightColor2 * c2 * phase2 * scatterStrength * 0.7;

        float absorption = exp(-localDensity * stepSize);
        volumeColor += scatter * localDensity * transmittance * stepSize;
        transmittance *= absorption;

        if (transmittance < 0.01) break;
      }

      gl_FragColor = vec4(sceneColor.rgb * transmittance + volumeColor, 1.0);
    }
  `
};

// Bilateral upsample shader: upsamples half-res volumetric to full res
// Uses depth-edge awareness to prevent blurring across depth discontinuities
const bilateralUpsampleShader = {
  uniforms: {
    tDiffuse: { value: null },       // Full-res scene
    tVolumetric: { value: null },    // Half-res volumetric result
    tDepth: { value: null },         // Full-res depth
    resolution: { value: new THREE.Vector2(window.innerWidth, window.innerHeight) }
  },
  vertexShader: `
    varying vec2 vUv;
    void main() {
      vUv = uv;
      gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    }
  `,
  fragmentShader: `
    uniform sampler2D tDiffuse;
    uniform sampler2D tVolumetric;
    uniform sampler2D tDepth;
    uniform vec2 resolution;
    varying vec2 vUv;

    float linearizeDepth(float d) {
      float near = 0.1;
      float far = 100.0;
      return near * far / (far - d * (far - near));
    }

    void main() {
      vec4 sceneColor = texture2D(tDiffuse, vUv);
      vec4 volColor = texture2D(tVolumetric, vUv);

      // The volumetric pass already composited vol + scene
      // So we just use the volumetric result directly
      // Bilateral filtering: sample 4 nearest half-res texels
      // and weight by depth similarity to prevent edge bleeding
      float centerDepth = linearizeDepth(texture2D(tDepth, vUv).x);
      vec2 texel = 1.0 / resolution;

      vec4 sum = vec4(0.0);
      float wSum = 0.0;

      for (int dx = -1; dx <= 1; dx++) {
        for (int dy = -1; dy <= 1; dy++) {
          vec2 offset = vec2(float(dx), float(dy)) * texel * 2.0;
          vec2 sampleUv = vUv + offset;
          vec4 samp = texture2D(tVolumetric, sampleUv);
          float sampleDepth = linearizeDepth(texture2D(tDepth, sampleUv).x);

          // Depth-edge weight: nearby depths contribute more
          float depthDiff = abs(centerDepth - sampleDepth);
          float depthWeight = exp(-depthDiff * depthDiff * 0.5);

          // Spatial weight (gaussian kernel)
          float spatialWeight = exp(-float(dx*dx + dy*dy) * 0.25);

          float w = depthWeight * spatialWeight;
          sum += samp * w;
          wSum += w;
        }
      }

      gl_FragColor = sum / wSum;
    }
  `
};

// ============================================================
// NIGHT 12 SECONDARY: DYNAMIC CAUSTIC FLOOR SHADER
// ============================================================
// Caustics now linked to glass object rotation and position
// The caustic UV projection shifts based on the hero shell orientations

const causticFloorMat = new THREE.ShaderMaterial({
  uniforms: {
    time: { value: 0 },
    causticMap: { value: causticTexture },
    envMap: { value: envMap },
    lightPos: { value: new THREE.Vector3(0, 1.2, 0) },
    floorY: { value: -1.0 },
    causticIntensity: { value: 0.35 },
    causticScale: { value: 3.0 },
    scratchMap: { value: scratchNormalMap },
    colorBlue: { value: BLUE },
    colorOrange: { value: ORANGE },
    // Night 12 additions: dynamic caustic projection
    heroRotY: { value: 0.0 },
    heroRotX: { value: 0.0 },
    heroWorldPos: { value: new THREE.Vector3(0, 0.8, 0) },
    innerLightPos: { value: new THREE.Vector3(0, 1.2, 0) }
  },
  vertexShader: `
    varying vec2 vUv;
    varying vec3 vWorldPos;
    varying vec3 vNormal;
    void main() {
      vUv = uv;
      vec4 worldPos = modelMatrix * vec4(position, 1.0);
      vWorldPos = worldPos.xyz;
      vNormal = normalize(normalMatrix * normal);
      gl_Position = projectionMatrix * viewMatrix * worldPos;
    }
  `,
  fragmentShader: `
    uniform float time, causticIntensity, causticScale, floorY;
    uniform float heroRotY, heroRotX;
    uniform vec3 heroWorldPos, innerLightPos;
    uniform sampler2D causticMap, scratchMap;
    uniform vec3 lightPos, colorBlue, colorOrange;
    varying vec2 vUv;
    varying vec3 vWorldPos;
    varying vec3 vNormal;

    // 2D rotation matrix
    mat2 rot2d(float a) {
      float c = cos(a), s = sin(a);
      return mat2(c, -s, s, c);
    }

    void main() {
      // Base floor color (very dark)
      vec3 baseColor = vec3(0.015, 0.018, 0.028);

      // Grid lines
      vec2 grid = abs(fract(vWorldPos.xz * 0.5) - 0.5);
      float gridLine = 1.0 - smoothstep(0.0, 0.02, min(grid.x, grid.y));
      baseColor += vec3(0.03, 0.04, 0.06) * gridLine * 0.5;

      // NIGHT 12: Dynamic caustic projection
      // UV is derived from the vector from inner light to floor point
      // Then rotated by the hero glass shell rotation
      vec2 projVec = vWorldPos.xz - heroWorldPos.xz;

      // Rotate the projection UV to match glass shell rotation
      // This makes caustics shift as the glass rotates
      projVec = rot2d(heroRotY * 0.6) * projVec;

      // Apply a slight squeeze/distortion from heroRotX (tilt)
      projVec.y *= 1.0 + sin(heroRotX) * 0.15;

      vec2 causticUV = projVec * 0.3;

      // Chromatic split with rotation-aware offsets
      float t = time * 0.3;
      float rotPhase = heroRotY * 0.3;

      vec2 uvR = causticUV * causticScale + vec2(t * 0.1 + sin(rotPhase) * 0.05, t * 0.07 + cos(rotPhase) * 0.03);
      vec2 uvG = causticUV * causticScale * 1.02 + vec2(t * 0.12 + sin(rotPhase + 0.5) * 0.04, t * 0.06 + cos(rotPhase + 0.3) * 0.03);
      vec2 uvB = causticUV * causticScale * 1.04 + vec2(t * 0.08 + sin(rotPhase + 1.0) * 0.06, t * 0.09 + cos(rotPhase + 0.7) * 0.04);

      float cR = texture2D(causticMap, uvR).r;
      float cG = texture2D(causticMap, uvG).g;
      float cB = texture2D(causticMap, uvB).b;

      // Second layer with counter-rotation for complexity
      vec2 projVec2 = rot2d(-heroRotY * 0.4) * (vWorldPos.xz - heroWorldPos.xz);
      vec2 causticUV2 = projVec2 * 0.3;

      vec2 uv2R = causticUV2 * causticScale * 1.7 + vec2(-t * 0.06, t * 0.1);
      vec2 uv2G = causticUV2 * causticScale * 1.72 + vec2(-t * 0.07, t * 0.09);
      vec2 uv2B = causticUV2 * causticScale * 1.74 + vec2(-t * 0.05, t * 0.11);

      cR = max(cR, texture2D(causticMap, uv2R).r * 0.6);
      cG = max(cG, texture2D(causticMap, uv2G).g * 0.6);
      cB = max(cB, texture2D(causticMap, uv2B).b * 0.6);

      vec3 causticColor = vec3(cR, cG, cB);

      // Distance falloff (now relative to dynamic light position)
      float dist = length(vWorldPos.xz - innerLightPos.xz);
      float falloff = exp(-dist * dist * 0.25);

      // Tint with brand colors
      causticColor = causticColor * 0.5 + causticColor * colorBlue.rgb * 0.3 + causticColor * colorOrange.rgb * 0.08;

      // Scratch normal map
      vec3 scratchNorm = texture2D(scratchMap, vUv * 8.0).rgb * 2.0 - 1.0;
      float scratchHighlight = dot(scratchNorm, normalize(vec3(0.5, 1.0, 0.3))) * 0.03;

      // Fresnel reflection
      vec3 viewDir = normalize(cameraPosition - vWorldPos);
      float fresnel = pow(1.0 - max(dot(viewDir, vNormal), 0.0), 4.0) * 0.15;

      vec3 finalColor = baseColor
        + causticColor * causticIntensity * falloff
        + scratchHighlight
        + vec3(0.02, 0.03, 0.05) * fresnel;

      gl_FragColor = vec4(finalColor, 1.0);
    }
  `
});

// Floor geometry
const floorGeo = new THREE.PlaneGeometry(30, 30, 1, 1);
const floor = new THREE.Mesh(floorGeo, causticFloorMat);
floor.rotation.x = -PI / 2;
floor.position.y = -1.0;
floor.receiveShadow = true;
scene.add(floor);

// ============================================================
// HERO: GLASS HEXAGONAL PRISM WITH MICRO-DETAIL
// ============================================================

function createHexPrism(radius, height, segments = 6) {
  const shape = new THREE.Shape();
  for (let i = 0; i <= segments; i++) {
    const angle = (i / segments) * TWO_PI - PI / 6;
    const x = Math.cos(angle) * radius;
    const y = Math.sin(angle) * radius;
    if (i === 0) shape.moveTo(x, y);
    else shape.lineTo(x, y);
  }
  const extrudeSettings = { depth: height, bevelEnabled: true, bevelThickness: 0.08, bevelSize: 0.06, bevelSegments: 8, steps: 1 };
  const geo = new THREE.ExtrudeGeometry(shape, extrudeSettings);
  geo.computeVertexNormals();
  geo.center();
  return geo;
}

const shellConfigs = [
  { radius: 1.2, height: 2.0, ior: 1.55, color: '#1a6b99', roughness: 0.02, opacity: 0.7, speed: 0.15 },
  { radius: 1.0, height: 1.7, ior: 1.50, color: '#2a93c1', roughness: 0.03, opacity: 0.6, speed: -0.12 },
  { radius: 0.75, height: 1.3, ior: 1.45, color: '#44b8e8', roughness: 0.04, opacity: 0.5, speed: 0.1 }
];

const shells = [];
const heroGroup = new THREE.Group();
heroGroup.position.set(0, 0.8, 0);

shellConfigs.forEach((cfg, i) => {
  const geo = createHexPrism(cfg.radius, cfg.height);
  const mat = new THREE.MeshPhysicalMaterial({
    color: new THREE.Color(cfg.color),
    metalness: 0.0,
    roughness: cfg.roughness,
    transmission: 0.95,
    thickness: cfg.radius * 1.5,
    ior: cfg.ior,
    envMap: envMap,
    envMapIntensity: 1.5,
    transparent: true,
    opacity: cfg.opacity,
    side: THREE.DoubleSide,
    attenuationColor: new THREE.Color(cfg.color),
    attenuationDistance: 2.0,
    normalMap: scratchNormalMap,
    normalScale: new THREE.Vector2(0.04 + i * 0.01, 0.04 + i * 0.01),
    clearcoat: 0.3,
    clearcoatRoughness: 0.1
  });

  const mesh = new THREE.Mesh(geo, mat);
  mesh.castShadow = true;
  mesh.userData = { speed: cfg.speed, baseY: 0 };
  shells.push(mesh);
  heroGroup.add(mesh);
});

scene.add(heroGroup);

// ============================================================
// ENERGY RINGS
// ============================================================
const rings = [];
for (let i = 0; i < 3; i++) {
  const ringGeo = new THREE.TorusGeometry(1.6 + i * 0.3, 0.015, 6, 6);
  const ringMat = new THREE.MeshStandardMaterial({
    color: i === 1 ? ORANGE : BLUE,
    emissive: i === 1 ? ORANGE : BLUE,
    emissiveIntensity: 2.5,
    metalness: 0.8,
    roughness: 0.2
  });
  const ring = new THREE.Mesh(ringGeo, ringMat);
  ring.userData = {
    axis: new THREE.Vector3(
      Math.sin(i * PI / 3) * 0.3,
      1,
      Math.cos(i * PI / 3) * 0.3
    ).normalize(),
    speed: 0.3 + i * 0.15,
    phase: i * TWO_PI / 3
  };
  heroGroup.add(ring);
  rings.push(ring);
}

// ============================================================
// DEPTH ELEMENTS
// ============================================================
const depthElements = [];

const nearGeos = [
  new THREE.IcosahedronGeometry(0.25, 2),
  new THREE.OctahedronGeometry(0.3, 2),
  new THREE.DodecahedronGeometry(0.22, 2)
];
const nearPositions = [
  new THREE.Vector3(-2.5, 1.0, 4.0),
  new THREE.Vector3(2.0, 2.0, 3.5),
  new THREE.Vector3(0.5, 0.5, 4.5)
];

nearGeos.forEach((geo, i) => {
  const mat = new THREE.MeshPhysicalMaterial({
    color: i === 1 ? 0xf1420b : 0x2a93c1,
    metalness: 0,
    roughness: 0.05,
    transmission: 0.9,
    thickness: 0.5,
    ior: 1.5,
    envMap: envMap,
    envMapIntensity: 1.2,
    transparent: true,
    opacity: 0.6,
    normalMap: scratchNormalMap,
    normalScale: new THREE.Vector2(0.03, 0.03)
  });
  const mesh = new THREE.Mesh(geo, mat);
  mesh.position.copy(nearPositions[i]);
  mesh.userData = { rotSpeed: 0.2 + Math.random() * 0.3, floatSpeed: 0.5 + Math.random() * 0.3, floatAmp: 0.15 };
  scene.add(mesh);
  depthElements.push(mesh);
});

const farPositions = [
  new THREE.Vector3(-3.0, 1.5, -4.0),
  new THREE.Vector3(2.5, 0.5, -5.0),
  new THREE.Vector3(0, 2.5, -3.5)
];

nearGeos.forEach((geo, i) => {
  const mat = new THREE.MeshPhysicalMaterial({
    color: i === 0 ? 0xf1420b : 0x2a93c1,
    metalness: 0,
    roughness: 0.05,
    transmission: 0.9,
    thickness: 0.5,
    ior: 1.5,
    envMap: envMap,
    envMapIntensity: 1.0,
    transparent: true,
    opacity: 0.5,
    normalMap: scratchNormalMap,
    normalScale: new THREE.Vector2(0.02, 0.02)
  });
  const mesh = new THREE.Mesh(geo.clone(), mat);
  mesh.position.copy(farPositions[i]);
  mesh.userData = { rotSpeed: 0.15 + Math.random() * 0.2, floatSpeed: 0.3 + Math.random() * 0.2, floatAmp: 0.1 };
  scene.add(mesh);
  depthElements.push(mesh);
});

// ============================================================
// PARTICLES
// ============================================================
const particleCount = 300;
const particleGeo = new THREE.BufferGeometry();
const positions = new Float32Array(particleCount * 3);
const sizes = new Float32Array(particleCount);
const particleColors = new Float32Array(particleCount * 3);

for (let i = 0; i < particleCount; i++) {
  positions[i * 3]     = (Math.random() - 0.5) * 16;
  positions[i * 3 + 1] = Math.random() * 6 - 1;
  positions[i * 3 + 2] = (Math.random() - 0.5) * 16;
  sizes[i] = 0.02 + Math.random() * 0.04;

  const isOrange = Math.random() < 0.3;
  if (isOrange) {
    particleColors[i * 3] = 0.95; particleColors[i * 3 + 1] = 0.26; particleColors[i * 3 + 2] = 0.05;
  } else {
    particleColors[i * 3] = 0.17; particleColors[i * 3 + 1] = 0.58; particleColors[i * 3 + 2] = 0.76;
  }
}

particleGeo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
particleGeo.setAttribute('size', new THREE.BufferAttribute(sizes, 1));
particleGeo.setAttribute('color', new THREE.BufferAttribute(particleColors, 3));

const particleMat = new THREE.ShaderMaterial({
  uniforms: {
    time: { value: 0 },
    pixelRatio: { value: renderer.getPixelRatio() }
  },
  vertexShader: `
    attribute float size;
    attribute vec3 color;
    varying vec3 vColor;
    varying float vAlpha;
    uniform float time, pixelRatio;
    void main() {
      vColor = color;
      vec3 pos = position;
      pos.y += sin(time * 0.3 + position.x * 0.5) * 0.15;
      pos.x += sin(time * 0.2 + position.z * 0.3) * 0.1;
      vec4 mvPos = modelViewMatrix * vec4(pos, 1.0);
      float dist = -mvPos.z;
      vAlpha = smoothstep(12.0, 2.0, dist) * 0.6;
      gl_PointSize = size * 300.0 * pixelRatio / dist;
      gl_Position = projectionMatrix * mvPos;
    }
  `,
  fragmentShader: `
    varying vec3 vColor;
    varying float vAlpha;
    void main() {
      float d = length(gl_PointCoord - 0.5);
      if (d > 0.5) discard;
      float alpha = smoothstep(0.5, 0.1, d) * vAlpha;
      gl_FragColor = vec4(vColor, alpha);
    }
  `,
  transparent: true,
  depthWrite: false,
  blending: THREE.AdditiveBlending
});

const particles = new THREE.Points(particleGeo, particleMat);
scene.add(particles);

// ============================================================
// POST-PROCESSING (Night 12: Hex Bokeh + Half-Res Volumetrics)
// ============================================================

// Full-res depth target
const depthTarget = new THREE.WebGLRenderTarget(window.innerWidth, window.innerHeight, {
  minFilter: THREE.NearestFilter,
  magFilter: THREE.NearestFilter,
  format: THREE.RGBAFormat,
  type: THREE.FloatType
});
depthTarget.depthTexture = new THREE.DepthTexture();
depthTarget.depthTexture.type = THREE.FloatType;

// Half-res render target for volumetric pass
const halfResTarget = new THREE.WebGLRenderTarget(halfW, halfH, {
  minFilter: THREE.LinearFilter,
  magFilter: THREE.LinearFilter,
  format: THREE.RGBAFormat,
  type: THREE.HalfFloatType
});
halfResTarget.depthTexture = new THREE.DepthTexture();
halfResTarget.depthTexture.type = THREE.FloatType;

// Half-res composer for volumetric rendering
const halfResComposer = new EffectComposer(renderer, halfResTarget);
halfResComposer.setSize(halfW, halfH);
const halfResRenderPass = new RenderPass(scene, camera);
halfResComposer.addPass(halfResRenderPass);

const volPass = new ShaderPass({
  uniforms: volumetricConeShader.uniforms,
  vertexShader: volumetricConeShader.vertexShader,
  fragmentShader: volumetricConeShader.fragmentShader
});
volPass.uniforms.tDepth = { value: null };
halfResComposer.addPass(volPass);

// Full-res effect composer
const composer = new EffectComposer(renderer);
const renderPass = new RenderPass(scene, camera);
composer.addPass(renderPass);

// Hexagonal Bokeh DoF (replaces BokehPass)
const hexBokehPass = new ShaderPass(hexBokehShader);
hexBokehPass.uniforms.tDepth = { value: null };
composer.addPass(hexBokehPass);

// Bilateral upsample: composite half-res volumetric into full-res scene
const bilateralPass = new ShaderPass(bilateralUpsampleShader);
bilateralPass.uniforms.tVolumetric = { value: null };
bilateralPass.uniforms.tDepth = { value: null };
composer.addPass(bilateralPass);

// Bloom
const bloomPass = new UnrealBloomPass(
  new THREE.Vector2(window.innerWidth, window.innerHeight),
  0.45,   // intensity
  0.6,    // radius
  0.85    // threshold
);
composer.addPass(bloomPass);

// Final pass: CA + Vignette + Grain
const finalShader = {
  uniforms: {
    tDiffuse: { value: null },
    time: { value: 0 },
    caStrength: { value: 0.0015 },
    vignetteOffset: { value: 0.3 },
    vignetteDarkness: { value: 0.7 },
    grainIntensity: { value: 0.015 }
  },
  vertexShader: `
    varying vec2 vUv;
    void main() { vUv = uv; gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0); }
  `,
  fragmentShader: `
    uniform sampler2D tDiffuse;
    uniform float time, caStrength, vignetteOffset, vignetteDarkness, grainIntensity;
    varying vec2 vUv;

    void main() {
      vec2 center = vUv - 0.5;
      float dist = length(center);

      float caWeight = smoothstep(0.2, 0.7, dist);
      vec2 caOffset = center * caStrength * caWeight;

      float r = texture2D(tDiffuse, vUv + caOffset).r;
      float g = texture2D(tDiffuse, vUv).g;
      float b = texture2D(tDiffuse, vUv - caOffset).b;
      vec3 color = vec3(r, g, b);

      float vignette = smoothstep(vignetteOffset, vignetteOffset + 0.6, dist);
      color *= 1.0 - vignette * vignetteDarkness;

      float grain = fract(sin(dot(vUv + fract(time), vec2(12.9898, 78.233))) * 43758.5453);
      color += (grain - 0.5) * grainIntensity;

      gl_FragColor = vec4(color, 1.0);
    }
  `
};
const finalPass = new ShaderPass(finalShader);
composer.addPass(finalPass);

// ============================================================
// MOUSE TRACKING
// ============================================================
const mouse = new THREE.Vector2(0, 0);
const smoothMouse = new THREE.Vector2(0, 0);
window.addEventListener('mousemove', (e) => {
  mouse.x = (e.clientX / window.innerWidth) * 2 - 1;
  mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;
});

// ============================================================
// ANIMATION LOOP
// ============================================================
const clock = new THREE.Clock();
let cameraAngle = 0;

// Track hero shell rotations for dynamic caustic projection
let currentHeroRotY = 0;
let currentHeroRotX = 0;

function animate() {
  requestAnimationFrame(animate);
  const t = clock.getElapsedTime();
  const dt = clock.getDelta();

  // FPS counter
  fpsFrames++;
  if (t - fpsTime >= 1.0) {
    fpsEl.textContent = `${fpsFrames} FPS | half-res vol`;
    fpsFrames = 0;
    fpsTime = t;
  }

  // Smooth mouse
  smoothMouse.lerp(mouse, 0.04);

  // Camera orbit
  cameraAngle += 0.0008;
  const camRadius = 7.5 + Math.sin(t * 0.15) * 0.5;
  const camY = 3.5 + Math.sin(t * 0.1) * 0.3 + smoothMouse.y * 0.5;
  camera.position.x = Math.sin(cameraAngle + smoothMouse.x * 0.3) * camRadius;
  camera.position.z = Math.cos(cameraAngle + smoothMouse.x * 0.3) * camRadius;
  camera.position.y = camY;
  camera.lookAt(0, 0.5, 0);

  // Shell rotations (temporal parallax for chromatic dispersion)
  shells.forEach((shell, i) => {
    shell.rotation.y = t * shell.userData.speed;
    shell.rotation.x = Math.sin(t * 0.2 + i) * 0.08;
    shell.position.y = Math.sin(t * 0.4 + i * 0.7) * 0.05;
  });

  // Track average shell rotation for dynamic caustics
  currentHeroRotY = t * shellConfigs[0].speed;
  currentHeroRotX = Math.sin(t * 0.2) * 0.08;

  // Energy ring orbits
  rings.forEach((ring, i) => {
    const { axis, speed, phase } = ring.userData;
    const angle = t * speed + phase;
    const q = new THREE.Quaternion().setFromAxisAngle(axis, angle);
    ring.quaternion.copy(q);
    ring.material.emissiveIntensity = 2.0 + Math.sin(t * 2 + i) * 0.8;
  });

  // Depth elements
  depthElements.forEach(el => {
    el.rotation.x += el.userData.rotSpeed * 0.01;
    el.rotation.y += el.userData.rotSpeed * 0.015;
    el.position.y += Math.sin(t * el.userData.floatSpeed) * 0.001;
  });

  // Inner glow breathing
  innerGlow.intensity = 8 + Math.sin(t * 0.8) * 3;
  innerGlowOrange.intensity = 3 + Math.sin(t * 1.2 + 1) * 1.5;
  innerGlowOrange.position.x = 0.5 + Math.sin(t * 0.5) * 0.3;
  innerGlowOrange.position.z = 0.5 + Math.cos(t * 0.4) * 0.3;

  // Update uniforms
  causticFloorMat.uniforms.time.value = t;
  causticFloorMat.uniforms.heroRotY.value = currentHeroRotY;
  causticFloorMat.uniforms.heroRotX.value = currentHeroRotX;
  causticFloorMat.uniforms.innerLightPos.value.copy(innerGlowOrange.position);

  particleMat.uniforms.time.value = t;
  finalPass.uniforms.time.value = t;

  // Update volumetric pass uniforms
  volPass.uniforms.time.value = t;
  volPass.uniforms.cameraPos.value.copy(camera.position);
  volPass.uniforms.invProjectionMatrix.value.copy(camera.projectionMatrixInverse);
  volPass.uniforms.invViewMatrix.value.copy(camera.matrixWorld);

  // Hex bokeh focus breathing
  hexBokehPass.uniforms.focusDist.value = 7.5 + Math.sin(t * 0.25) * 0.15;

  // ---- RENDER PIPELINE ----

  // Step 1: Render full-res depth
  renderer.setRenderTarget(depthTarget);
  renderer.render(scene, camera);
  renderer.setRenderTarget(null);

  // Feed depth to hex bokeh and volumetric
  hexBokehPass.uniforms.tDepth.value = depthTarget.depthTexture;
  volPass.uniforms.tDepth.value = depthTarget.depthTexture;
  bilateralPass.uniforms.tDepth.value = depthTarget.depthTexture;

  // Step 2: Render half-res volumetric
  renderer.setRenderTarget(halfResTarget);
  renderer.setSize(halfW, halfH, false);
  halfResComposer.render();
  renderer.setSize(window.innerWidth, window.innerHeight, false);
  renderer.setRenderTarget(null);

  // Feed half-res volumetric to bilateral upsample
  bilateralPass.uniforms.tVolumetric.value = halfResTarget.texture;

  // Step 3: Full-res compose
  composer.render();
}

// ============================================================
// RESIZE
// ============================================================
window.addEventListener('resize', () => {
  const w = window.innerWidth;
  const h = window.innerHeight;
  const hw = Math.floor(w / 2);
  const hh = Math.floor(h / 2);

  camera.aspect = w / h;
  camera.updateProjectionMatrix();
  renderer.setSize(w, h);
  composer.setSize(w, h);
  depthTarget.setSize(w, h);
  halfResTarget.setSize(hw, hh);
  halfResComposer.setSize(hw, hh);
  volPass.uniforms.resolution.value.set(hw, hh);
  hexBokehPass.uniforms.resolution.value.set(w, h);
  bilateralPass.uniforms.resolution.value.set(w, h);
});

// Start
animate();
</script>
</body>
</html>
