async function fetchLiveMetrics() {
  try {
    const res = await fetch(PORTAL_API + '/api/admin/clients', {
      headers: { 'Authorization': 'Bearer ' + PORTAL_TOKEN }
    });
    if (!res.ok) throw new Error('Portal API ' + res.status);
    const data = await res.json();
    const clients = data.clients || [];

    // Calculate metrics
    const active = clients.filter(c => c.status === 'active' && ['subscription_active', 'paid'].includes(c.payment_status));
    const totalRevenue = active.reduce((s, c) => s + (c.total_paid || 0), 0);
    const totalClients = clients.length;
    const activeCount = active.length;

    // Tier breakdown (normalize tier names to lowercase for matching)
    const tierMap = { awakened: 0, insiders: 0, partnered: 0, unified: 0, enterprise: 0 };
    const tierRevenue = { awakened: 0, insiders: 0, partnered: 0, unified: 0, enterprise: 0 };
    active.forEach(c => {
      const t = (c.tier || '').toLowerCase();
      if (t in tierMap) { tierMap[t]++; tierRevenue[t] += (c.total_paid || 0); }
      else { tierMap.awakened++; tierRevenue.awakened += (c.total_paid || 0); } // default
    });

    // MRR estimation: use tier pricing for active subscribers
    const tierPricing = { awakened: 149, insiders: 79, partnered: 499, unified: 999, enterprise: 3500 };
    const mrr = Object.keys(tierMap).reduce((s, t) => s + tierMap[t] * (tierPricing[t] || 149), 0);
    const arr = mrr * 12;
    const avgSubValue = activeCount > 0 ? Math.round(mrr / activeCount) : 0;

    liveMetrics = { clients, active, totalRevenue, totalClients, activeCount, tierMap, tierRevenue, mrr, arr, avgSubValue };

    // Update DOM elements
    applyLiveMetrics(liveMetrics);
    // Auto-calculate RAG status from live data
    if (typeof calculateRAGStatus === 'function') calculateRAGStatus();
    console.log('[777] Live metrics loaded:', activeCount, 'active,', '$' + mrr, 'MRR');
    return liveMetrics;
  } catch(e) {
    console.warn('[777] Portal admin API failed, trying public stats:', e);
    try {
      const pubRes = await fetch(PORTAL_API + '/api/public/client-stats');
      if (pubRes.ok) {
        const pub = await pubRes.json();
        const tierMap = { awakened: pub.tiers?.awakened || 0, insiders: pub.tiers?.insiders || 0, partnered: pub.tiers?.partnered || 0, unified: pub.tiers?.unified || 0, enterprise: pub.tiers?.enterprise || 0 };
        const tierPricing = { awakened: 149, insiders: 79, partnered: 499, unified: 999, enterprise: 3500 };
        const activeCount = Object.values(tierMap).reduce((s, v) => s + v, 0);
        const mrr = Object.keys(tierMap).reduce((s, t) => s + tierMap[t] * (tierPricing[t] || 149), 0);
        liveMetrics = { clients: [], active: [], totalRevenue: pub.mrr || 0, totalClients: pub.subscribers || 0, activeCount, tierMap, tierRevenue: {}, mrr, arr: mrr * 12, avgSubValue: activeCount > 0 ? Math.round(mrr / activeCount) : 0 };
        applyLiveMetrics(liveMetrics);
        // Auto-calculate RAG status from live data
        if (typeof calculateRAGStatus === 'function') calculateRAGStatus();
        console.log('[777] Public stats loaded as fallback:', activeCount, 'active');
        return liveMetrics;
      }
    } catch(e2) { console.warn('[777] Public stats also failed:', e2); }
    return null;
  }
}

