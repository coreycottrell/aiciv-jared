<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>777 Command Center v2</title>
  <link rel="icon" href="https://purebrain.ai/wp-content/uploads/2026/02/purebrain-icon-1.png" type="image/png">
  <link rel="apple-touch-icon" href="https://purebrain.ai/wp-content/uploads/2026/02/purebrain-icon-1.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Oswald:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" defer></script>
  <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js" defer></script>
  <style>
/* ===================== DESIGN TOKENS ===================== */
:root {
  --bg: #080a12;
  --bg2: #0d1121;
  --bg3: #111729;
  --blue: #2a93c1;
  --blue-dim: rgba(42,147,193,0.15);
  --blue-glow: rgba(42,147,193,0.4);
  --orange: #f1420b;
  --orange-dim: rgba(241,66,11,0.12);
  --orange-glow: rgba(241,66,11,0.35);
  --text: #e8eaf6;
  --text-dim: #7a8aaa;
  --text-muted: #4a5570;
  --border: rgba(42,147,193,0.18);
  --border-bright: rgba(42,147,193,0.4);
  --green: #22c55e;
  --green-dim: rgba(34,197,94,0.15);
  --yellow: #eab308;
  --yellow-dim: rgba(234,179,8,0.15);
  --red: #ef4444;
  --red-dim: rgba(239,68,68,0.15);
  --purple: #a78bfa;
  --purple-dim: rgba(167,139,250,0.15);
  --card-bg: rgba(13,17,33,0.85);
  --glass: rgba(255,255,255,0.03);
  --glass-border: rgba(255,255,255,0.06);
  --sidebar-w: 280px;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Plus Jakarta Sans', sans-serif;
  min-height: 100vh;
  overflow-x: hidden;
}
body.locked { overflow: hidden; }

::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--blue); }

/* ===================== PASSWORD GATE ===================== */
#password-gate {
  position: fixed; inset: 0;
  background: var(--bg);
  z-index: 9999;
  display: flex; align-items: center; justify-content: center; flex-direction: column;
}
.gate-inner { text-align: center; max-width: 420px; width: 90%; }
.gate-logo {
  font-family: 'Oswald', sans-serif; font-size: 72px; font-weight: 700;
  letter-spacing: 4px; color: var(--orange); margin-bottom: 4px;
  text-shadow: 0 0 40px var(--orange-glow); line-height: 1;
}
.gate-tagline {
  font-family: 'Oswald', sans-serif; font-size: 13px; letter-spacing: 4px;
  color: var(--text-dim); text-transform: uppercase; margin-bottom: 48px;
}
.gate-label { font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: var(--text-dim); margin-bottom: 12px; }
.gate-input {
  width: 100%; padding: 16px 20px; background: var(--bg3);
  border: 1px solid var(--border); border-radius: 8px;
  color: var(--text); font-family: 'Oswald', sans-serif; font-size: 22px;
  letter-spacing: 6px; text-align: center; outline: none;
  transition: border-color 0.2s; margin-bottom: 16px;
}
.gate-input:focus { border-color: var(--blue); }
.gate-input.shake { animation: shake 0.4s ease; }
@keyframes shake { 0%,100% { transform: translateX(0); } 25% { transform: translateX(-8px); } 75% { transform: translateX(8px); } }
.gate-btn {
  width: 100%; padding: 14px; background: var(--orange); color: #fff; border: none;
  border-radius: 8px; font-family: 'Oswald', sans-serif; font-size: 16px;
  letter-spacing: 3px; text-transform: uppercase; cursor: pointer;
  transition: background-color 0.2s, transform 0.2s;
}
.gate-btn:hover { background: #d93a09; transform: translateY(-1px); }
.gate-error { color: var(--red); font-size: 12px; margin-top: 12px; opacity: 0; transition: opacity 0.2s; }
.gate-error.show { opacity: 1; }

/* ===================== TIMEZONE BAR ===================== */
.timezone-bar {
  display: flex; align-items: center; justify-content: center; gap: 24px;
  background: var(--bg); border-bottom: 1px solid var(--border);
  padding: 6px 16px; flex-wrap: wrap;
}
.tz-item {
  display: flex; align-items: center; gap: 6px;
  font-family: 'Oswald', sans-serif; font-size: 11px; letter-spacing: 1px;
}
.tz-label { color: var(--text-muted); text-transform: uppercase; }
.tz-time { color: var(--text); font-weight: 500; min-width: 62px; }
.tz-item.tz-highlight .tz-time { color: var(--orange); }

/* ===================== DASHBOARD ===================== */
#dashboard { display: none; opacity: 0; transition: opacity 0.6s ease; flex-direction: column; min-height: 100vh; }
#dashboard.visible { display: flex; opacity: 1; }

/* ===================== SIDEBAR ===================== */
.sidebar {
  width: var(--sidebar-w); min-width: var(--sidebar-w); height: 100vh;
  background: var(--bg2); border-right: 1px solid var(--border);
  position: sticky; top: 0; overflow-y: auto; overflow-x: hidden;
  flex-shrink: 0; z-index: 50; transition: transform 0.3s;
}
.sidebar-header {
  padding: 16px 20px; border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 12px;
}
.sidebar-brand { font-family: 'Oswald', sans-serif; font-size: 20px; font-weight: 700; letter-spacing: 2px; }
.sidebar-brand .num { color: var(--orange); }
.sidebar-brand .txt { color: var(--text); font-size: 12px; letter-spacing: 3px; opacity: 0.7; }

.sidebar-search {
  padding: 12px 16px;
}
.sidebar-search input {
  width: 100%; padding: 8px 12px; background: var(--bg3);
  border: 1px solid var(--border); border-radius: 6px;
  color: var(--text); font-size: 12px; outline: none;
}
.sidebar-search input:focus { border-color: var(--blue); }
.sidebar-search input::placeholder { color: var(--text-muted); }

.nav-group { margin-bottom: 4px; }
.nav-group-header {
  padding: 8px 20px; display: flex; align-items: center; gap: 8px;
  cursor: pointer; transition: background 0.15s; user-select: none;
}
.nav-group-header:hover { background: var(--glass); }
.nav-group-label {
  font-family: 'Oswald', sans-serif; font-size: 10px; letter-spacing: 2px;
  text-transform: uppercase; color: var(--text-dim); flex: 1;
}
.nav-group-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
.nav-group-chevron { font-size: 10px; color: var(--text-muted); transition: transform 0.2s; }
.nav-group.open .nav-group-chevron { transform: rotate(90deg); }
.nav-group-items { display: none; }
.nav-group.open .nav-group-items { display: block; }

.nav-item {
  padding: 6px 20px 6px 36px; font-size: 12px; color: var(--text-dim);
  cursor: pointer; transition: all 0.15s; white-space: nowrap;
  overflow: hidden; text-overflow: ellipsis;
}
.nav-item:hover { color: var(--text); background: var(--glass); }
.nav-item.active { color: var(--orange); background: var(--orange-dim); border-right: 2px solid var(--orange); }

/* ===================== MAIN CONTENT ===================== */
.main-content { flex: 1; min-width: 0; }

.site-header {
  padding: 12px 24px;
  display: flex; align-items: center; justify-content: space-between;
  border-bottom: 1px solid var(--border);
  background: rgba(8,10,18,0.95); backdrop-filter: blur(12px);
  position: sticky; top: 0; z-index: 40;
  gap: 12px; flex-wrap: wrap;
}
.header-left { display: flex; align-items: center; gap: 16px; }
.menu-toggle {
  display: none; width: 36px; height: 36px; border-radius: 8px;
  background: var(--bg3); border: 1px solid var(--border);
  color: var(--text-dim); cursor: pointer; font-size: 18px;
  align-items: center; justify-content: center;
}
.header-date { font-size: 11px; color: var(--text-dim); letter-spacing: 1px; font-family: 'Oswald', sans-serif; }
.header-right { display: flex; align-items: center; gap: 8px; }
.header-score-chip {
  background: var(--orange-dim); border: 1px solid var(--orange);
  border-radius: 20px; padding: 4px 14px;
  font-family: 'Oswald', sans-serif; font-size: 13px; color: var(--orange); letter-spacing: 1px;
}
.header-btn {
  width: 32px; height: 32px; border-radius: 8px;
  background: var(--bg3); border: 1px solid var(--border);
  color: var(--text-dim); cursor: pointer;
  display: flex; align-items: center; justify-content: center; font-size: 14px;
  transition: all 0.2s;
}
.header-btn:hover { border-color: var(--blue); color: var(--blue); }
.header-btn.spinning { animation: spin 0.8s linear; }
@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

.freshness-chip {
  display: inline-flex; align-items: center; gap: 4px; padding: 3px 10px;
  border-radius: 12px; font-size: 10px; font-family: 'Oswald', sans-serif;
  letter-spacing: 1px;
}
.freshness-chip.live { background: var(--green-dim); color: var(--green); border: 1px solid rgba(34,197,94,0.3); }
.freshness-chip.stale { background: var(--yellow-dim); color: var(--yellow); border: 1px solid rgba(234,179,8,0.3); }
.freshness-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; animation: pulse 2s infinite; }
@keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }

/* ===================== SECTION PANEL ===================== */
.section-panel { display: none; padding: 24px; max-width: 1600px; margin: 0 auto; }
.section-panel.active { display: block; }

.section-title {
  font-family: 'Oswald', sans-serif; font-size: 22px; font-weight: 700;
  letter-spacing: 2px; margin-bottom: 20px;
  display: flex; align-items: center; gap: 10px;
}
.section-title .dot { width: 8px; height: 8px; border-radius: 50%; }

/* ===================== GRID & CARDS ===================== */
.grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: 16px; }

.card {
  background: var(--card-bg); border: 1px solid var(--border); border-radius: 14px;
  padding: 20px; position: relative; overflow: hidden;
  backdrop-filter: blur(8px); transition: border-color 0.2s, transform 0.15s;
}
.card:hover { border-color: var(--border-bright); transform: translateY(-1px); }
.card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--blue-glow), transparent); opacity: 0.6;
}
.card-orange::before { background: linear-gradient(90deg, transparent, var(--orange-glow), transparent); }

.card-title {
  font-family: 'Oswald', sans-serif; font-size: 11px; letter-spacing: 3px;
  text-transform: uppercase; color: var(--text-dim); margin-bottom: 14px;
  display: flex; align-items: center; gap: 8px;
}
.card-title-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--blue); flex-shrink: 0; }
.card-title-dot.orange { background: var(--orange); }
.card-title-dot.green { background: var(--green); }
.card-title-dot.red { background: var(--red); }
.card-title-dot.purple { background: var(--purple); }
.card-timestamp { font-size: 9px; color: var(--text-muted); margin-left: auto; font-family: 'Oswald', sans-serif; letter-spacing: 1px; }

.col-12 { grid-column: span 12; } .col-8 { grid-column: span 8; }
.col-7 { grid-column: span 7; } .col-6 { grid-column: span 6; }
.col-5 { grid-column: span 5; } .col-4 { grid-column: span 4; }
.col-3 { grid-column: span 3; }
@media (max-width: 1200px) { .col-8,.col-7 { grid-column: span 12; } .col-6,.col-5 { grid-column: span 6; } .col-4,.col-3 { grid-column: span 6; } }
@media (max-width: 768px) {
  .grid { gap: 12px; }
  .col-12,.col-8,.col-7,.col-6,.col-5,.col-4,.col-3 { grid-column: span 12; }
  .sidebar { position: fixed; left: 0; top: 0; transform: translateX(-100%); z-index: 200; }
  .sidebar.open { transform: translateX(0); }
  .menu-toggle { display: flex; }
  .section-panel { padding: 16px 12px; }
}

/* ===================== METRIC STYLES ===================== */
.metric-big { font-family: 'Oswald', sans-serif; font-size: 36px; font-weight: 700; line-height: 1; }
.metric-label { font-size: 11px; color: var(--text-dim); margin-top: 4px; letter-spacing: 1px; font-family: 'Oswald', sans-serif; text-transform: uppercase; }
.metric-delta { font-size: 12px; font-weight: 600; margin-top: 4px; }
.metric-delta.up { color: var(--green); } .metric-delta.down { color: var(--red); } .metric-delta.flat { color: var(--text-dim); }

.progress-bar { width: 100%; height: 6px; background: var(--bg3); border-radius: 3px; overflow: hidden; margin-top: 8px; }
.progress-fill { height: 100%; border-radius: 3px; transition: width 0.6s ease; }
.progress-fill.orange { background: linear-gradient(90deg, var(--orange), #ff6b35); }
.progress-fill.blue { background: linear-gradient(90deg, var(--blue), #60a5fa); }
.progress-fill.green { background: linear-gradient(90deg, var(--green), #4ade80); }

/* ===================== BADGES ===================== */
.badge {
  display: inline-block; padding: 2px 10px; border-radius: 12px; font-size: 10px;
  font-family: 'Oswald', sans-serif; letter-spacing: 1px; text-transform: uppercase; font-weight: 500;
}
.badge-green { background: var(--green-dim); color: var(--green); border: 1px solid rgba(34,197,94,0.3); }
.badge-yellow { background: var(--yellow-dim); color: var(--yellow); border: 1px solid rgba(234,179,8,0.3); }
.badge-red { background: var(--red-dim); color: var(--red); border: 1px solid rgba(239,68,68,0.3); }
.badge-blue { background: var(--blue-dim); color: var(--blue); border: 1px solid rgba(42,147,193,0.3); }
.badge-orange { background: var(--orange-dim); color: var(--orange); border: 1px solid rgba(241,66,11,0.3); }

/* ===================== TABLES ===================== */
.data-table { width: 100%; border-collapse: collapse; font-size: 12px; }
.data-table th { text-align: left; font-family: 'Oswald', sans-serif; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--text-muted); padding: 8px 10px; border-bottom: 1px solid var(--border); }
.data-table td { padding: 10px 10px; border-bottom: 1px solid rgba(255,255,255,0.03); vertical-align: middle; }
.data-table tr:hover td { background: var(--glass); }

/* ===================== BUTTONS ===================== */
.btn {
  display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px;
  border-radius: 8px; font-family: 'Oswald', sans-serif; font-size: 11px;
  letter-spacing: 1px; text-transform: uppercase; cursor: pointer;
  transition: all 0.2s; border: 1px solid transparent;
}
.btn-orange { background: var(--orange); color: #fff; border-color: var(--orange); }
.btn-orange:hover { background: #d93a09; transform: translateY(-1px); }
.btn-outline { background: transparent; color: var(--text-dim); border-color: var(--border); }
.btn-outline:hover { border-color: var(--blue); color: var(--blue); }
.btn-sm { padding: 4px 10px; font-size: 10px; }

/* ===================== DAILY CHECKLIST ===================== */
.checklist-items { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
@media (max-width: 768px) { .checklist-items { grid-template-columns: 1fr; } }
.check-item {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 12px; background: var(--bg3);
  border: 1px solid rgba(255,255,255,0.05); border-radius: 8px;
  cursor: pointer; transition: all 0.2s; user-select: none;
}
.check-item:hover { border-color: var(--border); }
.check-item.done { border-color: rgba(34,197,94,0.3); background: rgba(34,197,94,0.06); }
.check-item.half { border-color: rgba(234,179,8,0.3); background: rgba(234,179,8,0.06); }
.check-box {
  width: 22px; height: 22px; border: 2px solid var(--text-muted); border-radius: 4px;
  flex-shrink: 0; display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 700; transition: all 0.2s;
}
.check-item.done .check-box { background: var(--green); border-color: var(--green); color: #fff; }
.check-item.half .check-box { background: var(--yellow); border-color: var(--yellow); color: #000; }
.check-label { flex: 1; font-size: 12px; }
.check-score { font-family: 'Oswald', sans-serif; font-size: 14px; color: var(--text-dim); min-width: 30px; text-align: right; }

/* ===================== SCORE SELECTOR ===================== */
.score-btns { display: flex; gap: 3px; }
.score-btn {
  width: 28px; height: 24px; border-radius: 4px; border: 1px solid var(--border);
  background: var(--bg); color: var(--text-dim); font-size: 10px;
  font-family: 'Oswald', sans-serif; cursor: pointer; transition: all 0.15s;
  display: flex; align-items: center; justify-content: center;
}
.score-btn:hover { border-color: var(--blue); color: var(--blue); }
.score-btn.active { background: var(--orange); border-color: var(--orange); color: #fff; }

/* ===================== TASK INPUT ===================== */
.task-input-row {
  display: flex; gap: 8px; margin-top: 12px;
}
.task-input-row input {
  flex: 1; padding: 10px 14px; background: var(--bg3);
  border: 1px solid var(--border); border-radius: 8px;
  color: var(--text); font-size: 13px; outline: none;
}
.task-input-row input:focus { border-color: var(--blue); }
.task-input-row input::placeholder { color: var(--text-muted); }

/* ===================== HEATMAP ===================== */
.heatmap-grid { display: flex; gap: 3px; }
.heatmap-months { display: flex; gap: 3px; padding-left: 22px; margin-bottom: 4px; }
.heatmap-month-label { flex: 1; text-align: center; font-size: 9px; color: var(--text-muted); font-family: 'Oswald', sans-serif; letter-spacing: 1px; }
.heatmap-days-col { display: flex; flex-direction: column; gap: 3px; font-size: 9px; color: var(--text-muted); font-family: 'Oswald', sans-serif; width: 18px; }
.heatmap-days-col span { height: 12px; display: flex; align-items: center; }
.heatmap-weeks { display: flex; gap: 3px; flex: 1; }
.heatmap-week { display: flex; flex-direction: column; gap: 3px; flex: 1; }
.heatmap-cell { aspect-ratio: 1; border-radius: 2px; cursor: pointer; transition: transform 0.1s; }
.heatmap-cell:hover { transform: scale(1.3); z-index: 10; }
.heat-0 { background: #1a1f2e; } .heat-1 { background: #0e3a2a; }
.heat-2 { background: #0a5c3c; } .heat-3 { background: #0d7a4a; }
.heat-4 { background: #1a9958; } .heat-5 { background: var(--orange); }

/* ===================== STRATEGIC TIMELINE ===================== */
.timeline-container { position: relative; padding: 0 0 40px 0; }
.timeline-phases { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0; margin-bottom: 24px; border-radius: 10px; overflow: hidden; }
.timeline-phase { padding: 12px 16px; text-align: center; }
.timeline-phase-label { font-family: 'Oswald', sans-serif; font-size: 13px; letter-spacing: 3px; text-transform: uppercase; font-weight: 600; }
.timeline-phase-sub { font-size: 10px; color: var(--text-dim); margin-top: 2px; letter-spacing: 1px; }
.phase-1 { background: rgba(241,66,11,0.08); border: 1px solid rgba(241,66,11,0.2); }
.phase-1 .timeline-phase-label { color: var(--orange); }
.phase-2 { background: rgba(42,147,193,0.08); border: 1px solid rgba(42,147,193,0.2); border-left: none; }
.phase-2 .timeline-phase-label { color: var(--blue); }
.phase-3 { background: rgba(34,197,94,0.08); border: 1px solid rgba(34,197,94,0.2); border-left: none; }
.phase-3 .timeline-phase-label { color: var(--green); }

.track-block { margin-bottom: 32px; position: relative; }
.track-header { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
.track-icon { width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; }
.track-title { font-family: 'Oswald', sans-serif; font-size: 16px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; }
.track-subtitle { font-size: 11px; color: var(--text-dim); margin-top: 2px; }
.track-progress-info { margin-left: auto; text-align: right; }
.track-progress-value { font-family: 'Oswald', sans-serif; font-size: 20px; font-weight: 700; }
.track-progress-label { font-size: 10px; color: var(--text-dim); letter-spacing: 1px; text-transform: uppercase; }

.track-line-wrap { position: relative; padding: 0 8px; margin-bottom: 8px; }
.track-line { position: relative; height: 4px; border-radius: 2px; background: var(--bg3); }
.track-line-fill { position: absolute; top: 0; left: 0; height: 100%; border-radius: 2px; transition: width 1s ease; }
.track-line-fill.gold { background: linear-gradient(90deg, #f59e0b, #fbbf24); box-shadow: 0 0 12px rgba(245,158,11,0.4); }
.track-line-fill.teal { background: linear-gradient(90deg, #06b6d4, #22d3ee); box-shadow: 0 0 12px rgba(6,182,212,0.4); }
.track-line-fill.emerald { background: linear-gradient(90deg, #10b981, #34d399); box-shadow: 0 0 12px rgba(16,185,129,0.4); }

.milestone-dots { position: absolute; top: 50%; left: 0; right: 0; height: 0; }
.ms-dot {
  position: absolute; top: -8px; width: 16px; height: 16px; border-radius: 50%;
  transform: translateX(-50%); cursor: pointer; transition: all 0.2s; z-index: 5;
  display: flex; align-items: center; justify-content: center;
}
.ms-dot.completed { background: var(--green); border: 2px solid #4ade80; box-shadow: 0 0 8px rgba(34,197,94,0.5); }
.ms-dot.completed::after { content: '\2713'; color: #fff; font-size: 9px; font-weight: 700; }
.ms-dot.current { border: 2px solid; animation: ms-pulse 2s infinite; }
.ms-dot.current.gold { background: rgba(245,158,11,0.3); border-color: #f59e0b; box-shadow: 0 0 16px rgba(245,158,11,0.6); }
.ms-dot.current.teal { background: rgba(6,182,212,0.3); border-color: #06b6d4; box-shadow: 0 0 16px rgba(6,182,212,0.6); }
.ms-dot.current.emerald { background: rgba(16,185,129,0.3); border-color: #10b981; box-shadow: 0 0 16px rgba(16,185,129,0.6); }
.ms-dot.future { background: var(--bg3); border: 2px solid var(--text-muted); opacity: 0.5; }
.ms-dot:hover { transform: translateX(-50%) scale(1.4); opacity: 1; z-index: 10; }
@keyframes ms-pulse { 0%,100% { box-shadow: 0 0 8px currentColor; } 50% { box-shadow: 0 0 20px currentColor; } }

.ms-tooltip {
  display: none; position: absolute; bottom: calc(100% + 16px); left: 50%; transform: translateX(-50%);
  background: var(--bg2); border: 1px solid var(--border-bright); border-radius: 10px;
  padding: 12px 16px; min-width: 220px; max-width: 300px; z-index: 100;
  box-shadow: 0 8px 32px rgba(0,0,0,0.5); pointer-events: none;
}
.ms-dot:hover .ms-tooltip { display: block; }
.ms-tooltip-title { font-family: 'Oswald', sans-serif; font-size: 12px; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 6px; }
.ms-tooltip-phase { font-size: 10px; color: var(--text-dim); margin-bottom: 4px; }
.ms-tooltip-detail { font-size: 11px; color: var(--text-dim); line-height: 1.5; }
.ms-tooltip::after { content: ''; position: absolute; top: 100%; left: 50%; transform: translateX(-50%); border: 6px solid transparent; border-top-color: var(--border-bright); }

.offshoot-container { margin-top: 12px; display: flex; flex-wrap: wrap; gap: 8px; padding-left: 8px; }
.offshoot-card {
  display: flex; align-items: center; gap: 8px; padding: 8px 14px;
  border-radius: 8px; font-size: 11px; cursor: pointer; transition: all 0.2s;
  border: 1px dashed;
}
.offshoot-card:hover { transform: translateY(-2px); }
.offshoot-trigger { font-family: 'Oswald', sans-serif; font-size: 10px; letter-spacing: 1px; text-transform: uppercase; font-weight: 600; }
.offshoot-label { color: var(--text); }
.offshoot-card.gold { border-color: rgba(245,158,11,0.3); background: rgba(245,158,11,0.06); }
.offshoot-card.gold .offshoot-trigger { color: #f59e0b; }
.offshoot-card.teal { border-color: rgba(6,182,212,0.3); background: rgba(6,182,212,0.06); }
.offshoot-card.teal .offshoot-trigger { color: #06b6d4; }
.offshoot-card.emerald { border-color: rgba(16,185,129,0.3); background: rgba(16,185,129,0.06); }
.offshoot-card.emerald .offshoot-trigger { color: #10b981; }

.metrics-sidebar-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }
@media (max-width: 1200px) { .metrics-sidebar-grid { grid-template-columns: 1fr; } }
.metrics-phase-card { border-radius: 12px; padding: 16px; }
.metrics-phase-title { font-family: 'Oswald', sans-serif; font-size: 12px; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
.metrics-phase-title .dot { width: 6px; height: 6px; border-radius: 50%; }
.metrics-target { display: flex; align-items: center; gap: 8px; padding: 5px 0; font-size: 11px; color: var(--text-dim); }
.metrics-target .target-check { width: 14px; height: 14px; border-radius: 3px; border: 1px solid var(--text-muted); display: flex; align-items: center; justify-content: center; font-size: 8px; flex-shrink: 0; }
.metrics-target.done .target-check { background: var(--green); border-color: var(--green); color: #fff; }
.metrics-target.done { color: var(--text); }

.flywheel-wrap { display: flex; align-items: center; justify-content: center; padding: 20px; }
.flywheel-svg { max-width: 340px; width: 100%; }

/* ===================== RING ===================== */
.ring-container { position: relative; width: 110px; height: 110px; }
.ring-container canvas { position: absolute; top: 0; left: 0; }
.ring-label { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); text-align: center; }
.ring-score { font-family: 'Oswald', sans-serif; font-size: 28px; font-weight: 700; color: var(--orange); line-height: 1; }
.ring-max { font-size: 11px; color: var(--text-dim); }

/* ===================== STREAKS ===================== */
.streak-item { display: flex; align-items: center; gap: 10px; padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,0.03); }
.streak-icon { font-size: 16px; width: 24px; text-align: center; }
.streak-name { font-size: 11px; font-weight: 600; }
.streak-days { font-size: 10px; color: var(--text-dim); }
.streak-badge { font-family: 'Oswald', sans-serif; font-size: 18px; font-weight: 700; color: var(--orange); margin-left: auto; }

/* ===================== SPARKLINES ===================== */
.sparklines-row { display: flex; gap: 16px; margin-top: 12px; flex-wrap: wrap; }
.sparkline-item { flex: 1; min-width: 80px; }
.sparkline-label { font-size: 10px; color: var(--text-muted); margin-bottom: 4px; font-family: 'Oswald', sans-serif; letter-spacing: 1px; text-transform: uppercase; }
.sparkline-svg { width: 100%; height: 32px; }

/* ===================== RADAR ===================== */
.radar-wrap { display: flex; gap: 20px; flex-wrap: wrap; align-items: flex-start; }
.radar-chart-area { flex: 1; min-width: 200px; max-width: 300px; }
.f-details { flex: 1; min-width: 180px; }
.f-item { display: flex; align-items: center; gap: 10px; padding: 6px 10px; border-radius: 6px; margin-bottom: 4px; cursor: pointer; transition: background 0.15s; }
.f-item:hover { background: var(--glass); }
.f-item.active { background: var(--blue-dim); }
.f-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.f-label { font-size: 12px; flex: 1; font-weight: 600; }
.f-score { font-family: 'Oswald', sans-serif; font-size: 16px; font-weight: 600; }
.f-bar { flex: 2; height: 4px; background: var(--bg3); border-radius: 2px; overflow: hidden; }
.f-bar-fill { height: 100%; border-radius: 2px; transition: width 0.6s; }
.f-detail-card { background: var(--blue-dim); border: 1px solid var(--border); border-radius: 10px; padding: 14px; margin-top: 12px; display: none; }
.f-detail-card.show { display: block; }

/* ===================== GOAL MOUNTAIN ===================== */
.mountain-level { background: var(--bg3); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; margin-bottom: 6px; }
.mountain-level-header { padding: 10px 16px; display: flex; align-items: center; gap: 10px; cursor: pointer; transition: background 0.15s; }
.mountain-level-header:hover { background: var(--glass); }
.mountain-level-icon { font-size: 16px; }
.mountain-level-name { font-family: 'Oswald', sans-serif; font-size: 12px; letter-spacing: 2px; text-transform: uppercase; color: var(--text-dim); flex: 1; }
.mountain-level-count { font-size: 11px; color: var(--text-muted); }
.mountain-level-chevron { font-size: 12px; color: var(--text-muted); transition: transform 0.2s; }
.mountain-level.open .mountain-level-chevron { transform: rotate(90deg); }
.mountain-level-body { display: none; padding: 0 16px 12px; }
.mountain-level.open .mountain-level-body { display: block; }
.goal-item { display: flex; align-items: center; gap: 10px; padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.03); font-size: 12px; }

/* ===================== PROOF WALL ===================== */
.counter-number {
  font-family: 'Oswald', sans-serif; font-size: 56px; font-weight: 700;
  color: var(--orange); line-height: 1; text-shadow: 0 0 40px var(--orange-glow); letter-spacing: -1px;
}
.counter-label { font-size: 12px; color: var(--text-dim); letter-spacing: 2px; text-transform: uppercase; margin-top: 4px; }
.task-feed-item { display: flex; align-items: center; gap: 10px; padding: 8px 12px; background: var(--bg3); border-radius: 8px; font-size: 12px; margin-bottom: 4px; }

/* ===================== TRIANGLE DELIVERABLES LOG ===================== */
.deliv-stats-bar { display: flex; justify-content: center; gap: 32px; margin-bottom: 24px; flex-wrap: wrap; }
.deliv-stat { text-align: center; }
.deliv-stat-num { font-family: 'Oswald', sans-serif; font-size: 36px; font-weight: 700; color: var(--orange); line-height: 1; text-shadow: 0 0 20px var(--orange-glow); }
.deliv-stat-label { font-size: 10px; color: var(--text-dim); letter-spacing: 2px; text-transform: uppercase; margin-top: 4px; }
.deliv-view-tabs { display: flex; gap: 6px; margin-bottom: 20px; flex-wrap: wrap; }
.deliv-view-tab { padding: 6px 16px; border-radius: 6px; font-size: 11px; font-weight: 600; cursor: pointer; background: var(--bg3); color: var(--text-dim); border: 1px solid var(--glass-border); transition: all .2s; text-transform: uppercase; letter-spacing: 1px; }
.deliv-view-tab:hover { color: var(--text); border-color: var(--border); }
.deliv-view-tab.active { background: var(--orange-dim); color: var(--orange); border-color: rgba(241,66,11,0.4); }
.deliv-cols { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
@media (max-width: 900px) { .deliv-cols { grid-template-columns: 1fr; } }
.deliv-col { background: var(--bg3); border-radius: 12px; border: 1px solid var(--glass-border); padding: 16px; min-height: 200px; }
.deliv-col-header { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; padding-bottom: 10px; border-bottom: 1px solid var(--glass-border); }
.deliv-avatar { width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px; flex-shrink: 0; }
.deliv-avatar-jared { background: linear-gradient(135deg, #eab308, #f59e0b); }
.deliv-avatar-aether { background: linear-gradient(135deg, var(--blue), #6366f1); }
.deliv-avatar-chy { background: linear-gradient(135deg, var(--orange), #ef4444); }
.deliv-col-name { font-weight: 700; font-size: 13px; letter-spacing: 1px; text-transform: uppercase; font-family: 'Oswald', sans-serif; }
.deliv-col-count { font-size: 10px; color: var(--text-dim); margin-left: auto; }
.deliv-card { background: var(--card-bg); border-radius: 8px; padding: 10px 12px; margin-bottom: 6px; border: 1px solid var(--glass-border); transition: all .25s; }
.deliv-card:hover { border-color: var(--border-bright); box-shadow: 0 0 12px rgba(42,147,193,0.15); }
.deliv-card-text { font-size: 12px; line-height: 1.5; margin-bottom: 6px; }
.deliv-card-meta { display: flex; align-items: center; gap: 8px; }
.deliv-tag { font-size: 9px; padding: 2px 8px; border-radius: 4px; font-weight: 600; text-transform: uppercase; letter-spacing: .5px; }
.deliv-tag-product { background: var(--blue-dim); color: var(--blue); }
.deliv-tag-sales { background: var(--green-dim); color: var(--green); }
.deliv-tag-marketing { background: var(--purple-dim); color: var(--purple); }
.deliv-tag-operations { background: var(--orange-dim); color: var(--orange); }
.deliv-tag-finance { background: rgba(234,179,8,0.15); color: #eab308; }
.deliv-tag-hr { background: rgba(20,184,166,0.15); color: #14b8a6; }
.deliv-tag-infrastructure { background: rgba(148,163,184,0.15); color: #94a3b8; }
.deliv-tag-customer-support { background: var(--red-dim); color: var(--red); }
.deliv-tag-strategic { background: linear-gradient(90deg, rgba(234,179,8,0.15), var(--blue-dim)); color: #eab308; }
.deliv-time { font-size: 9px; color: var(--text-muted); margin-left: auto; }
.deliv-input-row { display: flex; gap: 8px; margin-top: 10px; }
.deliv-input-row input { flex: 1; background: var(--bg); border: 1px solid var(--border); border-radius: 6px; padding: 8px 10px; color: var(--text); font-size: 11px; font-family: inherit; }
.deliv-input-row input:focus { border-color: var(--blue); outline: none; }
.deliv-input-row select { background: var(--bg); border: 1px solid var(--border); border-radius: 6px; padding: 8px 6px; color: var(--text); font-size: 11px; font-family: inherit; cursor: pointer; }
.deliv-input-row select:focus { border-color: var(--blue); outline: none; }
.deliv-input-row button { white-space: nowrap; }
.deliv-weekly-chart { margin-top: 20px; }
.deliv-bar-row { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; }
.deliv-bar-label { width: 80px; font-size: 11px; color: var(--text-dim); text-align: right; }
.deliv-bar-track { flex: 1; height: 24px; background: rgba(255,255,255,0.04); border-radius: 6px; overflow: hidden; display: flex; }
.deliv-bar-seg { height: 100%; display: flex; align-items: center; justify-content: center; font-size: 9px; font-weight: 700; color: #fff; transition: width .8s ease; min-width: 0; }
.deliv-monthly-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
@media (max-width: 768px) { .deliv-monthly-grid { grid-template-columns: 1fr; } }
.deliv-monthly-card { background: var(--bg3); border-radius: 10px; padding: 16px; border: 1px solid var(--glass-border); text-align: center; }
.deliv-monthly-name { font-family: 'Oswald', sans-serif; font-size: 14px; font-weight: 600; margin-bottom: 4px; }
.deliv-monthly-num { font-family: 'Oswald', sans-serif; font-size: 28px; font-weight: 700; color: var(--orange); }
.deliv-monthly-sub { font-size: 10px; color: var(--text-dim); }
.deliv-yearly-tabs { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
.deliv-yearly-tab { padding: 6px 14px; border-radius: 6px; font-size: 11px; font-weight: 600; cursor: pointer; background: var(--bg3); color: var(--text-dim); border: 1px solid var(--glass-border); transition: all .2s; }
.deliv-yearly-tab.active { background: var(--blue-dim); color: var(--blue); border-color: rgba(42,147,193,0.4); }
.deliv-auto-note { margin-top: 16px; padding: 10px 14px; background: rgba(42,147,193,0.08); border: 1px solid var(--border); border-radius: 8px; font-size: 11px; color: var(--text-dim); line-height: 1.6; }
.deliv-empty { text-align: center; color: var(--text-muted); font-size: 12px; padding: 30px; font-style: italic; }
.deliv-search-row { display: flex; gap: 8px; margin-bottom: 16px; }
.deliv-search-row input { flex: 1; background: var(--bg); border: 1px solid var(--border); border-radius: 6px; padding: 8px 12px; color: var(--text); font-size: 12px; font-family: inherit; }
.deliv-search-row input:focus { border-color: var(--blue); outline: none; }

/* ===================== MONEY MAP ===================== */
.money-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.money-stat { padding: 12px; background: var(--bg3); border-radius: 10px; border: 1px solid var(--glass-border); text-align: center; }
.money-label { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--text-dim); margin-bottom: 6px; font-family: 'Oswald', sans-serif; }
.money-value { font-family: 'Oswald', sans-serif; font-size: 26px; font-weight: 700; line-height: 1; }
.number-track { height: 8px; background: rgba(255,255,255,0.06); border-radius: 4px; overflow: hidden; margin: 8px 0; }
.number-fill { height: 100%; background: linear-gradient(90deg, var(--blue), var(--orange)); border-radius: 4px; transition: width 1.5s ease; }

/* ===================== RELATIONSHIP ===================== */
.rel-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 10px; }
.rel-card { padding: 12px; background: var(--bg3); border-radius: 10px; border: 1px solid var(--glass-border); text-align: center; font-size: 12px; }
.rel-avatar {
  width: 40px; height: 40px; border-radius: 50%; background: var(--blue-dim);
  margin: 0 auto 8px; display: flex; align-items: center; justify-content: center;
  font-family: 'Oswald', sans-serif; font-size: 16px; color: var(--blue);
}
.rel-name { font-weight: 600; margin-bottom: 2px; }
.rel-days { font-size: 10px; }
.days-green { color: var(--green); } .days-yellow { color: var(--yellow); } .days-red { color: var(--red); }

/* ===================== LEGACY ===================== */
.eulogy-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 16px; }
@media (max-width: 768px) { .eulogy-grid { grid-template-columns: 1fr; } .money-grid { grid-template-columns: 1fr; } }
.eulogy-item { background: var(--bg3); border: 1px solid rgba(255,255,255,0.05); border-radius: 8px; padding: 10px 12px; }
.eulogy-who { font-size: 10px; color: var(--text-dim); font-family: 'Oswald', sans-serif; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 4px; }
.eulogy-text { font-size: 12px; line-height: 1.4; }

.epitaph-card {
  background: var(--orange-dim); border: 1px solid rgba(241,66,11,0.3);
  border-radius: 10px; padding: 14px 18px; margin-bottom: 16px; text-align: center;
}
.epitaph-label { font-family: 'Oswald', sans-serif; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: var(--orange); margin-bottom: 8px; }
.epitaph-text { font-size: 15px; line-height: 1.5; font-weight: 600; }

/* ===================== VISION CARD ===================== */
.vision-card {
  background: linear-gradient(135deg, rgba(42,147,193,0.1), rgba(241,66,11,0.05));
  border: 1px solid var(--border); border-radius: 10px; padding: 16px; margin-bottom: 16px;
}
.vision-label { font-family: 'Oswald', sans-serif; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: var(--blue); margin-bottom: 8px; }
.vision-text { font-size: 14px; line-height: 1.6; font-style: italic; }

/* ===================== MICRO LAWS ===================== */
.law-item {
  display: flex; align-items: flex-start; gap: 10px; padding: 7px 0;
  border-bottom: 1px solid rgba(255,255,255,0.04); font-size: 12px; color: var(--text-dim);
}
.law-num { font-family: 'Oswald', sans-serif; font-size: 14px; color: var(--orange); font-weight: 700; width: 20px; flex-shrink: 0; }

/* ===================== THINKING EXERCISES ===================== */
.thinking-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
@media (max-width: 1200px) { .thinking-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 768px) { .thinking-grid { grid-template-columns: 1fr; } }
.thinking-card {
  padding: 14px; background: var(--bg3); border: 1px solid var(--glass-border);
  border-radius: 10px; cursor: pointer; transition: all 0.2s;
}
.thinking-card:hover { border-color: var(--blue); transform: translateY(-2px); }
.thinking-card-icon { font-size: 20px; margin-bottom: 8px; }
.thinking-card-name { font-family: 'Oswald', sans-serif; font-size: 12px; letter-spacing: 1px; margin-bottom: 4px; }
.thinking-card-desc { font-size: 10px; color: var(--text-dim); line-height: 1.4; }

/* ===================== CALENDAR ===================== */
.cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; }
.cal-header { font-family: 'Oswald', sans-serif; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--text-muted); text-align: center; padding: 8px 0; }
.cal-day {
  aspect-ratio: 1; background: var(--bg3); border: 1px solid var(--glass-border);
  border-radius: 6px; padding: 4px; font-size: 11px; cursor: pointer; transition: all 0.15s;
  display: flex; flex-direction: column;
}
.cal-day:hover { border-color: var(--blue); }
.cal-day.today { border-color: var(--orange); background: var(--orange-dim); }
.cal-day.empty { background: transparent; border-color: transparent; cursor: default; }
.cal-day-num { font-family: 'Oswald', sans-serif; font-weight: 600; }
.cal-day-dots { display: flex; gap: 2px; margin-top: auto; flex-wrap: wrap; }
.cal-day-dot { width: 4px; height: 4px; border-radius: 50%; }

/* ===================== QUICK STATS BANNER ===================== */
.quick-stats { display: flex; gap: 12px; padding: 16px 24px; flex-wrap: wrap; }
.qs-card {
  flex: 1; min-width: 140px; background: var(--card-bg);
  border: 1px solid var(--border); border-radius: 12px;
  padding: 12px 16px; display: flex; align-items: center; gap: 12px;
  backdrop-filter: blur(8px); position: relative; overflow: hidden;
}
.qs-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, var(--blue-glow), transparent); opacity: 0.5; }
.qs-icon { font-size: 20px; }
.qs-value { font-family: 'Oswald', sans-serif; font-size: 24px; font-weight: 700; line-height: 1; color: var(--orange); }
.qs-label { font-size: 10px; color: var(--text-dim); letter-spacing: 1px; font-family: 'Oswald', sans-serif; text-transform: uppercase; }
@media (max-width: 768px) { .quick-stats { padding: 12px; } .qs-card { flex: 0 0 calc(50% - 6px); } .qs-value { font-size: 20px; } }

/* ===================== QUOTE STRIPE ===================== */
.quote-stripe {
  background: linear-gradient(90deg, transparent, var(--blue-dim), transparent);
  border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
  padding: 14px 32px; text-align: center; font-style: italic; color: var(--text-dim); font-size: 13px;
}
.quote-stripe strong { color: var(--blue); font-style: normal; }

/* ===================== GRATITUDE / JOURNAL ===================== */
.journal-entry {
  padding: 12px; background: var(--bg3); border: 1px solid var(--glass-border);
  border-radius: 8px; margin-bottom: 8px;
}
.journal-date { font-size: 10px; color: var(--text-muted); font-family: 'Oswald', sans-serif; letter-spacing: 1px; margin-bottom: 4px; }
.journal-text { font-size: 12px; line-height: 1.5; }

.journal-input {
  width: 100%; padding: 10px 14px; background: var(--bg3);
  border: 1px solid var(--border); border-radius: 8px;
  color: var(--text); font-size: 13px; outline: none; resize: vertical; min-height: 60px;
  font-family: 'Plus Jakarta Sans', sans-serif;
}
.journal-input:focus { border-color: var(--blue); }

/* ===================== COUNTDOWN ===================== */
.countdown-display { font-family: 'Oswald', sans-serif; font-size: 28px; font-weight: 700; color: var(--orange); text-align: center; letter-spacing: 2px; }
.countdown-label { font-size: 10px; color: var(--text-dim); text-align: center; letter-spacing: 2px; text-transform: uppercase; margin-top: 4px; }

/* ===================== TOAST ===================== */
.toast-container { position: fixed; bottom: 24px; right: 24px; z-index: 9000; display: flex; flex-direction: column; gap: 8px; }
.toast {
  padding: 12px 20px; border-radius: 10px; font-size: 13px;
  background: var(--bg3); border: 1px solid var(--border); color: var(--text);
  backdrop-filter: blur(10px); animation: slideIn 0.3s ease; max-width: 360px;
}
.toast.error { border-color: var(--red); } .toast.success { border-color: var(--green); }
@keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

/* ===================== TOOLTIP ===================== */
.tooltip {
  position: fixed; background: var(--bg2); border: 1px solid var(--border);
  border-radius: 8px; padding: 8px 12px; font-size: 11px; color: var(--text);
  pointer-events: none; z-index: 1000; display: none; max-width: 180px; text-align: center;
}

/* ===================== SKELETON ===================== */
.skeleton {
  background: linear-gradient(90deg, var(--bg3) 25%, rgba(42,147,193,0.08) 50%, var(--bg3) 75%);
  background-size: 200% 100%; animation: shimmer 1.5s infinite; border-radius: 6px;
}
@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
.skeleton-line { height: 14px; margin-bottom: 10px; }
.skeleton-line.short { width: 60%; }
.skeleton-block { height: 120px; }

/* ===================== HABIT TRACKER ===================== */
.habit-grid { display: grid; grid-template-columns: 1fr repeat(7, 36px); gap: 4px; align-items: center; }
.habit-name { font-size: 12px; padding-right: 8px; }
.habit-check {
  width: 32px; height: 32px; border-radius: 6px; border: 1px solid var(--border);
  background: var(--bg3); display: flex; align-items: center; justify-content: center;
  cursor: pointer; font-size: 14px; transition: all 0.15s;
}
.habit-check.done { background: var(--green-dim); border-color: var(--green); color: var(--green); }
.habit-check:hover { border-color: var(--blue); }

/* ===================== ANIMATIONS ===================== */
@keyframes cardIn { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
.card-animate { animation: cardIn 0.4s ease forwards; opacity: 0; }

/* ===================== OVERLAY ===================== */
.sidebar-overlay {
  display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5);
  z-index: 150;
}
.sidebar-overlay.show { display: block; }

/* ===================== NORTH STAR 3 PILLARS ===================== */
.ns-pillar-tabs { display: flex; gap: 6px; margin-bottom: 8px; }
.ns-pillar-tab {
  padding: 8px 18px; border-radius: 8px; font-family: 'Oswald', sans-serif;
  font-size: 12px; letter-spacing: 1.5px; text-transform: uppercase;
  cursor: pointer; border: 1px solid var(--border); color: var(--text-dim);
  background: var(--bg3); transition: all 0.2s; flex: 1; text-align: center;
}
.ns-pillar-tab.active { color: #fff; }
.ns-pillar-tab[data-pillar="people"].active { background: var(--orange); border-color: var(--orange); }
.ns-pillar-tab[data-pillar="product"].active { background: var(--blue); border-color: var(--blue); }
.ns-pillar-tab[data-pillar="profits"].active { background: var(--green); border-color: var(--green); }
.ns-pillar-tab[data-pillar="all"].active { background: linear-gradient(90deg, var(--orange), var(--blue), var(--green)); border-color: var(--blue); }
.ns-pillar-tab:hover:not(.active) { border-color: var(--blue); color: var(--text); }

.ns-timeframe-tabs { display: flex; gap: 4px; margin-bottom: 16px; }
.ns-timeframe-tab {
  padding: 6px 16px; border-radius: 20px; font-family: 'Oswald', sans-serif;
  font-size: 11px; letter-spacing: 1px; text-transform: uppercase;
  cursor: pointer; border: 1px solid var(--border); color: var(--text-dim);
  background: transparent; transition: all 0.2s;
}
.ns-timeframe-tab.active { background: var(--orange); border-color: var(--orange); color: #fff; }
.ns-timeframe-tab:hover:not(.active) { border-color: var(--blue); color: var(--blue); }

/* Pillars overview grid (ALL mode) */
.ns-pillars-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
@media (max-width: 900px) { .ns-pillars-grid { grid-template-columns: 1fr; } }

/* Single pillar card */
.ns-pillar-card {
  background: var(--card-bg); border-radius: 16px; padding: 20px;
  border: 1px solid var(--glass-border); backdrop-filter: blur(8px);
  transition: all 0.3s; position: relative; overflow: hidden;
}
.ns-pillar-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
}
.ns-pillar-card.people::before { background: var(--orange); }
.ns-pillar-card.product::before { background: var(--blue); }
.ns-pillar-card.profits::before { background: var(--green); }
.ns-pillar-card:hover { border-color: var(--border-bright); transform: translateY(-2px); }

/* Mandala container */
.ns-container { position: relative; width: 100%; max-width: 700px; margin: 0 auto; aspect-ratio: 1; }
.ns-container.compact { max-width: 320px; }
.ns-center {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
  width: 140px; height: 140px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-direction: column; cursor: pointer; transition: all 0.3s; z-index: 10;
}
.ns-center.people {
  background: radial-gradient(circle, rgba(241,66,11,0.2) 0%, rgba(241,66,11,0.05) 70%, transparent 100%);
  border: 2px solid var(--orange);
  box-shadow: 0 0 40px rgba(241,66,11,0.15), inset 0 0 30px rgba(241,66,11,0.08);
  animation: ns-glow-orange 3s ease-in-out infinite;
}
.ns-center.product {
  background: radial-gradient(circle, rgba(42,147,193,0.2) 0%, rgba(42,147,193,0.05) 70%, transparent 100%);
  border: 2px solid var(--blue);
  box-shadow: 0 0 40px rgba(42,147,193,0.15), inset 0 0 30px rgba(42,147,193,0.08);
  animation: ns-glow-blue 3s ease-in-out infinite;
}
.ns-center.profits {
  background: radial-gradient(circle, rgba(34,197,94,0.2) 0%, rgba(34,197,94,0.05) 70%, transparent 100%);
  border: 2px solid var(--green);
  box-shadow: 0 0 40px rgba(34,197,94,0.15), inset 0 0 30px rgba(34,197,94,0.08);
  animation: ns-glow-green 3s ease-in-out infinite;
}
.ns-center.expanded { width: 180px; height: 180px; }
.ns-center:hover { transform: translate(-50%, -50%) scale(1.05); }
@keyframes ns-glow-orange {
  0%,100% { box-shadow: 0 0 40px rgba(241,66,11,0.15), inset 0 0 30px rgba(241,66,11,0.08); }
  50% { box-shadow: 0 0 60px rgba(241,66,11,0.25), inset 0 0 40px rgba(241,66,11,0.12); }
}
@keyframes ns-glow-blue {
  0%,100% { box-shadow: 0 0 40px rgba(42,147,193,0.15), inset 0 0 30px rgba(42,147,193,0.08); }
  50% { box-shadow: 0 0 60px rgba(42,147,193,0.25), inset 0 0 40px rgba(42,147,193,0.12); }
}
@keyframes ns-glow-green {
  0%,100% { box-shadow: 0 0 40px rgba(34,197,94,0.15), inset 0 0 30px rgba(34,197,94,0.08); }
  50% { box-shadow: 0 0 60px rgba(34,197,94,0.25), inset 0 0 40px rgba(34,197,94,0.12); }
}
.ns-center-icon { font-size: 28px; margin-bottom: 4px; }
.ns-center-label { font-family: 'Oswald', sans-serif; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; }
.ns-center-label.people { color: var(--orange); }
.ns-center-label.product { color: var(--blue); }
.ns-center-label.profits { color: var(--green); }
.ns-center-text { font-size: 11px; color: var(--text); text-align: center; padding: 0 12px; margin-top: 4px; line-height: 1.3; max-height: 52px; overflow: hidden; }
.ns-orbit-ring {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
  width: 520px; height: 520px; border-radius: 50%;
  border: 1px dashed rgba(255,255,255,0.08);
}
.ns-orbit-ring.compact { width: 270px; height: 270px; }
.ns-orbit-ring.people { border-color: rgba(241,66,11,0.15); }
.ns-orbit-ring.product { border-color: rgba(42,147,193,0.15); }
.ns-orbit-ring.profits { border-color: rgba(34,197,94,0.15); }
.ns-category {
  position: absolute; width: 110px; height: 110px; border-radius: 50%;
  background: var(--card-bg); border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  flex-direction: column; cursor: pointer; transition: all 0.3s;
  backdrop-filter: blur(8px); text-align: center; padding: 8px;
}
.ns-category.compact { width: 64px; height: 64px; padding: 4px; }
.ns-category:hover { transform: scale(1.08); }
.ns-category.people:hover, .ns-category.people.active { border-color: var(--orange); box-shadow: 0 0 20px rgba(241,66,11,0.3); }
.ns-category.product:hover, .ns-category.product.active { border-color: var(--blue); box-shadow: 0 0 20px var(--blue-glow); }
.ns-category.profits:hover, .ns-category.profits.active { border-color: var(--green); box-shadow: 0 0 20px rgba(34,197,94,0.3); }
.ns-category.active.people { background: var(--orange-dim); }
.ns-category.active.product { background: var(--blue-dim); }
.ns-category.active.profits { background: var(--green-dim); }
.ns-category-icon { font-size: 20px; margin-bottom: 2px; }
.ns-category.compact .ns-category-icon { font-size: 14px; margin-bottom: 0; }
.ns-category-name { font-family: 'Oswald', sans-serif; font-size: 9px; letter-spacing: 1px; text-transform: uppercase; color: var(--text-dim); }
.ns-category.compact .ns-category-name { font-size: 7px; letter-spacing: 0; }
.ns-category-count { font-size: 10px; color: var(--text-muted); margin-top: 2px; }
.ns-category.compact .ns-category-count { display: none; }
.ns-connector {
  position: absolute; top: 50%; left: 50%; transform-origin: 0 0;
  height: 1px; opacity: 0.3; z-index: 1;
}
.ns-connector.people { background: linear-gradient(90deg, rgba(241,66,11,0.4), rgba(241,66,11,0.1)); }
.ns-connector.product { background: linear-gradient(90deg, rgba(42,147,193,0.4), rgba(42,147,193,0.1)); }
.ns-connector.profits { background: linear-gradient(90deg, rgba(34,197,94,0.4), rgba(34,197,94,0.1)); }

/* Pillar badge on tasks */
.ns-pillar-badge {
  font-size: 8px; padding: 1px 6px; border-radius: 8px;
  font-family: 'Oswald', sans-serif; letter-spacing: 1px; text-transform: uppercase;
}
.ns-pillar-badge.people { background: var(--orange-dim); color: var(--orange); }
.ns-pillar-badge.product { background: var(--blue-dim); color: var(--blue); }
.ns-pillar-badge.profits { background: var(--green-dim); color: var(--green); }

/* ===================== RAG STATUS INDICATORS ===================== */
.rag-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; cursor: pointer; transition: all 0.2s; vertical-align: middle; margin-left: 6px; position: relative; }
.rag-dot:hover { transform: scale(1.3); }
.rag-green { background: #10b981; box-shadow: 0 0 8px rgba(16,185,129,0.5); }
.rag-amber { background: #f59e0b; box-shadow: 0 0 8px rgba(245,158,11,0.5); }
.rag-red { background: #ef4444; box-shadow: 0 0 8px rgba(239,68,68,0.5); }
.rag-label { font-size: 8px; font-family: 'Oswald', sans-serif; letter-spacing: 1px; text-transform: uppercase; margin-left: 4px; vertical-align: middle; }
.rag-label.green { color: #10b981; }
.rag-label.amber { color: #f59e0b; }
.rag-label.red { color: #ef4444; }
.rag-dropdown { position: absolute; top: 18px; left: -4px; background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; padding: 4px; z-index: 200; display: none; min-width: 130px; box-shadow: 0 8px 24px rgba(0,0,0,0.4); }
.rag-dropdown.show { display: block; }
.rag-dropdown-item { display: flex; align-items: center; gap: 8px; padding: 6px 10px; border-radius: 6px; cursor: pointer; font-size: 11px; color: var(--text); font-family: 'Oswald', sans-serif; letter-spacing: 0.5px; white-space: nowrap; }
.rag-dropdown-item:hover { background: var(--glass); }
.rag-wrapper { display: inline-block; position: relative; vertical-align: middle; }
.rag-auto-badge { font-size: 7px; font-family: 'Oswald', sans-serif; letter-spacing: 0.5px; background: rgba(99,102,241,0.2); color: #818cf8; border-radius: 3px; padding: 1px 4px; margin-left: 3px; vertical-align: middle; cursor: help; }
.rag-auto-badge.manual { background: rgba(245,158,11,0.15); color: #f59e0b; }

/* ===================== ACTIVITY FEED ===================== */
.af-container { background: var(--card-bg); border: 1px solid var(--glass-border); border-radius: 16px; padding: 20px; backdrop-filter: blur(8px); }
.af-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
.af-title { font-family: 'Oswald', sans-serif; font-size: 18px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--text); }
.af-live { display: flex; align-items: center; gap: 6px; font-family: 'Oswald', sans-serif; font-size: 11px; letter-spacing: 2px; color: var(--red); text-transform: uppercase; }
.af-live-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--red); animation: af-pulse 1.5s ease-in-out infinite; }
@keyframes af-pulse { 0%, 100% { opacity: 1; box-shadow: 0 0 4px var(--red); } 50% { opacity: 0.4; box-shadow: 0 0 12px var(--red); } }
.af-feed { max-height: 500px; overflow-y: auto; }
.af-item { display: flex; align-items: flex-start; gap: 12px; padding: 10px 12px; border-radius: 8px; border-left: 3px solid var(--border); margin-bottom: 4px; transition: background 0.2s; }
.af-item:hover { background: var(--glass); }
.af-item.jared { border-left-color: var(--orange); }
.af-item.aether { border-left-color: var(--blue); }
.af-item.chy { border-left-color: var(--green); }
.af-item.boop { border-left-color: var(--purple); }
.af-item.team { border-left-color: var(--yellow); }
.af-time { font-family: 'Oswald', sans-serif; font-size: 11px; color: var(--text-muted); letter-spacing: 0.5px; min-width: 70px; flex-shrink: 0; margin-top: 2px; }
.af-icon { font-size: 16px; flex-shrink: 0; margin-top: 1px; }
.af-who { font-family: 'Oswald', sans-serif; font-size: 11px; letter-spacing: 1px; text-transform: uppercase; color: var(--text-dim); min-width: 60px; flex-shrink: 0; margin-top: 3px; }
.af-action { font-size: 13px; color: var(--text); line-height: 1.4; flex: 1; }
.af-category { font-size: 9px; padding: 2px 8px; border-radius: 10px; font-family: 'Oswald', sans-serif; letter-spacing: 1px; text-transform: uppercase; background: var(--glass); color: var(--text-dim); flex-shrink: 0; margin-top: 2px; }
.af-empty { text-align: center; color: var(--text-muted); font-size: 13px; padding: 40px 20px; font-style: italic; }

.ns-subgoal-item {
  display: flex; align-items: center; gap: 8px; padding: 8px 10px;
  background: var(--bg3); border-radius: 8px; margin-bottom: 4px;
  font-size: 12px;
}
.ns-subgoal-item.people { border-left: 3px solid var(--orange); }
.ns-subgoal-item.product { border-left: 3px solid var(--blue); }
.ns-subgoal-item.profits { border-left: 3px solid var(--green); }
.ns-subgoal-item .ns-sg-score { margin-left: auto; display: flex; gap: 4px; }
.ns-subgoal-item .ns-sg-badge { font-size: 8px; padding: 1px 6px; border-radius: 8px; font-family: 'Oswald', sans-serif; letter-spacing: 1px; }
.ns-edit-input {
  width: 100%; padding: 8px 12px; background: var(--bg3);
  border: 1px solid var(--border); border-radius: 8px;
  color: var(--text); font-size: 12px; outline: none; font-family: inherit;
}
.ns-edit-input:focus { border-color: var(--blue); }
.ns-add-btn {
  display: flex; align-items: center; gap: 4px; padding: 6px 10px;
  background: transparent; border: 1px dashed var(--border); border-radius: 8px;
  color: var(--text-muted); font-size: 11px; cursor: pointer; width: 100%;
  justify-content: center; transition: all 0.2s; margin-top: 4px;
}
.ns-add-btn:hover { border-color: var(--blue); color: var(--blue); }
@media (max-width: 768px) {
  .ns-container { max-width: 360px; }
  .ns-container.compact { max-width: 260px; }
  .ns-center { width: 100px; height: 100px; }
  .ns-center.expanded { width: 120px; height: 120px; }
  .ns-center-icon { font-size: 18px; }
  .ns-center-text { font-size: 9px; }
  .ns-orbit-ring { width: 300px; height: 300px; }
  .ns-orbit-ring.compact { width: 220px; height: 220px; }
  .ns-category { width: 70px; height: 70px; }
  .ns-category.compact { width: 52px; height: 52px; }
  .ns-category-icon { font-size: 14px; }
  .ns-category-name { font-size: 7px; }
}

/* ===================== PRIORITY FILTERS ===================== */
.pf-filter-tabs { display: flex; gap: 6px; margin-bottom: 16px; flex-wrap: wrap; }
.pf-filter-tab {
  padding: 8px 18px; border-radius: 8px; font-family: 'Oswald', sans-serif;
  font-size: 11px; letter-spacing: 1px; text-transform: uppercase;
  cursor: pointer; border: 1px solid var(--border); color: var(--text-dim);
  background: var(--bg3); transition: all 0.2s;
}
.pf-filter-tab.active { background: var(--blue); border-color: var(--blue); color: #fff; }
.pf-filter-tab:hover:not(.active) { border-color: var(--blue); color: var(--blue); }
.pf-matrix { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
@media (max-width: 768px) { .pf-matrix { grid-template-columns: 1fr; } }
.pf-quadrant {
  padding: 14px; background: var(--bg3); border-radius: 12px;
  border: 1px solid var(--glass-border); min-height: 80px;
  transition: border-color 0.2s;
}
.pf-quadrant:hover { border-color: var(--border-bright); }
.pf-quadrant-header { display: flex; align-items: center; gap: 6px; margin-bottom: 10px; }
.pf-quadrant-icon { font-size: 16px; }
.pf-quadrant-title { font-family: 'Oswald', sans-serif; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; }
.pf-quadrant-action { font-size: 9px; margin-left: auto; padding: 2px 8px; border-radius: 10px; font-family: 'Oswald', sans-serif; letter-spacing: 1px; }
.pf-task-item {
  display: flex; align-items: center; gap: 8px; padding: 6px 8px;
  background: rgba(255,255,255,0.02); border-radius: 6px; margin-bottom: 3px;
  font-size: 11px; cursor: pointer; transition: background 0.15s;
}
.pf-task-item:hover { background: rgba(255,255,255,0.05); }
.pf-task-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
.pf-task-text { flex: 1; }
.pf-task-assignee { font-size: 9px; color: var(--text-muted); font-family: 'Oswald', sans-serif; letter-spacing: 1px; }
.pf-abcde-row { display: flex; gap: 4px; margin-bottom: 6px; }
.pf-abcde-tag {
  padding: 4px 12px; border-radius: 6px; font-family: 'Oswald', sans-serif;
  font-size: 11px; letter-spacing: 1px; cursor: pointer; transition: all 0.15s;
  border: 1px solid transparent;
}
.pf-abcde-tag:hover { transform: translateY(-1px); }
.pf-abcde-tag.a { background: var(--red-dim); color: var(--red); border-color: rgba(239,68,68,0.3); }
.pf-abcde-tag.b { background: var(--orange-dim); color: var(--orange); border-color: rgba(241,66,11,0.3); }
.pf-abcde-tag.c { background: var(--yellow-dim); color: var(--yellow); border-color: rgba(234,179,8,0.3); }
.pf-abcde-tag.d { background: var(--blue-dim); color: var(--blue); border-color: rgba(42,147,193,0.3); }
.pf-abcde-tag.e { background: var(--glass); color: var(--text-muted); border-color: var(--glass-border); }
.pf-planning-track { display: flex; gap: 8px; align-items: flex-start; margin-bottom: 8px; }
.pf-planning-label {
  font-family: 'Oswald', sans-serif; font-size: 10px; letter-spacing: 1px;
  text-transform: uppercase; padding: 4px 10px; border-radius: 6px;
  min-width: 100px; text-align: center; flex-shrink: 0;
}
.pf-planning-items { flex: 1; }
.pf-score-summary {
  display: flex; gap: 12px; padding: 12px 16px; background: var(--bg3);
  border-radius: 10px; margin-top: 12px; flex-wrap: wrap;
}
.pf-score-item { text-align: center; }
.pf-score-label { font-size: 9px; color: var(--text-muted); font-family: 'Oswald', sans-serif; letter-spacing: 1px; text-transform: uppercase; }
.pf-score-value { font-family: 'Oswald', sans-serif; font-size: 18px; font-weight: 700; }

/* ===================== SMART MORNING PULSE ===================== */
.smp-suggestion {
  display: flex; align-items: flex-start; gap: 12px; padding: 12px 16px;
  background: var(--bg3); border-radius: 10px; margin-bottom: 8px;
  border-left: 3px solid var(--orange); transition: all 0.2s;
}
.smp-suggestion:hover { border-color: var(--blue); }
.smp-suggestion-rank { font-family: 'Oswald', sans-serif; font-size: 16px; font-weight: 700; min-width: 28px; }
.smp-suggestion-text { flex: 1; font-size: 13px; line-height: 1.5; }
.smp-suggestion-source { font-size: 9px; color: var(--text-muted); margin-top: 4px; font-family: 'Oswald', sans-serif; letter-spacing: 1px; }
.smp-suggestion-actions { display: flex; gap: 4px; flex-shrink: 0; }
.smp-action-btn {
  padding: 4px 10px; border-radius: 6px; font-size: 10px;
  font-family: 'Oswald', sans-serif; letter-spacing: 1px;
  cursor: pointer; border: 1px solid var(--border); background: transparent;
  color: var(--text-dim); transition: all 0.15s;
}
.smp-action-btn:hover { border-color: var(--blue); color: var(--blue); }
.smp-action-btn.approve { border-color: var(--green); color: var(--green); }
.smp-action-btn.approve:hover { background: var(--green-dim); }
.smp-delegation-block {
  padding: 14px 16px; background: var(--bg3); border-radius: 10px;
  margin-bottom: 8px; border: 1px solid var(--glass-border);
}
.smp-delegation-header {
  font-family: 'Oswald', sans-serif; font-size: 10px; letter-spacing: 2px;
  text-transform: uppercase; margin-bottom: 8px; display: flex;
  align-items: center; gap: 6px;
