  if (hasToday) {
    pulseItems.innerHTML = html;
    console.log('[Morning Pulse] rehydrated from sheet (todayISO=' + todayISO + ')');
    console.log('[MorningPulse] updated morning-pulse-items innerHTML');
    // Also restore smpSuggestions so the SMART PULSE cards (top) show approved state
    // Parse the saved priorities back into the suggestions array
    try {
      // Find the row that matched (latest today)
      let savedPriorities = '';
      for (let r = data.length - 1; r >= 1; r--) {
        const d = (data[r][0] || '').trim();
        const matchISO = d === todayISO;
        const matchSlash = d === todaySlash;
