async function loadNorthStarFromSheet() {
  const data = await fetchSheet("'North Star'!A:AZ", TOS_SPREADSHEET_ID);
  if (!data || data.length < 2) return;
  // New format: Pillar | Timeframe | North Star Goal | Cat1Name | Cat1Sub1..Cat1Sub5 | Cat2Name | ...
  // 9 rows total: people-Monthly, people-Quarterly, people-Yearly, product-Monthly, etc.
  for (let r = 1; r < data.length; r++) {
    const pillarKey = (data[r][0] || '').trim().toLowerCase();
    const tf = (data[r][1] || '').trim();
    if (!pillarKey || !NS_PILLAR_KEYS.includes(pillarKey) || tf !== nsData.timeframe) continue;
    nsData.pillars[pillarKey].northStar = data[r][2] || '';
    for (let c = 0; c < 8; c++) {
      const baseCol = 3 + (c * 6);
      if (data[r][baseCol]) {
        nsData.pillars[pillarKey].categories[c].name = data[r][baseCol];
        nsData.pillars[pillarKey].categories[c].subgoals = [];
        for (let s = 1; s <= 5; s++) {
          const sg = (data[r][baseCol + s] || '').trim();
          if (sg) nsData.pillars[pillarKey].categories[c].subgoals.push({ text: sg, abcde: '', quadrant: '', level: '', assignee: '' });
        }
      }
    }
  }
  saveNorthStarToStorage();
  renderAllPillars();
  generateSmartSuggestions();
}

async function saveNorthStarToSheet(pillarKey) {
  const p = nsData.pillars[pillarKey];
  const row = [pillarKey, nsData.timeframe, p.northStar];
  for (let c = 0; c < 8; c++) {
    row.push(p.categories[c].name);
    const sgs = p.categories[c].subgoals || [];
    for (let s = 0; s < 5; s++) {
      row.push(sgs[s] ? sgs[s].text : '');
    }
  }
  await appendSheet("'North Star'!A:AZ", [row], TOS_SPREADSHEET_ID);
  saveNorthStarToStorage();
  toast('North Star saved (' + NS_PILLAR_CONFIG[pillarKey].name + ')', 'success');
}

