async function syncApprovedToSheet() {
  // Persist current approved suggestions to Morning Pulse sheet (UPDATE today's row or APPEND)
  const approved = smpSuggestions.filter(s => s.approved);
  if (approved.length === 0) return null;
  const now = new Date();
  const yyyy = now.getFullYear();
  const mm = String(now.getMonth() + 1).padStart(2, '0');
  const dd = String(now.getDate()).padStart(2, '0');
  const dateStr = `${yyyy}-${mm}-${dd}`;
  const combined = approved.map((s, i) => `P${i+1}: ${s.text}`).join(' | ');
  const aetherScopeEl = document.getElementById('smp-aether-items');
  const chyScopeEl = document.getElementById('smp-chy-items');
  const aetherScope = aetherScopeEl ? Array.from(aetherScopeEl.querySelectorAll('.smp-delegation-item')).map(el => el.textContent.trim()).join(', ') : '';
  const chyScope = chyScopeEl ? Array.from(chyScopeEl.querySelectorAll('.smp-delegation-item')).map(el => el.textContent.trim()).join(', ') : '';

  // Find today's row to UPDATE in place
  let result = null;
  try {
    const existing = await fetchSheet("'Morning Pulse'!A:H", TOS_SPREADSHEET_ID);
    if (existing && existing.length > 1) {
      const todaySlash = `${now.getMonth()+1}/${now.getDate()}/${yyyy}`;
      let matchRow = -1;
      for (let r = 1; r < existing.length; r++) {
        const d = (existing[r][0] || '').trim();
        if (d === dateStr || d === todaySlash || (d.includes(`${now.getMonth()+1}/${now.getDate()}`) && d.includes(String(yyyy)))) {
          matchRow = r + 1;
          break;
        }
      }
      if (matchRow > 0) {
        const range = `'Morning Pulse'!A${matchRow}:H${matchRow}`;
        result = await updateSheet(range, [[dateStr, combined, aetherScope, '', chyScope, '', '', 'Approved']], TOS_SPREADSHEET_ID);
      }
    }
  } catch(e) { console.warn('[pulse] pre-check failed', e); }
  if (!result) {
    result = await appendSheet("'Morning Pulse'!A:H", [[dateStr, combined, aetherScope, '', chyScope, '', '', 'Approved']], TOS_SPREADSHEET_ID);
  }
  if (!result) {
    toast('Save failed — priorities NOT saved to sheet', 'error');
    return null;
  }
  // Update the Today's Priorities display
  const pulseItems = document.getElementById('morning-pulse-items');
  if (pulseItems) {
    const colors = ['var(--orange)', 'var(--blue)', 'var(--green)'];
    const labels = ['P1', 'P2', 'P3'];
    const savedTime = now.toLocaleTimeString('en-US', {hour:'numeric', minute:'2-digit'});
    pulseItems.innerHTML = approved.map((s, i) => `
      <div class="morning-item" style="display:flex;align-items:flex-start;gap:10px;padding:10px 14px;background:var(--bg3);border-radius:8px;margin-bottom:6px;border-left:3px solid ${colors[i]};">
        <span style="color:${colors[i]};font-size:11px;font-weight:700;min-width:24px;">${labels[i]}</span>
        <span style="flex:1;font-size:12px;line-height:1.5;">${escHtml(s.text)}</span>
        <span class="badge badge-green">Saved ${savedTime}</span>
      </div>
    `).join('');
  }
  return result;
}

