  const ring = document.getElementById('ns-orbit-ring');
  ring.className = 'ns-orbit-ring ' + cfg.theme;

  // Categories
  const container = document.getElementById('ns-categories');
  const connectors = document.getElementById('ns-connectors');
  const radius = 210;
  let catHtml = '';
  let conHtml = '';

  for (let i = 0; i < 8; i++) {
    const angle = (i * 45 - 90) * (Math.PI / 180);
    const x = Math.cos(angle) * radius;
    const y = Math.sin(angle) * radius;
    const sgCount = (p.categories[i].subgoals || []).length;
    const activeClass = (nsActivePillarKey === pillarKey && i === nsActiveCategory) ? ' active' : '';

    catHtml += `
      <div class="ns-category ${cfg.theme}${activeClass}" onclick="selectCategory('${pillarKey}',${i})"
           style="left:calc(50% + ${x}px - 55px);top:calc(50% + ${y}px - 55px);">
