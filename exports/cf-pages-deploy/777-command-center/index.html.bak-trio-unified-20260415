  let html = '<table class="data-table"><thead><tr><th>Date</th><th>From</th><th>To</th><th>Item</th><th>Priority</th><th>Status</th></tr></thead><tbody>';
  let count = 0;
  for (let r = data.length - 1; r >= 1 && count < 20; r--) {
    if (!data[r][0]) continue;
