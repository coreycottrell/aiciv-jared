function applyDeliverablesData(data) {
  if (!data || data.length < 2) return;
  deliverables = [];
  for (let r = 1; r < data.length; r++) {
    if (data[r][0] && data[r][1] && data[r][2]) {
      deliverables.push({
        date: data[r][0],
        person: data[r][1],
        text: data[r][2],
        category: data[r][3] || 'Product',
        details: data[r][4] || ''
      });
    }
  }
  renderDeliverables();
}

function renderDeliverables() {
  const now = new Date();
  const todayStr = now.toLocaleDateString('en-US');
  const weekStart = new Date(now); weekStart.setDate(now.getDate() - now.getDay());
  const monthStart = new Date(now.getFullYear(), now.getMonth(), 1);
  const yearStart = new Date(now.getFullYear(), 0, 1);

  // Count stats
  let weekCount = 0, monthCount = 0, yearCount = 0;
  deliverables.forEach(d => {
    const dt = new Date(d.date);
    if (dt >= yearStart) yearCount++;
    if (dt >= monthStart) monthCount++;
    if (dt >= weekStart) weekCount++;
  });

  animateCounter('deliv-week-count', weekCount);
  animateCounter('deliv-month-count', monthCount);
  animateCounter('deliv-year-count', yearCount);

  renderDailyDeliverables(todayStr);
  renderWeeklyRollup(weekStart, now);
