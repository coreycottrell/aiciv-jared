const RAG_STATES = ['green', 'amber', 'red'];
const RAG_LABELS = { green: 'On Track', amber: 'Needs Attention', red: 'Action Required' };
let ragStatus = { people: 'green', product: 'green', profits: 'green' };

function loadRAGFromStorage() {
  try {
    const saved = localStorage.getItem('777_rag_status');
    if (saved) ragStatus = { ...ragStatus, ...JSON.parse(saved) };
  } catch(e) {}
}

function saveRAGToStorage() {
  try { localStorage.setItem('777_rag_status', JSON.stringify(ragStatus)); } catch(e) {}
}

async function saveRAGToSheet() {
  const row = [new Date().toISOString(), ragStatus.people, ragStatus.product, ragStatus.profits];
  await appendSheet("'RAG Status'!A:D", [row], TOS_SPREADSHEET_ID);
}

async function loadRAGFromSheet() {
  const data = await fetchSheet("'RAG Status'!A:D", TOS_SPREADSHEET_ID);
  if (!data || data.length < 2) return;
  const lastRow = data[data.length - 1];
  if (lastRow[1]) ragStatus.people = lastRow[1];
  if (lastRow[2]) ragStatus.product = lastRow[2];
  if (lastRow[3]) ragStatus.profits = lastRow[3];
  saveRAGToStorage();
  renderRAGIndicators();
}

function cycleRAG(pillar, event) {
  if (event) { event.stopPropagation(); event.preventDefault(); }
  const current = ragStatus[pillar];
  const nextIdx = (RAG_STATES.indexOf(current) + 1) % RAG_STATES.length;
  ragStatus[pillar] = RAG_STATES[nextIdx];
  saveRAGToStorage();
