  const p2 = (document.getElementById('morning-pulse-p2') || {}).value || '';
  const p3 = (document.getElementById('morning-pulse-p3') || {}).value || '';
  if (!p1.trim() && !p2.trim() && !p3.trim()) { toast('Please enter at least one priority', 'error'); return; }
  const now = new Date();
  // Standardized ISO format YYYY-MM-DD
  const yyyy = now.getFullYear();
  const mm = String(now.getMonth() + 1).padStart(2, '0');
  const dd = String(now.getDate()).padStart(2, '0');
  const dateStr = `${yyyy}-${mm}-${dd}`;
  const priorities = [p1.trim(), p2.trim(), p3.trim()].filter(Boolean);
  const combined = priorities.map((p, i) => `P${i+1}: ${p}`).join(' | ');
  console.log('[Morning Pulse] manual drop date=' + dateStr + ' priorities=' + priorities.length);

  // ===== STEP 1: IMMEDIATE localStorage persistence (guaranteed, survives refresh) =====
  try {
    const local = { date: dateStr, priorities: priorities, combined: combined, savedAt: now.toISOString() };
    localStorage.setItem(MP_LOCAL_KEY, JSON.stringify(local));
    console.log('[Morning Pulse] manual drop persisted to localStorage');
  } catch(e) {
    console.error('[Morning Pulse] localStorage write FAILED', e);
  }

  // ===== STEP 2: Rehydrate smpSuggestions so smart-card + race-guard see manual drop =====
  try {
    if (typeof smpSuggestions !== 'undefined' && Array.isArray(smpSuggestions)) {
      smpSuggestions = priorities.map((text, i) => ({
        text: text,
        source: 'Manual drop by Jared',
        approved: true,
        task: null
      }));
      if (typeof renderSmartPulse === 'function') renderSmartPulse();
      console.log('[Morning Pulse] smpSuggestions rehydrated (' + smpSuggestions.length + ' approved slots)');
    }
  } catch(e) { console.warn('[Morning Pulse] smpSuggestions rehydrate failed', e); }

  // ===== STEP 3: Attempt sheet write (UPDATE in place, fallback to APPEND) =====
  let result = null;
  try {
    const existing = await fetchSheet("'Morning Pulse'!A:H", TOS_SPREADSHEET_ID);
    if (existing && existing.length > 1) {
      const todayShort = `${now.getMonth()+1}/${now.getDate()}/${now.getFullYear()}`;
      let matchRow = -1;
      for (let r = 1; r < existing.length; r++) {
        const d = (existing[r][0] || '').trim();
        if (d === dateStr || d === todayShort || (d.includes(`${now.getMonth()+1}/${now.getDate()}`) && d.includes(`${now.getFullYear()}`))) {
          matchRow = r + 1;
          break;
        }
      }
      if (matchRow > 0) {
        const range = `'Morning Pulse'!A${matchRow}:H${matchRow}`;
        console.log('[Morning Pulse] UPDATE row ' + matchRow + ' range=' + range);
        result = await updateSheet(range, [[dateStr, combined, '', '', '', '', '', 'New']], TOS_SPREADSHEET_ID);
      }
    }
  } catch(e) { console.warn('[Morning Pulse] pre-check failed, falling back to append', e); }

  if (!result) {
    console.log('[Morning Pulse] APPEND new row');
    result = await appendSheet("'Morning Pulse'!A:H", [[dateStr, combined, '', '', '', '', '', 'New']], TOS_SPREADSHEET_ID);
  }

  const sheetOk = !!result;
  console.log('[Morning Pulse] sheet write result=' + (sheetOk ? 'OK' : 'FAILED (localStorage will still restore)'));

  // Invalidate sheet cache so next load re-fetches fresh data
  try { delete sheetsCache[(TOS_SPREADSHEET_ID || '') + ':' + "'Morning Pulse'!A:H"]; } catch(e) {}

  // ===== STEP 4: UI confirmation (only AFTER write attempt resolves) =====
  const confirm = document.getElementById('pulse-confirm');
  if (confirm) {
    confirm.style.display = 'inline';
    setTimeout(() => { confirm.style.display = 'none'; }, 5000);
  }
  // Clear inputs
  if (document.getElementById('morning-pulse-p1')) document.getElementById('morning-pulse-p1').value = '';
  if (document.getElementById('morning-pulse-p2')) document.getElementById('morning-pulse-p2').value = '';
  if (document.getElementById('morning-pulse-p3')) document.getElementById('morning-pulse-p3').value = '';
  // Render with accurate save state (Saved/Local-only) timestamp
  const pulseItems = document.getElementById('morning-pulse-items');
  const colors = ['var(--orange)', 'var(--blue)', 'var(--green)'];
  const labels = ['P1', 'P2', 'P3'];
  const savedTime = now.toLocaleTimeString('en-US', {hour:'numeric', minute:'2-digit'});
  const badgeClass = sheetOk ? 'badge-green' : 'badge-orange';
  const badgeText = sheetOk ? ('Saved ' + savedTime) : ('Local ' + savedTime);
  pulseItems.innerHTML = priorities.map((line, i) => `
    <div class="morning-item" style="display:flex;align-items:flex-start;gap:10px;padding:10px 14px;background:var(--bg3);border-radius:8px;margin-bottom:6px;border-left:3px solid ${colors[i]};">
      <span style="color:${colors[i]};font-size:11px;font-weight:700;min-width:24px;">${labels[i]}</span>
      <span style="flex:1;font-size:12px;line-height:1.5;">${escHtml(line)}</span>
      <span class="badge ${badgeClass}">${badgeText}</span>
    </div>
  `).join('');
  if (sheetOk) {
    toast('Priorities saved! Aether & Chy will scope these.', 'success');
  } else {
    toast('Saved locally — sheet write failed. Will retry next session.', 'error');
  }
}

