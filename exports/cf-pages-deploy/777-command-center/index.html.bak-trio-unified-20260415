    { id: 'tz-mum', tz: 'Asia/Kolkata' },
    { id: 'tz-pkt', tz: 'Asia/Karachi' },
    { id: 'tz-bj', tz: 'Asia/Shanghai' }
  ];
  const now = new Date();
  zones.forEach(z => {
    const el = document.getElementById(z.id);
    if (el) el.textContent = now.toLocaleTimeString('en-US', { timeZone: z.tz, hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: true });
  });
}
