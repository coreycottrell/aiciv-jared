function colToLetter(col) {
  let letter = '';
  while (col >= 0) { letter = String.fromCharCode(65 + (col % 26)) + letter; col = Math.floor(col / 26) - 1; }
  return letter;
}

function cycleScore(el, idx) {
  const q = dailyQuestions[idx];
  const current = dailyScoresMap[q] || 0;
  const next = current === 0 ? 0.5 : current === 0.5 ? 0.75 : current === 0.75 ? 1 : 0;
  dailyScoresMap[q] = next;
  renderDailyChecklist();
  renderFullDailyChecklist();
  if (dailyTodayCol >= 0 && dailyQuestionsRows[idx] !== undefined) {
    const cellRef = colToLetter(dailyTodayCol) + (dailyQuestionsRows[idx] + 1);
    writeSheet(`'Daily Reflection Process (2026-2028)'!${cellRef}`, [[next]]);
  }
}

function cycleScoreFull(el, idx) { cycleScore(el, idx); }

function setScore(idx, score, btn) {
  dailyScoresMap[dailyQuestions[idx]] = score;
  renderDailyChecklist();
  renderFullDailyChecklist();
  if (dailyTodayCol >= 0 && dailyQuestionsRows[idx] !== undefined) {
