function getAllScoredTasks() {
  const tasks = [];
  NS_PILLAR_KEYS.forEach(pk => {
    const cfg = NS_PILLAR_CONFIG[pk];
    nsData.pillars[pk].categories.forEach((cat, ci) => {
      (cat.subgoals || []).forEach((sg, si) => {
        tasks.push({ ...sg, category: cat.name, catIcon: cat.icon, catIdx: ci, sgIdx: si, pillar: pk, pillarName: cfg.name, pillarIcon: cfg.icon });
      });
    });
  });
  return tasks;
}

function renderPriorityFilters() {
  const tasks = getAllScoredTasks();

  // ABCDE Panel
  const abcdeEl = document.getElementById('pf-abcde-tasks');
  const groups = { A: [], B: [], C: [], D: [], E: [], '': [] };
  tasks.forEach(t => { (groups[t.abcde] || groups['']).push(t); });
  let abcdeHtml = '';
  const abcdeLabels = { A: 'Must Do Today', B: 'Should Do', C: 'Nice to Do', D: 'Delegate', E: 'Eliminate' };
  const abcdeColors = { A: 'var(--red)', B: 'var(--orange)', C: 'var(--yellow)', D: 'var(--blue)', E: 'var(--text-muted)' };
  ['A','B','C','D','E'].forEach(grade => {
    if (groups[grade].length) {
      abcdeHtml += `<div style="margin-bottom:10px;"><div style="font-family:'Oswald',sans-serif;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:${abcdeColors[grade]};margin-bottom:4px;">${grade} - ${abcdeLabels[grade]} (${groups[grade].length})</div>`;
      groups[grade].forEach(t => {
        const pBadge = t.pillar ? `<span class="ns-pillar-badge ${t.pillar}">${t.pillarName}</span>` : '';
        abcdeHtml += `<div class="pf-task-item"><div class="pf-task-dot" style="background:${abcdeColors[grade]}"></div>${pBadge}<span class="pf-task-text">${t.catIcon} ${escHtml(t.text)}</span><span class="pf-task-assignee">${t.assignee || '-'}</span></div>`;
      });
      abcdeHtml += '</div>';
    }
  });
  if (groups[''].length) {
    abcdeHtml += `<div style="margin-top:8px;font-size:11px;color:var(--text-muted);">${groups[''].length} unscored tasks - go to North Star to score them</div>`;
  }
  abcdeEl.innerHTML = abcdeHtml || '<div style="color:var(--text-dim);font-size:12px;font-style:italic;">No tasks to display. Add sub-goals in the North Star mandala first.</div>';

  // Eisenhower Matrix
  const eisGroups = { '1': [], '2': [], '3': [], '4': [] };
  tasks.forEach(t => { if (t.quadrant && eisGroups[t.quadrant]) eisGroups[t.quadrant].push(t); });
  ['1','2','3','4'].forEach(q => {
    const el = document.getElementById('pf-eis-q' + q);
    if (el) {
      el.innerHTML = eisGroups[q].map(t => {
        const pBadge = t.pillar ? `<span class="ns-pillar-badge ${t.pillar}">${t.pillarName}</span>` : '';
        return `<div class="pf-task-item"><div class="pf-task-dot" style="background:var(--blue)"></div>${pBadge}<span class="pf-task-text">${t.catIcon} ${escHtml(t.text)}</span><span class="pf-task-assignee">${t.assignee || '-'}</span></div>`;
      }).join('') || '<div style="font-size:10px;color:var(--text-muted);">Empty</div>';
    }
  });

  // Planning Levels
  const planMap = { '1': 'critical', '2': 'important', '3': 'progress', '4': 'accomplish', '5': 'enjoyment' };
  Object.entries(planMap).forEach(([lvl, id]) => {
    const el = document.getElementById('pf-plan-' + id);
    if (!el) return;
    const items = tasks.filter(t => t.level === lvl);
    if (items.length) {
      el.innerHTML = items.map(t => {
        const pBadge = t.pillar ? `<span class="ns-pillar-badge ${t.pillar}">${t.pillarName}</span>` : '';
        return `<div class="pf-task-item"><div class="pf-task-dot" style="background:var(--blue)"></div>${pBadge}<span class="pf-task-text">${t.catIcon} ${escHtml(t.text)}</span><span class="pf-task-assignee">${t.assignee || '-'}</span></div>`;
      }).join('');
    }
  });

  // Combined View
  const combinedEl = document.getElementById('pf-combined-list');
  const scored = tasks.filter(t => t.abcde && t.quadrant && t.level);
  if (scored.length) {
    // Sort by priority: A>B>C>D>E, then Q1>Q2>Q3>Q4, then level 1>2>3>4>5
    scored.sort((a, b) => {
      const ao = 'ABCDE'.indexOf(a.abcde); const bo = 'ABCDE'.indexOf(b.abcde);
      if (ao !== bo) return ao - bo;
      if (a.quadrant !== b.quadrant) return a.quadrant.localeCompare(b.quadrant);
      return a.level.localeCompare(b.level);
    });

    const assigneeColors = { Jared: 'var(--orange)', Aether: 'var(--blue)', Chy: 'var(--green)', Team: 'var(--purple)', Eliminate: 'var(--text-muted)' };
    combinedEl.innerHTML = scored.map((t, i) => `
      <div class="pf-task-item" style="padding:8px 10px;">
        <span style="font-family:'Oswald',sans-serif;font-size:12px;color:var(--text-muted);min-width:20px;">#${i+1}</span>
        <div class="pf-task-dot" style="background:${assigneeColors[t.assignee] || 'var(--text-muted)'}"></div>
        ${t.pillar ? `<span class="ns-pillar-badge ${t.pillar}">${t.pillarName}</span>` : ''}
        <span class="pf-task-text">${t.catIcon} ${escHtml(t.text)}</span>
        <span class="ns-sg-badge pf-abcde-tag ${t.abcde.toLowerCase()}" style="font-size:9px;">${t.abcde}</span>
        <span class="ns-sg-badge badge badge-blue" style="font-size:9px;">Q${t.quadrant}</span>
        <span class="pf-task-assignee" style="color:${assigneeColors[t.assignee] || 'var(--text-muted)'}">${t.assignee || '-'}</span>
      </div>
    `).join('');

    // Routing summary
    document.getElementById('pf-routing-summary').style.display = 'flex';
    document.getElementById('pf-jared-count').textContent = scored.filter(t => t.assignee === 'Jared').length;
    document.getElementById('pf-aether-count').textContent = scored.filter(t => t.assignee === 'Aether').length;
    document.getElementById('pf-chy-count').textContent = scored.filter(t => t.assignee === 'Chy').length;
    document.getElementById('pf-team-count').textContent = scored.filter(t => t.assignee === 'Team').length;
  }
}

/* ======================== SMART MORNING PULSE ======================== */

let smpSuggestions = []; // { text, source, approved }
let smpMode = 'smart'; // 'smart' or 'manual'

function generateSmartSuggestions() {
  // RACE-CONDITION GUARD (2026-04-14): applyMorningPulseData() may have already
  // restored approved priorities from the Morning Pulse sheet. North Star fetch
  // resolves on its own timeline and calls this function — without this guard it
  // would clobber Jared's saved/approved priorities with freshly-generated ones.
  // If ALL three slots are already approved, bail out entirely.
  // If SOME slots are approved, preserve them and only fill the empty/unapproved slots.
  const preserved = (typeof smpSuggestions !== 'undefined' && Array.isArray(smpSuggestions))
    ? smpSuggestions.slice(0, 3).map(s => (s && s.approved) ? s : null)
    : [null, null, null];
  const approvedCount = preserved.filter(Boolean).length;
  if (approvedCount >= 3) {
    renderSmartPulse();
    renderDelegationBlocks(getAllScoredTasks(), getAllScoredTasks().filter(t => t.abcde && t.quadrant && t.level));
    return;
  }

  const tasks = getAllScoredTasks();
  const scored = tasks.filter(t => t.abcde && t.quadrant && t.level);

  if (scored.length === 0) {
    // Fallback: try to pick one from each pillar
    const suggestions = [];
    NS_PILLAR_KEYS.forEach(pk => {
      const pillarTasks = tasks.filter(t => t.pillar === pk);
      if (pillarTasks.length > 0) suggestions.push(pillarTasks[0]);
    });
    if (suggestions.length === 0) {
      // Use unscored tasks
      suggestions.push(...tasks.slice(0, 3));
    }
    smpSuggestions = suggestions.slice(0, 3).map(t => ({
      text: t.text,
      source: (t.pillarIcon || '') + ' ' + (t.pillarName || '') + ' > ' + t.catIcon + ' ' + t.category + ' (unscored)',
      approved: false,
      task: t
    }));
    // If no tasks at all, use north star goals
    if (smpSuggestions.length === 0) {
      const nsGoals = NS_PILLAR_KEYS.filter(pk => nsData.pillars[pk].northStar).map(pk => ({
        text: 'Work on ' + NS_PILLAR_CONFIG[pk].name + ': ' + nsData.pillars[pk].northStar,
        source: NS_PILLAR_CONFIG[pk].icon + ' ' + NS_PILLAR_CONFIG[pk].name + ' North Star',
        approved: false, task: null
      }));
      smpSuggestions = nsGoals.slice(0, 3);
    }
  } else {
    // Sort scored tasks
    scored.sort((a, b) => {
      const ao = 'ABCDE'.indexOf(a.abcde); const bo = 'ABCDE'.indexOf(b.abcde);
      if (ao !== bo) return ao - bo;
      if (a.quadrant !== b.quadrant) return a.quadrant.localeCompare(b.quadrant);
      return a.level.localeCompare(b.level);
    });

    // Try to balance across at least 2 pillars
    const topTasks = [];
    const usedPillars = new Set();
    const jaredTasks = scored.filter(t => t.assignee === 'Jared');
    const pool = jaredTasks.length >= 3 ? jaredTasks : scored;

    // First pass: pick best from each pillar
    NS_PILLAR_KEYS.forEach(pk => {
      const pillarBest = pool.find(t => t.pillar === pk && !topTasks.includes(t));
      if (pillarBest && topTasks.length < 3) {
        topTasks.push(pillarBest);
        usedPillars.add(pk);
      }
    });
    // Fill remaining from overall top
    pool.forEach(t => {
      if (topTasks.length < 3 && !topTasks.includes(t)) topTasks.push(t);
    });

    smpSuggestions = topTasks.slice(0, 3).map(t => ({
      text: t.text,
      source: (t.pillarIcon || '') + ' ' + (t.pillarName || '') + ' > ' + t.catIcon + ' ' + t.category + ' | ' + t.abcde + ' | Q' + t.quadrant,
      approved: false,
      task: t
    }));
  }

  // RACE-CONDITION GUARD (2026-04-14): Merge preserved approved slots back in.
  // If Jared had already approved P1/P2/P3, those slots must survive any regeneration.
  if (approvedCount > 0) {
    for (let i = 0; i < 3; i++) {
      if (preserved[i]) smpSuggestions[i] = preserved[i];
    }
  }

  renderSmartPulse();
  renderDelegationBlocks(tasks, scored);
}

function renderSmartPulse() {
  const colors = ['var(--orange)', 'var(--blue)', 'var(--green)'];
  const labels = ['P1', 'P2', 'P3'];

  for (let i = 0; i < 3; i++) {
