/* ======================== BRANDED PROMPT MODAL ======================== */
function brandedPrompt(title, body, defaultValue) {
  return new Promise(resolve => {
    const overlay = document.getElementById('branded-modal');
    const titleEl = document.getElementById('modal-title');
    const bodyEl = document.getElementById('modal-body');
    const inputEl = document.getElementById('modal-input');
    const saveBtn = document.getElementById('modal-save');
    const cancelBtn = document.getElementById('modal-cancel');
    titleEl.textContent = title;
    bodyEl.textContent = body || '';
    bodyEl.style.display = body ? 'block' : 'none';
    inputEl.value = defaultValue || '';
    overlay.classList.add('active');
    inputEl.focus();
    function cleanup() { overlay.classList.remove('active'); saveBtn.onclick = null; cancelBtn.onclick = null; inputEl.onkeydown = null; }
    saveBtn.onclick = function() { cleanup(); resolve(inputEl.value); };
    cancelBtn.onclick = function() { cleanup(); resolve(null); };
    inputEl.onkeydown = function(e) { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); cleanup(); resolve(inputEl.value); } if (e.key === 'Escape') { cleanup(); resolve(null); } };
  });
}

