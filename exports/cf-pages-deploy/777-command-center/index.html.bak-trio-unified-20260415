        `;
      }
    }
  }
  console.log('[MorningPulse] hasToday=', hasToday, 'html length=', html.length);

  // LOCALSTORAGE FALLBACK (2026-04-14): if sheet has no today row, check local manual drop.
  // This guarantees manual Drop Priorities persists across refresh/restart even if sheet
  // write silently failed. Sheet is source-of-truth when present; localStorage is the safety net.
  if (!hasToday) {
