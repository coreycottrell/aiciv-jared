function applyDailyReflection(data) {
  if (!data || data.length < 2) return;
  // Headers in row 1, questions in column A, dates in row 1
  const headers = data[0];
  // Sheet uses non-zero-padded dates like "4/12/26" — match that format
  const now = new Date();
  const todayMatch = (now.getMonth() + 1) + '/' + now.getDate() + '/' + String(now.getFullYear()).slice(-2);
  const todayMatchAlt = (now.getMonth() + 1) + '/' + now.getDate(); // fallback: just M/D
  let todayCol = -1;
  for (let i = 1; i < headers.length; i++) {
    if (headers[i] && (headers[i].trim() === todayMatch || headers[i].trim() === todayMatchAlt ||
        headers[i].includes(todayMatch) || headers[i].includes(todayMatchAlt + '/'))) {
      todayCol = i; break;
    }
  }
  // Extract questions from column A
  const questions = [];
  for (let r = 1; r < data.length; r++) {
    if (data[r][0] && data[r][0].trim()) {
      questions.push({
        text: data[r][0],
        score: todayCol >= 0 && data[r][todayCol] ? parseFloat(data[r][todayCol]) : null,
        row: r
      });
