// ==================== TRIO COMMS ====================
// Uses SHEETS_API + WORKER_API_KEY (already defined above).
// Endpoints:
//   POST /trio/message        { from, to, content, bridge_file_path? }
//   GET  /trio/messages?limit&since
//   POST /trio/mark-read      { message_id, reader }
const TRIO_COLORS = { aether: '#2a93c1', chy: '#5fbd5f', morphe: '#f1420b', jared: '#ffffff' };
let _trioMessages = [];
let _trioRenderLimit = 25;

function trioEscape(s) {
  return String(s || '').replace(/[&<>"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
}

function trioRenderMarkdown(s) {
  // Lightweight: escape, then bold + code + linkify.
  let html = trioEscape(s);
  html = html.replace(/`([^`]+)`/g, '<code style="background:var(--bg3);padding:1px 5px;border-radius:4px;font-size:11px;">$1</code>');
  html = html.replace(/\*\*([^\*]+)\*\*/g, '<strong>$1</strong>');
  html = html.replace(/(https?:\/\/[^\s<]+)/g, '<a href="$1" target="_blank" style="color:var(--blue);">$1</a>');
  html = html.replace(/\n/g, '<br>');
  return html;
}

function trioFormatTs(iso) {
  try {
    const d = new Date(iso);
    const est = d.toLocaleString('en-US', { timeZone: 'America/New_York', month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' });
    return `<span title="${trioEscape(iso)} UTC">${trioEscape(est)} EST</span>`;
  } catch (e) { return trioEscape(iso); }
}

async function loadTrioComms(announce) {
  try {
    const ts = document.getElementById('trio-comms-timestamp');
    if (ts) ts.textContent = 'Loading...';
    const res = await fetch(`${SHEETS_API}/trio/messages?limit=200`, {
      headers: { 'X-API-Key': WORKER_API_KEY }
    });
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const data = await res.json();
    _trioMessages = data.messages || [];
    renderTrioComms();
    if (ts) ts.textContent = `Updated ${new Date().toLocaleTimeString('en-US', { timeZone: 'America/New_York', hour: 'numeric', minute: '2-digit' })} EST`;
    if (announce) {
      const s = document.getElementById('trio-comms-status');
      if (s) { s.textContent = `${_trioMessages.length} messages`; setTimeout(() => s.textContent = '', 3000); }
    }
  } catch (e) {
    console.warn('[Trio] load failed:', e);
    const feed = document.getElementById('trio-comms-feed');
    if (feed) feed.innerHTML = `<div style="color:var(--red);font-size:12px;padding:12px;">Failed to load trio comms: ${trioEscape(e.message)}</div>`;
  }
}

function renderTrioComms() {
  const feed = document.getElementById('trio-comms-feed');
  if (!feed) return;
  const fFrom = document.getElementById('trio-filter-from').value;
  const fTo = document.getElementById('trio-filter-to').value;
  let filtered = _trioMessages.filter(m => {
    if (fFrom && m.from !== fFrom) return false;
    if (fTo) {
      const tos = (m.to || '').split(',').map(s => s.trim());
      if (fTo === 'all') { if (!tos.includes('all')) return false; }
      else { if (!tos.includes(fTo) && !tos.includes('all')) return false; }
    }
    return true;
  });
  if (filtered.length === 0) {
    feed.innerHTML = `<div style="color:var(--text-dim);font-size:12px;font-style:italic;padding:12px;">No messages match the current filter.</div>`;
    document.getElementById('trio-load-more').style.display = 'none';
    return;
  }
  const slice = filtered.slice(0, _trioRenderLimit);
  feed.innerHTML = slice.map(m => {
    const color = TRIO_COLORS[m.from] || 'var(--text)';
    const bridgeBadge = m.bridge_file_path
      ? `<span style="font-size:10px;color:var(--text-dim);margin-left:8px;" title="${trioEscape(m.bridge_file_path)}">[bridge]</span>`
      : '';
    return `
      <div style="border-left:3px solid ${color};padding:8px 12px;background:var(--bg3);border-radius:6px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
          <strong style="color:${color};text-transform:capitalize;font-size:12px;">${trioEscape(m.from)}</strong>
          <span style="color:var(--text-dim);font-size:11px;">&rarr; ${trioEscape(m.to)}</span>
          ${bridgeBadge}
          <span style="margin-left:auto;font-size:11px;color:var(--text-dim);">${trioFormatTs(m.timestamp)}</span>
        </div>
        <div style="font-size:13px;line-height:1.5;color:var(--text);">${trioRenderMarkdown(m.content)}</div>
      </div>`;
  }).join('');
  const btn = document.getElementById('trio-load-more');
  btn.style.display = filtered.length > _trioRenderLimit ? 'inline-block' : 'none';
}

function trioLoadMore() {
  _trioRenderLimit += 25;
  renderTrioComms();
}

async function sendTrioMessage() {
  const ta = document.getElementById('trio-input');
  const to = document.getElementById('trio-send-to').value;
  const status = document.getElementById('trio-send-status');
  const content = (ta.value || '').trim();
  if (!content) { status.style.color = 'var(--red)'; status.textContent = 'Empty message'; return; }
  status.style.color = 'var(--text-dim)'; status.textContent = 'Sending...';
  try {
    const res = await fetch(`${SHEETS_API}/trio/message`, {
      method: 'POST',
      headers: { 'X-API-Key': WORKER_API_KEY, 'Content-Type': 'application/json' },
      body: JSON.stringify({ from: 'jared', to, content })
    });
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const j = await res.json();
    ta.value = '';
    status.style.color = 'var(--green)'; status.textContent = `Sent (${j.id})`;
    await loadTrioComms(false);
    setTimeout(() => status.textContent = '', 4000);
  } catch (e) {
    status.style.color = 'var(--red)'; status.textContent = 'Failed: ' + e.message;
  }
}

// Auto-load when trio panel is viewed + periodic refresh.
(function initTrioComms() {
  if (typeof document === 'undefined') return;
  // Initial load on dashboard ready.
  const boot = () => { loadTrioComms(false); };
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    setTimeout(boot, 1200);
  } else {
    document.addEventListener('DOMContentLoaded', () => setTimeout(boot, 1200));
  }
  // Refresh every 45s.
  setInterval(() => {
    const p = document.getElementById('panel-sec-trio-comms');
    if (p && p.offsetParent !== null) loadTrioComms(false);
  }, 45000);
})();

/* ==================== OBEYA (Big Room dashboard) ==================== */
/* Aggregates data from existing 777 sections into a single war-room view.
   Updated on panel open + every 60s while visible. Pulls from:
   - North Star section (DOM)
   - Handshake Queue (DOM / #handshake-content)
   - Ship Board section (DOM)
   - Trio Comms (uses _trioMessages cache populated by loadTrioComms)
   - Revenue / Financial Health (DOM if present)
*/
function obeyaEscape(s){return String(s||'').replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));}

function obeyaExtractFromPanel(panelId, {maxItems=5, selector=null}={}){
  const p = document.getElementById(panelId);
  if (!p) return null;
  if (selector){
    const nodes = p.querySelectorAll(selector);
    if (!nodes.length) return null;
    return Array.from(nodes).slice(0,maxItems).map(n=>n.textContent.trim()).filter(Boolean);
  }
  const txt = (p.innerText || p.textContent || '').trim();
  return txt ? txt.slice(0, 600) : null;
}

function obeyaRenderList(elId, items, emptyMsg){
  const el = document.getElementById(elId);
  if (!el) return;
  if (!items || !items.length){
    el.innerHTML = `<div style="color:var(--text-dim);font-style:italic;font-size:12px;">${obeyaEscape(emptyMsg||'No data yet.')}</div>`;
    return;
  }
  el.innerHTML = items.map(t =>
    `<div style="padding:6px 10px;margin-bottom:6px;background:var(--bg2);border-left:3px solid var(--orange);border-radius:4px;">${obeyaEscape(t).slice(0,280)}</div>`
  ).join('');
}

function obeyaRenderNorthStar(){
  const el = document.getElementById('obeya-northstar');
  if (!el) return;
  const src = document.getElementById('panel-sec-north-star');
  if (!src){ el.innerHTML = '<div style="color:var(--text-dim);font-style:italic;font-size:12px;">North Star section not loaded yet.</div>'; return; }
  // Try to grab card titles + first line of each card
  const cards = src.querySelectorAll('.card');
  if (!cards.length){
    const txt = (src.innerText||'').trim().slice(0, 400);
    el.innerHTML = txt ? obeyaEscape(txt).replace(/\n/g,'<br>') : '<div style="color:var(--text-dim);font-style:italic;font-size:12px;">(empty)</div>';
    return;
  }
  el.innerHTML = Array.from(cards).slice(0,4).map(c => {
    const title = (c.querySelector('.card-title')?.innerText || '').trim();
    const body = (c.innerText||'').replace(title,'').trim().slice(0,180);
    return `<div style="margin-bottom:8px;"><div style="font-weight:600;color:var(--blue);font-size:12px;">${obeyaEscape(title)}</div><div style="font-size:12px;color:var(--text-dim);">${obeyaEscape(body)}</div></div>`;
  }).join('');
}

function obeyaRenderBlockers(){
  // Pull from handshake queue text content; filter lines mentioning "blocker" / "blocked" / "waiting"
  const hq = document.getElementById('handshake-content');
  const priorityPanel = document.getElementById('panel-sec-priority-filters');
  let items = [];
  if (hq){
    const lines = (hq.innerText||'').split('\n').map(l=>l.trim()).filter(Boolean);
    items = lines.filter(l => /block|blocked|blocker|waiting|stuck|stalled|pending jared|needs jared/i.test(l)).slice(0,6);
  }
  if (!items.length && priorityPanel){
    const lines = (priorityPanel.innerText||'').split('\n').map(l=>l.trim()).filter(Boolean);
    items = lines.filter(l => l.length > 10 && l.length < 200).slice(0,5);
  }
  obeyaRenderList('obeya-blockers', items, 'No active blockers detected. (Checks handshake queue + priority filters for block/waiting/stuck keywords.)');
}

function obeyaRenderInflight(){
  const hq = document.getElementById('handshake-content');
  if (!hq){ obeyaRenderList('obeya-inflight', null, 'Handshake queue loading…'); return; }
  const lines = (hq.innerText||'').split('\n').map(l=>l.trim()).filter(l => l.length > 8 && l.length < 220);
  // Prefer lines that look like actions (start with dash/bullet/verb)
  const actions = lines.filter(l => !/block|waiting|stuck/i.test(l)).slice(0,6);
  obeyaRenderList('obeya-inflight', actions, 'Queue empty or not yet loaded.');
}

function obeyaRenderShips(){
  const sb = document.getElementById('panel-sec-ship-board');
  if (!sb){ obeyaRenderList('obeya-ships', null, 'Ship board not loaded.'); return; }
  const cards = sb.querySelectorAll('.card');
  let items = [];
  if (cards.length){
    items = Array.from(cards).slice(0,5).map(c => (c.innerText||'').trim().split('\n')[0]).filter(Boolean);
  } else {
    items = (sb.innerText||'').split('\n').map(l=>l.trim()).filter(l=>l.length>10 && l.length<200).slice(0,5);
  }
  obeyaRenderList('obeya-ships', items, 'No ships logged today.');
}

function obeyaRenderMetrics(){
  const el = document.getElementById('obeya-metrics');
  if (!el) return;
  const metrics = [];
  // Try to pull key numbers from Revenue + Financial Health + BOOP Health
  const sources = [
    {id:'panel-sec-revenue', label:'Revenue'},
    {id:'panel-sec-financial-health', label:'Financial Health'},
    {id:'panel-sec-boop-health', label:'BOOP Health'},
    {id:'panel-sec-sales-pipeline', label:'Pipeline'},
  ];
  sources.forEach(s => {
    const p = document.getElementById(s.id);
    if (!p) return;
    const txt = (p.innerText||'').trim();
    const firstNum = txt.match(/([^\n]*(\$[\d,]+|\d+\s*(clients|active|posts|deals|boops|pending|open))[^\n]*)/i);
    if (firstNum) metrics.push(`<strong>${obeyaEscape(s.label)}:</strong> ${obeyaEscape(firstNum[1].trim().slice(0,120))}`);
  });
  if (!metrics.length){
    el.innerHTML = '<div style="color:var(--text-dim);font-style:italic;font-size:12px;">Metrics sections not populated yet. Refresh after Morning Pulse runs.</div>';
    return;
  }
  el.innerHTML = metrics.map(m=>`<div style="padding:4px 0;border-bottom:1px solid var(--border);">${m}</div>`).join('');
}

function obeyaRenderDecisions(){
  // Anything in handshake queue addressed to Jared / "needs decision" / "approval"
  const hq = document.getElementById('handshake-content');
  let items = [];
  if (hq){
    const lines = (hq.innerText||'').split('\n').map(l=>l.trim()).filter(Boolean);
    items = lines.filter(l => /jared|approv|decide|decision|greenlight|sign[- ]?off|yes\/no/i.test(l)).slice(0,5);
  }
  obeyaRenderList('obeya-decisions', items, 'No open decisions flagged. (Checks for items mentioning Jared / approval / decision / greenlight.)');
}

function obeyaRenderTrioTail(){
  const el = document.getElementById('obeya-trio-tail');
  if (!el) return;
  const msgs = (typeof _trioMessages !== 'undefined' && Array.isArray(_trioMessages)) ? _trioMessages : [];
  if (!msgs.length){
    el.innerHTML = '<div style="color:var(--text-dim);font-style:italic;">Trio comms not loaded yet. Open Trio Comms section first or wait 45s.</div>';
    return;
  }
  const tail = msgs.slice(-3).reverse();
  el.innerHTML = tail.map(m => {
    const from = (m.from||'?').toLowerCase();
    const color = ({aether:'#2a93c1',chy:'#5fbd5f',morphe:'#f1420b',jared:'#ffffff'})[from] || '#7a8aaa';
    const ts = m.timestamp ? new Date(m.timestamp).toLocaleTimeString('en-US',{timeZone:'America/New_York',hour:'numeric',minute:'2-digit'}) : '';
    const content = obeyaEscape((m.content||'').slice(0,240));
    return `<div style="padding:6px 8px;margin-bottom:6px;background:var(--bg2);border-left:3px solid ${color};border-radius:4px;">
      <div style="font-size:10px;color:${color};font-weight:600;">${obeyaEscape(m.from||'?')} &rarr; ${obeyaEscape(m.to||'?')} &middot; ${ts}</div>
      <div style="font-size:12px;margin-top:2px;">${content}</div>
    </div>`;
  }).join('');
}

function refreshObeya(){
  try {
    obeyaRenderNorthStar();
    obeyaRenderBlockers();
    obeyaRenderInflight();
    obeyaRenderShips();
    obeyaRenderMetrics();
    obeyaRenderDecisions();
    obeyaRenderTrioTail();
  } catch(e){ console.warn('[obeya] render failed', e); }
}

// Refresh when Obeya panel is visible
(function initObeya(){
  if (typeof document === 'undefined') return;
  const boot = () => { setTimeout(refreshObeya, 1800); };
  if (document.readyState === 'complete' || document.readyState === 'interactive') boot();
  else document.addEventListener('DOMContentLoaded', boot);
  setInterval(() => {
    const p = document.getElementById('panel-sec-obeya');
    if (p && p.offsetParent !== null) refreshObeya();
  }, 60000);
  // Also refresh when user navigates to it
  document.addEventListener('click', (e) => {
    const t = e.target.closest('[data-section="sec-obeya"]');
    if (t) setTimeout(refreshObeya, 150);
  });
})();

/* ==================== TRIO CHAT WIDGET (3-panel broadcast) ==================== */
const TRIO_WIDGET = {
  ais: [
    { id: 'aether', label: 'Aether', color: '#2a93c1', subtitle: 'Co-CEO' },
    { id: 'chy',    label: 'Chy',    color: '#d4a574', subtitle: 'Prodigy' },
    { id: 'morphe', label: 'Morphe', color: '#a78bfa', subtitle: 'Trio 3rd' },
  ],
  lastSeenTs: 0,
  pollHandle: null,
  open: false,
};

function twEscape(s){return String(s||'').replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));}
function twLinkify(s){
  let h = twEscape(s);
  h = h.replace(/`([^`]+)`/g,'<code>$1</code>');
  h = h.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>');
  h = h.replace(/(https?:\/\/[^\s<]+)/g,'<a href="$1" target="_blank" rel="noopener" style="color:inherit;text-decoration:underline;">$1</a>');
  h = h.replace(/\n/g,'<br>');
  return h;
}
function twFmtTs(iso){
  try { return new Date(iso).toLocaleTimeString('en-US',{timeZone:'America/New_York',hour:'numeric',minute:'2-digit'}); }
  catch(e){ return ''; }
}

function openTrioWidget(){
  TRIO_WIDGET.open = true;
  const m = document.getElementById('trio-widget-modal');
  if (m) { m.classList.add('open'); }
  twRefresh();
  if (TRIO_WIDGET.pollHandle) clearInterval(TRIO_WIDGET.pollHandle);
  TRIO_WIDGET.pollHandle = setInterval(twRefresh, 10000);
  setTimeout(()=>{ const i=document.getElementById('tw-input'); if(i) i.focus(); }, 120);
}
function closeTrioWidget(){
  TRIO_WIDGET.open = false;
  const m = document.getElementById('trio-widget-modal');
  if (m) m.classList.remove('open');
  if (TRIO_WIDGET.pollHandle) { clearInterval(TRIO_WIDGET.pollHandle); TRIO_WIDGET.pollHandle = null; }
}

async function twRefresh(){
  try {
    const res = await fetch(`${SHEETS_API}/trio/messages?limit=200`,{headers:{'X-API-Key':WORKER_API_KEY}});
    if (!res.ok) throw new Error('HTTP '+res.status);
    const data = await res.json();
    const messages = (data.messages || []).slice().sort((a,b)=> (a.timestamp < b.timestamp ? -1 : 1)); // oldest first for chat
    TRIO_WIDGET.ais.forEach(ai => twRenderPanel(ai, messages));
  } catch (e) {
    console.warn('[trio-widget] refresh failed', e);
  }
}

function twRenderPanel(ai, messages){
  const feed = document.getElementById('tw-feed-'+ai.id);
  if (!feed) return;
  // Show: messages FROM jared (broadcast to this AI or to 'all') AND messages FROM this AI.
  const rel = messages.filter(m => {
    const from = (m.from||'').toLowerCase();
    const to = (m.to||'').toLowerCase();
    const tos = to.split(',').map(s=>s.trim()).filter(Boolean);
    if (from === ai.id) return true;
    if (from === 'jared' && (tos.includes(ai.id) || tos.includes('all'))) return true;
    return false;
  });
  const atBottom = Math.abs(feed.scrollTop + feed.clientHeight - feed.scrollHeight) < 40;
  feed.innerHTML = rel.map(m => {
    const fromJared = (m.from||'').toLowerCase() === 'jared';
    const color = fromJared ? '#ffffff' : ai.color;
    const side = fromJared ? 'right' : 'left';
    return `
      <div class="tw-msg tw-msg-${side}">
        <div class="tw-msg-meta" style="color:${color};">${twEscape(fromJared ? 'Jared' : ai.label)} &middot; ${twEscape(twFmtTs(m.timestamp))}</div>
        <div class="tw-msg-body" style="border-color:${color}55;">${twLinkify(m.content||'')}</div>
      </div>`;
  }).join('') || `<div class="tw-empty">No messages yet. Say hi to ${twEscape(ai.label)}.</div>`;
  if (atBottom) feed.scrollTop = feed.scrollHeight;
}

async function twSend(){
  const ta = document.getElementById('tw-input');
  const status = document.getElementById('tw-status');
  const content = (ta.value||'').trim();
  if (!content) return;
  status.textContent = 'Broadcasting...';
  status.style.color = 'var(--text-dim)';
  const stamp = Date.now();
  const bridge = `jared-widget-${stamp}`;
  try {
    const res = await fetch(`${SHEETS_API}/trio/message`,{
      method:'POST',
      headers:{'X-API-Key':WORKER_API_KEY,'Content-Type':'application/json'},
      body: JSON.stringify({ from:'jared', to:'all', content, bridge_file_path: bridge })
    });
    if (!res.ok) throw new Error('HTTP '+res.status);
    ta.value = '';
    status.style.color = 'var(--green)';
    status.textContent = 'Sent to all 3.';
    setTimeout(()=>{ status.textContent=''; }, 3500);
    await twRefresh();
  } catch (e) {
    status.style.color = 'var(--red)';
    status.textContent = 'Failed: ' + e.message;
  }
}

// Keyboard: Enter to send, Shift+Enter for newline.
document.addEventListener('keydown', e => {
  if (!TRIO_WIDGET.open) return;
  if (e.key === 'Escape') { closeTrioWidget(); return; }
  if (e.target && e.target.id === 'tw-input' && e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault(); twSend();
  }
});

</script>

