        <div style="font-size:13px;">${highlightMatch(r.text, q)}</div>
      </div>
    `).join('');
  }
}, 300));

function debounce(fn, ms) { let t; return function() { clearTimeout(t); t = setTimeout(() => fn.apply(this, arguments), ms); }; }

function highlightMatch(text, query) {
  const safe = escHtml(text);
  const idx = safe.toLowerCase().indexOf(query);
  if (idx === -1) return safe;
  return safe.slice(0, idx) + '<span style="color:var(--orange);font-weight:700;">' + safe.slice(idx, idx + query.length) + '</span>' + safe.slice(idx + query.length);
}

function searchAllContent(q) {
  const results = [];
  const searchable = [
    ...microLaws.map((l, i) => ({ text: l, category: 'Micro Laws', section: 'sec-microlaws' })),
    ...contacts.map(c => ({ text: c.name + ' - ' + c.role, category: 'Relationships', section: 'sec-relationships' })),
    ...eulogies.map(e => ({ text: e.who + ': ' + e.text, category: 'Legacy', section: 'sec-legacy' })),
    ...recentTasks.map(t => ({ text: t.text, category: 'Completed Tasks', section: 'sec-proof' })),
    ...deliverables.map(d => ({ text: d.person + ': ' + d.text + ' [' + d.category + ']', category: 'Deliverables', section: 'sec-deliverables' })),
    { text: goals.infinite, category: 'Vision', section: 'sec-vision' },
    ...thinkingExercises.map(t => ({ text: t.name + ' - ' + t.desc, category: 'Thinking', section: 'sec-thinking' })),
  ];
  // Add goals
  ['daily', 'weekly', 'monthly', 'yearly'].forEach(tier => {
    (goals[tier] || []).forEach(g => {
      searchable.push({ text: g.text, category: tier.charAt(0).toUpperCase() + tier.slice(1) + ' Goal', section: 'sec-yearly-goals' });
    });
  });
  // Add daily questions
  dailyQuestions.forEach(dq => {
    searchable.push({ text: dq, category: 'Daily Reflection', section: 'sec-daily-reflection' });
  });

  searchable.forEach(item => {
    if (item.text && item.text.toLowerCase().includes(q)) {
      results.push(item);
    }
  });
  return results.slice(0, 30);
}

