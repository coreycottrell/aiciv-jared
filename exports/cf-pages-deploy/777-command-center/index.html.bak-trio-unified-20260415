// Expected row counts for summary stats
const ARCHIVE_TASK_COUNTS = { 2026: 4527, 2025: 4526, 2024: 4526, 2023: 4526, 2022: 4526, 2021: 4594, 2020: 4121, 2019: 3932 };
const ARCHIVE_GOAL_COUNTS = { 2026: 401, 2025: 401, 2024: 401, 2023: 401, 2022: 401, 2021: 401, 2020: 401 };

function selectArchiveYear(year) {
  archiveState.year = year;
  // Update button styles
  document.querySelectorAll('#archive-year-btns button').forEach(b => {
    b.className = b.textContent == year ? 'btn btn-orange btn-sm' : 'btn btn-outline btn-sm';
  });
  // Reload current tab for new year
  loadArchiveTab(archiveState.tab);
}

function loadArchiveTab(tab) {
  archiveState.tab = tab;
  archiveState.page = 0;

  // Update tab button styles
  document.querySelectorAll('#archive-tab-btns button').forEach(b => {
    const tabId = b.id.replace('arch-tab-', '');
    b.className = tabId === tab ? 'btn btn-orange btn-sm' : 'btn btn-outline btn-sm';
  });

  // Determine which sheet range to fetch
  let sheetName = '';
  const year = archiveState.year;

  if (tab === 'tasks') {
    sheetName = ARCHIVE_TAB_MAP.tasks[year];
    if (!sheetName) { showArchiveEmpty('No task data for ' + year); return; }
  } else if (tab === 'goals') {
    sheetName = ARCHIVE_TAB_MAP.goals[year];
    if (!sheetName) { showArchiveEmpty('No goals data for ' + year); return; }
  } else if (tab === 'reflections') {
    // Map year to correct reflection tab
    if (year >= 2026) sheetName = ARCHIVE_TAB_MAP.reflections['2026-2028'];
    else if (year >= 2023) sheetName = ARCHIVE_TAB_MAP.reflections['2023-2025'];
    else sheetName = ARCHIVE_TAB_MAP.reflections['2019-2022'];
  } else {
    // Non-year-specific tabs
    const tabMap = ARCHIVE_TAB_MAP[tab];
    if (tabMap) sheetName = tabMap.all || Object.values(tabMap)[0];
    if (!sheetName) { showArchiveEmpty('No data for this tab'); return; }
  }

  const cacheKey = sheetName;
  if (archiveState.cache[cacheKey]) {
    applyArchiveData(archiveState.cache[cacheKey], tab);
    return;
  }

  // Show loading
  showArchiveLoading(sheetName);

  // Fetch from API (lazy load)
  fetchArchiveSheet(sheetName, tab);
}

async function fetchArchiveSheet(sheetName, tab) {
  try {
    const range = "'" + sheetName + "'!A:ZZ";
    const url = `${SHEETS_API}/api/sheets/read?range=${encodeURIComponent(range)}`;
    const res = await fetch(url, { headers: { 'X-API-Key': WORKER_API_KEY } });
    if (!res.ok) throw new Error('API returned ' + res.status);
    const data = await res.json();
    const values = data.values || [];
    archiveState.cache[sheetName] = values;
    applyArchiveData(values, tab);
    toast('Loaded ' + values.length + ' rows from ' + sheetName.split('(')[0].trim(), 'success');
  } catch(e) {
    console.warn('Archive fetch failed:', e);
    hideArchiveLoading();
    showArchiveEmpty('Failed to load data: ' + e.message + '. Try refreshing.');
    toast('Archive load failed', 'error');
  }
}

function applyArchiveData(values, tab) {
  hideArchiveLoading();
  if (!values || values.length === 0) { showArchiveEmpty('No data found'); return; }

  archiveState.data = values;
  archiveState.filteredData = values;
  archiveState.page = 0;
  renderArchiveTable();
}

function renderArchiveTable() {
  const data = archiveState.filteredData;
  if (!data || data.length === 0) { showArchiveEmpty('No matching data'); return; }

  const table = document.getElementById('archive-data-table');
  const thead = document.getElementById('archive-table-head');
  const tbody = document.getElementById('archive-table-body');
  const empty = document.getElementById('archive-empty');
  const pagination = document.getElementById('archive-pagination');

  table.style.display = 'table';
  empty.style.display = 'none';

  // Determine if data is wide (reflections, nightly, etc.) or narrow (tasks, goals)
  const maxCols = Math.max(...data.map(r => r.length));
  const isWide = maxCols > 10;

  // Headers from first row (or generate)
  const headers = data[0] || [];
  const displayCols = isWide ? Math.min(headers.length, 20) : headers.length;

  thead.innerHTML = '<tr>' + headers.slice(0, displayCols).map((h, i) =>
    `<th style="min-width:${i === 0 ? '200px' : '80px'};max-width:300px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="${escHtml(h || 'Col ' + (i+1))}">${escHtml(h || 'Col ' + (i+1))}</th>`
  ).join('') + (isWide && headers.length > displayCols ? '<th style="color:var(--text-muted);">+' + (headers.length - displayCols) + ' more</th>' : '') + '</tr>';

  // Paginate data rows (skip header)
  const rows = data.slice(1);
  const start = archiveState.page * archiveState.pageSize;
  const end = Math.min(start + archiveState.pageSize, rows.length);
  const pageRows = rows.slice(start, end);

  tbody.innerHTML = pageRows.map(row => {
    return '<tr>' + row.slice(0, displayCols).map((cell, i) => {
      const val = (cell || '').toString();
      const truncated = val.length > 80 ? val.slice(0, 80) + '...' : val;
      return `<td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${escHtml(val)}">${escHtml(truncated)}</td>`;
    }).join('') + (isWide && row.length > displayCols ? '<td style="color:var(--text-muted);font-size:10px;">...</td>' : '') + '</tr>';
  }).join('');

  // Update pagination
  const totalPages = Math.ceil(rows.length / archiveState.pageSize);
  if (totalPages > 1) {
    pagination.style.display = 'flex';
    document.getElementById('archive-page-info').textContent =
      `Page ${archiveState.page + 1} of ${totalPages} (${rows.length.toLocaleString()} rows)`;
  } else {
    pagination.style.display = 'none';
  }

  // Update result count
  document.getElementById('archive-result-count').textContent =
    rows.length.toLocaleString() + ' rows loaded';
}

function filterArchiveData() {
  const q = (document.getElementById('archive-search').value || '').toLowerCase().trim();
  if (!q) {
    archiveState.filteredData = archiveState.data;
  } else {
    archiveState.filteredData = [
      archiveState.data[0], // keep headers
      ...archiveState.data.slice(1).filter(row =>
        row.some(cell => cell && cell.toString().toLowerCase().includes(q))
      )
    ];
  }
  archiveState.page = 0;
  renderArchiveTable();
}

function archiveNextPage() {
  const totalPages = Math.ceil((archiveState.filteredData.length - 1) / archiveState.pageSize);
  if (archiveState.page < totalPages - 1) {
    archiveState.page++;
    renderArchiveTable();
    document.getElementById('archive-data-container').scrollTop = 0;
  }
}

function archivePrevPage() {
  if (archiveState.page > 0) {
    archiveState.page--;
    renderArchiveTable();
    document.getElementById('archive-data-container').scrollTop = 0;
  }
}

function showArchiveLoading(sheetName) {
  document.getElementById('archive-loading').style.display = 'block';
  document.getElementById('archive-loading-detail').textContent = 'Fetching: ' + sheetName;
  document.getElementById('archive-data-table').style.display = 'none';
  document.getElementById('archive-empty').style.display = 'none';
  document.getElementById('archive-pagination').style.display = 'none';
}

function hideArchiveLoading() {
  document.getElementById('archive-loading').style.display = 'none';
}

function showArchiveEmpty(msg) {
  document.getElementById('archive-data-table').style.display = 'none';
