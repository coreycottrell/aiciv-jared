/* ======================== HEATMAP ======================== */
function scoreToHeat(s) { if (s === 0) return 0; if (s <= 3) return 1; if (s <= 6) return 2; if (s <= 9) return 3; if (s <= 12) return 4; return 5; }

function buildHeatmap() {
  const container = document.getElementById('heatmap-weeks');
  const monthsEl = document.getElementById('heatmap-months');
  const today = new Date();
  const startDate = new Date(today); startDate.setDate(today.getDate() - 90);
  startDate.setDate(startDate.getDate() - startDate.getDay());
  const tooltip = document.getElementById('tooltip');

  const weeks = [];
  let cur = new Date(startDate);
  for (let w = 0; w < 14; w++) {
    const week = [];
    for (let d = 0; d < 7; d++) { week.push(new Date(cur)); cur.setDate(cur.getDate() + 1); }
    weeks.push(week);
  }

  const monthsSeen = new Set();
  const mLabels = [];
  weeks.forEach(w => { const m = w[0].getMonth(); const l = w[0].toLocaleString('default', { month: 'short' }); mLabels.push(!monthsSeen.has(m) ? (monthsSeen.add(m), l) : ''); });
  monthsEl.innerHTML = mLabels.map(l => `<span class="heatmap-month-label">${l}</span>`).join('');

  const scoreMap = {};
  dailyScores.forEach((s, i) => { const d = new Date(today); d.setDate(today.getDate() - (90 - i)); scoreMap[d.toDateString()] = s; });

  container.innerHTML = '';
  weeks.forEach(week => {
    const col = document.createElement('div'); col.className = 'heatmap-week';
    week.forEach(day => {
      const cell = document.createElement('div');
      const ds = day.toDateString();
      const isFuture = day > today; const isToday = ds === today.toDateString();
      const score = scoreMap[ds] || 0;
      cell.className = 'heatmap-cell' + (isFuture ? '' : ' heat-' + scoreToHeat(score));
      if (isToday) { cell.style.outline = '2px solid var(--orange)'; cell.style.outlineOffset = '1px'; }
      if (!isFuture) {
        cell.addEventListener('mouseenter', e => {
