function applyMorningPulseData(data) {
  console.log('[MorningPulse] applyMorningPulseData called with', data ? data.length : 'null', 'rows');
  if (!data || data.length < 2) {
    console.warn('[MorningPulse] no data or too few rows — falling back to localStorage');
    const restored = rehydrateMorningPulseFromLocal();
    if (restored) console.log('[Morning Pulse] rehydrated from localStorage (sheet empty/null)');
    return;
  }
  // Find today's entries - column A is Date
  const now = new Date();
  const yyyy = now.getFullYear();
  const mm = String(now.getMonth() + 1).padStart(2, '0');
  const dd = String(now.getDate()).padStart(2, '0');
  const todayISO = `${yyyy}-${mm}-${dd}`;                          // 2026-04-14
  const todaySlash = `${now.getMonth()+1}/${now.getDate()}/${yyyy}`; // 4/14/2026
  const todayMonthDay = `${now.getMonth()+1}/${now.getDate()}`;     // 4/14
  console.log('[MorningPulse] looking for date:', todayISO, '/', todaySlash);
  const pulseItems = document.getElementById('morning-pulse-items');
  if (!pulseItems) { console.warn('[MorningPulse] morning-pulse-items element not found'); return; }
  let html = '';
  let hasToday = false;
  let lastSavedTime = '';
  // Headers: Date, Priorities, Aether Scope, ETA, Chy Scope, ETA, Overlaps, Status
  // Iterate in reverse so LATEST entry for today wins
  for (let r = data.length - 1; r >= 1; r--) {
    const dateStr = (data[r][0] || '').trim();
    const matchISO = dateStr === todayISO;
    const matchSlash = dateStr === todaySlash;
    const matchFuzzy = dateStr.includes(todayMonthDay) && dateStr.includes(String(yyyy));
    if (matchISO || matchSlash || matchFuzzy) {
      if (hasToday) continue; // already got latest, skip older dupes
      hasToday = true;
      const priorities = data[r][1] || '';
      const aetherScope = data[r][2] || '';
      const aetherETA = data[r][3] || '';
