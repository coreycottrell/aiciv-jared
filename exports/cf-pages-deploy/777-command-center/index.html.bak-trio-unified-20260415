// Tracks which pillars the user has manually overridden this session
let ragManualOverride = { people: false, product: false, profits: false };

// Monthly MRR ramp targets (April=M1 through September=M6)
const MRR_RAMP_TARGETS = {
  4: 161825,   // M1 Apr
  5: 398685,   // M2 May
  6: 677355,   // M3 Jun
  7: 981555,   // M4 Jul
  8: 1368985,  // M5 Aug
  9: 1840255   // M6 Sep
};

// Headcount targets by month
const HEADCOUNT_TARGETS = {
  4: 23,  // M1 Apr
  5: 30,  // M2 May
  6: 30,  // M3 Jun
  7: 31,  // M4 Jul
  8: 34   // M5 Aug
};

// Product milestones (true = complete)
const PRODUCT_MILESTONES = {
  'Birth Pipeline': true,
  'Portal (17/17 QA)': true,
  'Brainiac Training': true,
  'Referral System': true,
  'Enterprise Features': false,
  'NVIDIA Setup': false,
  'PureSurf v5.5': true,
  'Voice TTS': true
};

function calculateRAGStatus() {
  if (!liveMetrics) return;

  const now = new Date();
  const month = now.getMonth() + 1; // 1-12

  // === PROFITS RAG ===
  if (!ragManualOverride.profits) {
    const mrr = liveMetrics.mrr || 0;
    const target = MRR_RAMP_TARGETS[month];
    let profitsColor, profitsLabel;

    if (!target) {
      // Outside ramp months (Oct-Mar) - use simple growth check
      profitsColor = mrr > 10000 ? 'green' : (mrr > 0 ? 'amber' : 'red');
      profitsLabel = mrr > 10000 ? 'On Track' : (mrr > 0 ? 'Early Stage' : 'No Revenue');
    } else if (mrr < 10000) {
      // Pre-raise / early stage: ramp hasn't meaningfully started
      profitsColor = 'amber';
      profitsLabel = 'Pre-Raise';
    } else {
      const pct = mrr / target;
      if (pct >= 0.8) {
        profitsColor = 'green';
        profitsLabel = 'On Track';
      } else if (pct >= 0.5) {
        profitsColor = 'amber';
        profitsLabel = 'Needs Attention';
      } else {
        profitsColor = 'red';
        profitsLabel = 'Below Target';
      }
    }

    const fmtMrr = mrr >= 1000 ? '$' + (mrr / 1000).toFixed(1) + 'K' : '$' + mrr;
    profitsLabel += ' \u2014 ' + fmtMrr + ' MRR';
    ragStatus.profits = profitsColor;
    updateRAGDisplay('profits', profitsColor, profitsLabel, true);
  }

  // === PEOPLE RAG ===
  if (!ragManualOverride.people) {
    const headcountTarget = HEADCOUNT_TARGETS[month] || 30;
    // Current headcount: count active clients as proxy for team + known team size
    // Use a known baseline: 30+ people, 13+ AIs
    const currentHeadcount = 30; // baseline - updated manually or from sheets
    let peopleColor, peopleLabel;

    const pct = currentHeadcount / headcountTarget;
    if (pct >= 1.0) {
      peopleColor = 'green';
      peopleLabel = 'On Track';
    } else if (pct >= 0.8) {
      peopleColor = 'amber';
      peopleLabel = 'Needs Attention';
    } else {
      peopleColor = 'red';
      peopleLabel = 'Below Target';
    }
    peopleLabel += ' \u2014 ' + currentHeadcount + '/' + headcountTarget;
    ragStatus.people = peopleColor;
    updateRAGDisplay('people', peopleColor, peopleLabel, true);
  }

  // === PRODUCT RAG ===
  if (!ragManualOverride.product) {
    const total = Object.keys(PRODUCT_MILESTONES).length;
    const done = Object.values(PRODUCT_MILESTONES).filter(v => v).length;
    const pct = done / total;
    let productColor, productLabel;

    if (pct >= 0.7) {
      productColor = 'green';
      productLabel = 'On Track';
    } else if (pct >= 0.5) {
      productColor = 'amber';
      productLabel = 'Needs Attention';
    } else {
      productColor = 'red';
      productLabel = 'Action Required';
    }
    productLabel += ' \u2014 ' + done + '/' + total + ' milestones';
    ragStatus.product = productColor;
    updateRAGDisplay('product', productColor, productLabel, true);
  }

  // Save and render
  saveRAGToStorage();
  renderRAGIndicators();
  console.log('[777] RAG auto-calculated:', JSON.stringify(ragStatus));
}

