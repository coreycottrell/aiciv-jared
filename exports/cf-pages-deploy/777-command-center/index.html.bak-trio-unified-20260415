/* ======================== APPLY HEATMAP FROM REFLECTION ======================== */
function applyHeatmapFromReflection(data) {
  if (!data || data.length < 3) return;
  const headers = data[1] || []; // Row 2 has dates
  const today = new Date();
  // Build a map of date -> total score for that day
  const realScoreMap = {};
  let maxPossible = 0;
  let questionCount = 0;
  // Count questions (rows 3+)
  for (let r = 2; r < data.length; r++) {
    if (data[r][0] && data[r][0].trim() && !data[r][0].includes('TOTAL') && !data[r][0].includes('AVERAGE')) {
      questionCount++;
    }
  }
  // For each date column, sum the scores
  for (let c = 2; c < headers.length; c++) {
    if (!headers[c]) continue;
    // Parse the date header (format: M/D/YY)
    const parts = headers[c].trim().split('/');
    if (parts.length < 2) continue;
    const month = parseInt(parts[0]) - 1;
    const day = parseInt(parts[1]);
    const year = parts.length >= 3 ? (parseInt(parts[2]) < 100 ? 2000 + parseInt(parts[2]) : parseInt(parts[2])) : today.getFullYear();
    const dateObj = new Date(year, month, day);
    // Only look at last 91 days
    const daysDiff = Math.floor((today - dateObj) / 86400000);
    if (daysDiff < 0 || daysDiff > 91) continue;
    let dayTotal = 0;
    for (let r = 2; r < data.length; r++) {
      if (data[r][0] && data[r][0].trim() && !data[r][0].includes('TOTAL') && !data[r][0].includes('AVERAGE')) {
        const val = parseFloat(data[r][c]);
        if (!isNaN(val)) dayTotal += val;
      }
    }
    realScoreMap[dateObj.toDateString()] = dayTotal;
  }
  // Replace the random dailyScores with real data
  dailyMax = questionCount || 15;
  dailyScores = [];
  for (let i = 90; i >= 0; i--) {
    const d = new Date(today); d.setDate(today.getDate() - i);
    const score = realScoreMap[d.toDateString()];
    dailyScores.push(score !== undefined ? Math.round(score) : 0);
  }
  // Rebuild heatmap and related displays
  buildHeatmap();
  buildTodayRing();
  buildSparklines();
  updateQuickStatsFromData();
}

/* ======================== APPLY STREAKS FROM REFLECTION ======================== */
function applyStreaksFromReflection(data) {
  if (!data || data.length < 3) return;
  const headers = data[1] || [];
  const today = new Date();
  // Calculate current streak: consecutive days with score > 0
  let streak = 0;
  // Find today's column index and work backwards
  for (let c = headers.length - 1; c >= 2; c--) {
    if (!headers[c]) continue;
    const parts = headers[c].trim().split('/');
    if (parts.length < 2) continue;
    const month = parseInt(parts[0]) - 1;
    const day = parseInt(parts[1]);
    const year = parts.length >= 3 ? (parseInt(parts[2]) < 100 ? 2000 + parseInt(parts[2]) : parseInt(parts[2])) : today.getFullYear();
    const dateObj = new Date(year, month, day);
    const daysDiff = Math.floor((today - dateObj) / 86400000);
    if (daysDiff < 0 || daysDiff > 365) continue;
    // Check if any scores exist for this day
    let hasScore = false;
    for (let r = 2; r < data.length; r++) {
      if (data[r][c] && parseFloat(data[r][c]) > 0) { hasScore = true; break; }
    }
    if (hasScore && daysDiff <= streak + 1) {
      streak = daysDiff + 1;
    } else if (!hasScore && daysDiff <= streak) {
      break; // Streak broken
    }
  }
  // Update streak display
  window._liveStreak = streak;
  const streaksList = document.getElementById('streaks-list');
  if (streaksList) {
    streaksList.innerHTML = `
      <div class="streak-item"><div class="streak-icon">&#128293;</div><div><div class="streak-name">Daily Reflection</div><div class="streak-days">${streak} day${streak !== 1 ? 's' : ''} running</div></div><div class="streak-badge">${streak}</div></div>
      <div class="streak-item"><div class="streak-icon">&#9989;</div><div><div class="streak-name">Task Completion</div><div class="streak-days">Active today</div></div><div class="streak-badge">${window._liveTaskCount ? '&#10003;' : '-'}</div></div>
    `;
  }
  // Update quick stats streak
  const qsStreak = document.getElementById('qs-streak');
  if (qsStreak) qsStreak.textContent = streak;
}

