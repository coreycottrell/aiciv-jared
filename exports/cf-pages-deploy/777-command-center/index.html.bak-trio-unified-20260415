  renderAllPillars();
}

function addSubgoal() {
  if (nsActiveCategory < 0 || !nsActivePillarKey) return;
  const input = document.getElementById('ns-new-subgoal');
  const text = input.value.trim();
  if (!text) return;
  const cats = nsData.pillars[nsActivePillarKey].categories;
  if (!cats[nsActiveCategory].subgoals) cats[nsActiveCategory].subgoals = [];
  if (cats[nsActiveCategory].subgoals.length >= 5) {
    toast('Max 5 sub-goals per category', 'error');
    return;
  }
  cats[nsActiveCategory].subgoals.push({ text, abcde: '', quadrant: '', level: '', assignee: '' });
  input.value = '';
  saveNorthStarToStorage();
  selectCategory(nsActivePillarKey, nsActiveCategory);
  saveNorthStarToSheet(nsActivePillarKey);
  generateSmartSuggestions();
}

function removeSubgoal(pillarKey, catIdx, sgIdx) {
  nsData.pillars[pillarKey].categories[catIdx].subgoals.splice(sgIdx, 1);
  saveNorthStarToStorage();
  selectCategory(pillarKey, catIdx);
  saveNorthStarToSheet(pillarKey);
  generateSmartSuggestions();
}

async function scoreSubgoal(pillarKey, catIdx, sgIdx) {
  const sg = nsData.pillars[pillarKey].categories[catIdx].subgoals[sgIdx];
  const abcde = await brandedPrompt('ABCDE Score', 'Score for: "' + sg.text + '"\n\nA = Must do (serious consequences)\nB = Should do (mild consequences)\nC = Nice to do (no consequences)\nD = Delegate\nE = Eliminate', sg.abcde || 'A');
  if (abcde && 'ABCDE'.includes(abcde.toUpperCase())) sg.abcde = abcde.toUpperCase();

  const quad = await brandedPrompt('Eisenhower Quadrant', '1 = Urgent + Important (DO NOW)\n2 = Important, Not Urgent (SCHEDULE)\n3 = Urgent, Not Important (DELEGATE)\n4 = Not Urgent, Not Important (ELIMINATE)', sg.quadrant || '1');
  if (quad && '1234'.includes(quad)) sg.quadrant = quad;

  const level = await brandedPrompt('Priority Level', '1 = Critical (NOW)\n2 = Important (NEXT)\n3 = Progress (SOON)\n4 = Accomplish (MIND)\n5 = Enjoyment (LIFETIME)', sg.level || '1');
  if (level && '12345'.includes(level)) sg.level = level;

  sg.assignee = computeAssignee(sg);

  saveNorthStarToStorage();
  selectCategory(pillarKey, catIdx);
  saveNorthStarToSheet(pillarKey);
  renderPriorityFilters();
  generateSmartSuggestions();
}

function computeAssignee(sg) {
  const { abcde, quadrant, level } = sg;
  if (abcde === 'A' && (quadrant === '1' || quadrant === '2') && (level === '1' || level === '2')) return 'Jared';
  if (abcde === 'B' && quadrant === '2' && level === '3') return 'Aether';
  if (abcde === 'B' && (quadrant === '1' || quadrant === '2')) return 'Chy';
  if (abcde === 'D' || quadrant === '3') return 'Team';
  if (abcde === 'E' || quadrant === '4') return 'Eliminate';
  return 'Team';
}

