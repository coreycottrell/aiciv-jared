          hasToday = true;
          console.log('[Morning Pulse] rehydrated from localStorage (sheet had no today row)');
          // Rehydrate smart suggestions so race-guard protects these priorities
          if (typeof smpSuggestions !== 'undefined') {
            smpSuggestions = local.priorities.map(text => ({ text: text, source: 'Saved by Jared (local)', approved: true, task: null }));
            if (typeof renderSmartPulse === 'function') renderSmartPulse();
