/* ======================== APPLY SHIP BOARD FROM EOD ======================== */
function applyShipBoard(data) {
  if (!data || data.length < 2) return;
  const container = document.getElementById('ship-board-items');
  container.dataset.loaded = 'true';
  // Headers: Date, Aether Shipped, Chy Shipped, Combined, Blockers, Tomorrow
  const now = new Date();
  const todayStr = (now.getMonth()+1) + '/' + now.getDate() + '/' + now.getFullYear();
  const yesterday = new Date(now); yesterday.setDate(yesterday.getDate()-1);
  const yesterdayStr = (yesterday.getMonth()+1) + '/' + yesterday.getDate() + '/' + yesterday.getFullYear();

  // Find today's data first, fall back to yesterday
  let targetRow = null;
  let isYesterday = false;
  for (let r = data.length - 1; r >= 1; r--) {
    if (!data[r][0]) continue;
    const d = data[r][0].trim();
    if (d === todayStr || d.includes(now.getDate() + '/' + now.getFullYear())) { targetRow = data[r]; break; }
  }
  if (!targetRow) {
    for (let r = data.length - 1; r >= 1; r--) {
      if (!data[r][0]) continue;
      const d = data[r][0].trim();
      if (d === yesterdayStr || d.includes(yesterday.getDate() + '/' + yesterday.getFullYear())) { targetRow = data[r]; isYesterday = true; break; }
    }
  }
  // If still no match, use most recent entry
  if (!targetRow) {
    for (let r = data.length - 1; r >= 1; r--) {
      if (data[r] && data[r][0]) { targetRow = data[r]; isYesterday = true; break; }
    }
  }

  if (!targetRow || (!targetRow[1] && !targetRow[2])) {
    container.innerHTML = '<div style="color:var(--text-dim);font-size:13px;text-align:center;padding:32px 20px;">End-of-day report will populate at 5pm ET</div>';
    return;
  }

  const dateLabel = isYesterday ? 'Yesterday (' + escHtml(targetRow[0]) + ')' : 'Today';
  let html = '<div style="font-size:10px;color:var(--text-muted);font-family:\'Oswald\',sans-serif;letter-spacing:1px;text-transform:uppercase;margin-bottom:12px;">' + dateLabel + '</div>';
  html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">';
  // AETHER column
  html += '<div style="background:var(--bg3);border-radius:10px;padding:14px;border-top:3px solid var(--blue);">';
  html += '<div style="font-family:\'Oswald\',sans-serif;font-size:13px;letter-spacing:2px;color:var(--blue);margin-bottom:10px;">AETHER</div>';
  if (targetRow[1]) {
    const items = targetRow[1].split(/[,;\n]+/).filter(Boolean);
    items.forEach(item => { html += '<div style="font-size:12px;padding:4px 0;border-bottom:1px solid rgba(255,255,255,0.03);">' + escHtml(item.trim()) + '</div>'; });
  } else {
    html += '<div style="font-size:11px;color:var(--text-muted);">No items logged</div>';
  }
  html += '</div>';
  // CHY column
  html += '<div style="background:var(--bg3);border-radius:10px;padding:14px;border-top:3px solid var(--orange);">';
  html += '<div style="font-family:\'Oswald\',sans-serif;font-size:13px;letter-spacing:2px;color:var(--orange);margin-bottom:10px;">CHY</div>';
  if (targetRow[2]) {
    const items = targetRow[2].split(/[,;\n]+/).filter(Boolean);
    items.forEach(item => { html += '<div style="font-size:12px;padding:4px 0;border-bottom:1px solid rgba(255,255,255,0.03);">' + escHtml(item.trim()) + '</div>'; });
  } else {
    html += '<div style="font-size:11px;color:var(--text-muted);">No items logged</div>';
  }
  html += '</div></div>';
  container.innerHTML = html;
}

