  html += '</div>';
  return html;
}

function renderSinglePillar(pillarKey) {
  const cfg = NS_PILLAR_CONFIG[pillarKey];
  const p = nsData.pillars[pillarKey];

  // Center
  const center = document.getElementById('ns-center');
  center.className = 'ns-center expanded ' + cfg.theme;
  center.onclick = () => editNorthStar(pillarKey);
  document.getElementById('ns-center-icon').textContent = cfg.icon;
  const label = document.getElementById('ns-center-label');
  label.textContent = cfg.name;
  label.className = 'ns-center-label ' + cfg.theme;
  document.getElementById('ns-center-text').textContent = p.northStar || 'Click to set your ' + cfg.name + ' goal';

