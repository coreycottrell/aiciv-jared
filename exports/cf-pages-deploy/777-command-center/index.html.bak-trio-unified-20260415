function renderMonthlySummary(now) {
  const container = document.getElementById('deliv-monthly-content');
  if (!container) return;

  // Group by month
  const months = {};
  deliverables.forEach(d => {
    const dt = new Date(d.date);
    if (dt.getFullYear() !== now.getFullYear()) return;
    const key = dt.getMonth();
    if (!months[key]) months[key] = { total: 0, byPerson: { Jared: 0, Aether: 0, Chy: 0 }, best: [] };
    months[key].total++;
    months[key].byPerson[d.person] = (months[key].byPerson[d.person] || 0) + 1;
    if (d.category === 'Strategic' || d.category === 'Product') months[key].best.push(d.text);
  });

  const monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  let html = '<div class="deliv-monthly-grid">';
  for (let m = 0; m <= now.getMonth(); m++) {
    const data = months[m] || { total: 0, byPerson: { Jared: 0, Aether: 0, Chy: 0 }, best: [] };
    const isCurrent = m === now.getMonth();
    html += `<div class="deliv-monthly-card" style="${isCurrent ? 'border-color:var(--orange);' : ''}">
      <div class="deliv-monthly-name">${monthNames[m]} ${now.getFullYear()}</div>
      <div class="deliv-monthly-num">${data.total}</div>
      <div class="deliv-monthly-sub">deliverables</div>
      <div style="margin-top:8px;font-size:10px;color:var(--text-dim);">
        J:${data.byPerson.Jared} | A:${data.byPerson.Aether} | C:${data.byPerson.Chy}
      </div>
      ${data.best.length > 0 ? `<div style="margin-top:6px;font-size:10px;color:var(--blue);font-style:italic;">${escHtml(data.best[0])}</div>` : ''}
    </div>`;
  }
  html += '</div>';

  // Trend line
  const monthTotals = [];
  for (let m = 0; m <= now.getMonth(); m++) monthTotals.push(months[m] ? months[m].total : 0);
  if (monthTotals.length >= 2) {
    const trend = monthTotals[monthTotals.length - 1] - monthTotals[monthTotals.length - 2];
    html += `<div style="text-align:center;margin-top:16px;font-size:12px;color:${trend >= 0 ? 'var(--green)' : 'var(--red)'};">
      ${trend >= 0 ? '&#9650;' : '&#9660;'} ${Math.abs(trend)} ${trend >= 0 ? 'more' : 'fewer'} than last month - ${trend >= 0 ? 'Accelerating!' : 'Let\'s push harder'}
    </div>`;
  }
  container.innerHTML = html;
}

function renderYearlyArchive(now) {
  const tabsEl = document.getElementById('deliv-yearly-tabs');
  const container = document.getElementById('deliv-yearly-content');
  if (!tabsEl || !container) return;

  // Get distinct years
  const years = new Set();
  deliverables.forEach(d => { const y = new Date(d.date).getFullYear(); if (y) years.add(y); });
  if (years.size === 0) years.add(now.getFullYear());
  const sortedYears = [...years].sort((a, b) => b - a);

  tabsEl.innerHTML = sortedYears.map((y, i) =>
    `<div class="deliv-yearly-tab ${i === 0 ? 'active' : ''}" onclick="selectDelivYear(${y})">${y}</div>`
  ).join('');

  selectDelivYear(sortedYears[0]);
}

function selectDelivYear(year) {
  document.querySelectorAll('.deliv-yearly-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.deliv-yearly-tab').forEach(t => { if (t.textContent == year) t.classList.add('active'); });

  const container = document.getElementById('deliv-yearly-content');
  const yearItems = deliverables.filter(d => new Date(d.date).getFullYear() === year);

  if (yearItems.length === 0) { container.innerHTML = '<div class="deliv-empty">No deliverables for ' + year + '</div>'; return; }

  // Summary + full list
  const byPerson = { Jared: 0, Aether: 0, Chy: 0 };
  yearItems.forEach(d => { byPerson[d.person] = (byPerson[d.person] || 0) + 1; });

  let html = `<div style="display:flex;gap:20px;justify-content:center;margin-bottom:16px;">`;
  ['Jared', 'Aether', 'Chy'].forEach(p => {
    html += `<div style="text-align:center;"><div style="font-family:'Oswald',sans-serif;font-size:28px;font-weight:700;color:var(--orange);">${byPerson[p]}</div><div style="font-size:10px;color:var(--text-dim);text-transform:uppercase;">${p}</div></div>`;
  });
  html += `<div style="text-align:center;"><div style="font-family:'Oswald',sans-serif;font-size:28px;font-weight:700;color:var(--blue);">${yearItems.length}</div><div style="font-size:10px;color:var(--text-dim);text-transform:uppercase;">Total</div></div>`;
  html += '</div>';

  // Full list grouped by date descending
  const byDate = {};
  yearItems.forEach(d => { if (!byDate[d.date]) byDate[d.date] = []; byDate[d.date].push(d); });
  const sortedDates = Object.keys(byDate).sort((a, b) => new Date(b) - new Date(a));

  html += '<div id="deliv-yearly-list" style="max-height:500px;overflow-y:auto;">';
  sortedDates.forEach(date => {
    html += `<div style="font-size:11px;color:var(--text-dim);margin:12px 0 6px;font-family:'Oswald',sans-serif;letter-spacing:1px;">${date}</div>`;
    byDate[date].forEach(d => {
      const tagClass = 'deliv-tag-' + (DELIV_CATEGORIES[d.category] || 'product');
      const avatar = d.person === 'Jared' ? '&#128081;' : d.person === 'Aether' ? '&#129504;' : '&#9881;';
      html += `<div class="deliv-card"><div style="display:flex;align-items:center;gap:8px;"><span style="font-size:12px;">${avatar}</span><span class="deliv-card-text" style="margin:0;flex:1;">${escHtml(d.text)}</span><span class="deliv-tag ${tagClass}">${escHtml(d.category)}</span></div></div>`;
    });
  });
  html += '</div>';
  container.innerHTML = html;
}

