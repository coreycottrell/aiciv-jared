          console.log('[MorningPulse] restoring from localStorage (' + local.priorities.length + ' priorities)');
          const colorsLS = ['var(--orange)', 'var(--blue)', 'var(--green)'];
          const savedHHMM = (new Date(local.savedAt || Date.now())).toLocaleTimeString('en-US', {hour:'numeric', minute:'2-digit'});
          html = local.priorities.map((line, i) => {
            const c = colorsLS[i] || 'var(--text-dim)';
            return `
            <div class="morning-item" style="display:flex;align-items:center;gap:10px;padding:8px 12px;background:var(--bg3);border-radius:8px;margin-bottom:4px;border-left:3px solid ${c};">
