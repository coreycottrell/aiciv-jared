/* ======================== TODAY RING ======================== */
function buildTodayRing() {
  const canvas = document.getElementById('ring-today');
  const ctx = canvas.getContext('2d');
  const score = dailyScores[dailyScores.length - 1];
  const pct = score / dailyMax;
  document.getElementById('today-score').textContent = score;
  document.getElementById('today-max').textContent = '/' + dailyMax;

  let current = 0;
  const target = pct * Math.PI * 2;
  const step = target / 60;
  function draw() {
    ctx.clearRect(0, 0, 110, 110);
    ctx.beginPath(); ctx.arc(55, 55, 44, -Math.PI/2, Math.PI * 1.5);
    ctx.strokeStyle = 'rgba(241,66,11,0.12)'; ctx.lineWidth = 10; ctx.lineCap = 'round'; ctx.stroke();
    ctx.beginPath(); ctx.arc(55, 55, 44, -Math.PI/2, -Math.PI/2 + current);
    const grad = ctx.createLinearGradient(11, 55, 99, 55);
    grad.addColorStop(0, '#f1420b'); grad.addColorStop(1, '#ff6b35');
    ctx.strokeStyle = grad; ctx.lineWidth = 10; ctx.lineCap = 'round'; ctx.stroke();
    if (current < target) { current = Math.min(current + step, target); requestAnimationFrame(draw); }
  }
  draw();
}

/* ======================== SPARKLINES ======================== */
function buildSparklines() {
  const container = document.getElementById('sparklines-row');
  const last7 = dailyScores.slice(-7);
  const sparkData = [
    { label: '7-Day Score', values: last7, color: '#f1420b' },
    { label: 'Streak', values: [14,14,15,16,17,20,21], color: '#2a93c1' },
    { label: 'Weekly Avg', values: [8,9,8,10,9,11,10], color: '#22c55e' },
  ];
  container.innerHTML = '';
  sparkData.forEach(sp => {
    const min = Math.min(...sp.values); const max = Math.max(...sp.values); const range = max - min || 1;
    const w = 100, h = 32, pad = 4;
    const pts = sp.values.map((v, i) => {
      const x = pad + (i / (sp.values.length - 1)) * (w - pad * 2);
      const y = h - pad - ((v - min) / range) * (h - pad * 2);
      return `${x},${y}`;
    }).join(' ');
    const last = pts.split(' ').pop().split(',');
    container.innerHTML += `<div class="sparkline-item"><div class="sparkline-label">${sp.label}</div><svg class="sparkline-svg" viewBox="0 0 ${w} ${h}"><polyline points="${pts}" fill="none" stroke="${sp.color}" stroke-width="2" stroke-linecap="round"/><circle cx="${last[0]}" cy="${last[1]}" r="3" fill="${sp.color}"/></svg></div>`;
  });
}

