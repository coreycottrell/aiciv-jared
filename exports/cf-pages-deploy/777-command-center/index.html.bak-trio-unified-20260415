    const statusBadge = status.includes('done') || status.includes('complete') ? 'badge-green' : status.includes('overdue') || status.includes('block') ? 'badge-red' : status.includes('open') || status.includes('pending') ? 'badge-orange' : status.includes('progress') ? 'badge-yellow' : 'badge-blue';
    html += `<tr>
      <td>${escHtml(data[r][0])}</td>
      <td>${escHtml(data[r][1] || '')}</td>
      <td>${escHtml(data[r][2] || '')}</td>
