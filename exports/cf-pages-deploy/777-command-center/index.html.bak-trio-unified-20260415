function renderCompactCategories(pillarKey) {
  const p = nsData.pillars[pillarKey];
  const cfg = NS_PILLAR_CONFIG[pillarKey];
  const radius = 105;
  let html = '<div style="position:relative;width:100%;height:100%;">';
  for (let i = 0; i < 8; i++) {
    const angle = (i * 45 - 90) * (Math.PI / 180);
