async function fetchSheet(range, spreadsheetId) {
  const cacheKey = (spreadsheetId || '') + ':' + range;
  if (sheetsCache[cacheKey] && Date.now() - lastFetch < 60000) return sheetsCache[cacheKey];
  if (!API_KEY) return null;
  try {
    let url = `${SHEETS_API}/api/sheets/read?range=${encodeURIComponent(range)}`;
    if (spreadsheetId) url += `&spreadsheetId=${encodeURIComponent(spreadsheetId)}`;
    const res = await fetch(url, {
      headers: { 'X-API-Key': WORKER_API_KEY }
    });
    if (!res.ok) throw new Error('Sheets API ' + res.status);
    const data = await res.json();
    sheetsCache[cacheKey] = data.values || [];
    lastFetch = Date.now();
    return sheetsCache[cacheKey];
  } catch(e) {
    console.warn('Sheets fetch failed:', e);
    return null;
  }
