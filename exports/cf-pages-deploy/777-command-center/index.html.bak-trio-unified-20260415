          source: 'Saved by Jared',
          approved: true,
          task: null
        }));
        if (typeof renderSmartPulse === 'function') renderSmartPulse();
      }
    } catch(e) { console.warn('[pulse] could not restore smart pulse state', e); }
  }
}

