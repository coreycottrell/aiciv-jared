/* ======================== CONTENT CALENDAR (BaaS API) ======================== */
async function loadContentCalendar() {
  const cal = document.getElementById('content-cal-strip');
  try {
    const res = await fetch('https://surf.purebrain.ai/social/scheduled', {
      headers: { 'X-API-Key': 'WtHJY1zr0HuP4NmcBNMUSGXlM2kxIeibDDmY-btXSHs' }
    });
    if (res.ok) {
      const data = await res.json();
      const days = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri'];
      const today = new Date();
      const todayDay = today.getDay();
      // Group scheduled items by day of week
      const byDay = { 1: [], 2: [], 3: [], 4: [], 5: [] };
      (Array.isArray(data) ? data : data.items || []).forEach(item => {
        const d = new Date(item.scheduled_at || item.date);
        const dow = d.getDay();
        if (dow >= 1 && dow <= 5) {
          byDay[dow].push(item);
        }
      });
      cal.innerHTML = days.map((d, i) => {
        const dow = i + 1;
        const items = byDay[dow] || [];
        const itemsHtml = items.length > 0
          ? items.map(it => {
              const platform = (it.platform || 'LI').toUpperCase().slice(0, 2);
              const color = platform === 'LI' ? 'var(--blue)' : platform === 'BS' ? 'var(--orange)' : 'var(--green)';
              return `<div style="padding:6px 8px;background:rgba(42,147,193,0.1);border-radius:6px;font-size:10px;margin-bottom:4px;"><span style="font-weight:700;color:${color};">${platform}</span> ${escHtml((it.title || it.text || 'Scheduled').slice(0, 30))}</div>`;
            }).join('')
          : '<div style="font-size:10px;color:var(--text-muted);padding:6px;">No items</div>';
        return `<div class="cal-strip-day ${dow === todayDay ? 'today' : ''}">
          <div style="font-family:'Oswald',sans-serif;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--text-dim);margin-bottom:8px;text-align:center;">${d}</div>
          ${itemsHtml}
        </div>`;
      }).join('');
      return;
    }
  } catch(e) { console.warn('BaaS API unavailable:', e); }
  // Fallback: show static calendar
  const days = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri'];
  const todayDay = new Date().getDay();
  cal.innerHTML = days.map((d, i) => `
    <div class="cal-strip-day ${i + 1 === todayDay ? 'today' : ''}">
      <div style="font-family:'Oswald',sans-serif;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--text-dim);margin-bottom:8px;text-align:center;">${d}</div>
      <div style="padding:6px 8px;background:var(--blue-dim);border-radius:6px;font-size:10px;margin-bottom:4px;"><span style="font-weight:700;color:var(--blue);">LI</span> Post scheduled</div>
    </div>
  `).join('');
}

