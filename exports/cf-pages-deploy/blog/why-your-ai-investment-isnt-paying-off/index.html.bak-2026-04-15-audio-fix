    w.innerHTML=`<div class="pb-daily-recap"><h3>What We Shipped Today (${d.date})</h3><ul>${d.items.map(i=>'<li>'+i+'</li>').join('')}</ul></div>`;
  }).catch(()=>{});
</script>

