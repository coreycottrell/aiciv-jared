<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="PureBrain's governance architecture — constitutional compliance infrastructure for autonomous AI operations. Transparent governance you can examine." />
  <meta property="og:title" content="Governance Spine — PureBrain.ai" />
  <meta property="og:description" content="Constitutional compliance infrastructure for autonomous AI operations. Governance you can't circumvent." />
  <meta property="og:type" content="website" />
  <title>Governance Spine — PureBrain.ai</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #080a12; --bg-2: #0d1120; --bg-3: #111827;
      --blue: #2a93c1; --blue-dim: #1a6a92;
      --blue-glow: rgba(42,147,193,0.15); --blue-glow-sm: rgba(42,147,193,0.08);
      --orange: #f1420b; --orange-dim: #b83008;
      --orange-glow: rgba(241,66,11,0.15);
      --green: #22c55e; --green-glow: rgba(34,197,94,0.12);
      --white: #ffffff; --muted: rgba(255,255,255,0.55); --muted-2: rgba(255,255,255,0.72);
      --border: rgba(255,255,255,0.07); --border-blue: rgba(42,147,193,0.25);
      --border-orange: rgba(241,66,11,0.25); --border-green: rgba(34,197,94,0.2);
      --radius: 12px; --radius-lg: 20px;
      --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
      --font-serif: Georgia, 'Times New Roman', serif;
    }
    html { scroll-behavior: smooth; }
    body { background: var(--bg); color: var(--white); font-family: var(--font-sans); font-size: 16px; line-height: 1.6; -webkit-font-smoothing: antialiased; overflow-x: hidden; }
    ::selection { background: var(--blue); color: #fff; }
    h1, h2, h3, h4 { line-height: 1.15; letter-spacing: -0.02em; }
    .section-label { font-size: 11px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--blue); margin-bottom: 12px; display: block; }
    .container { max-width: 1120px; margin: 0 auto; padding: 0 24px; }
    section { padding: 100px 0; }

    /* NAV */
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(8,10,18,0.85); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-bottom: 1px solid var(--border); transition: background 0.3s; }
    .nav-inner { display: flex; align-items: center; justify-content: space-between; height: 64px; max-width: 1120px; margin: 0 auto; padding: 0 24px; }
    .nav-logo { font-size: 18px; font-weight: 800; letter-spacing: -0.01em; text-decoration: none; }
    .nav-logo .blue { color: var(--blue); } .nav-logo .orange { color: var(--orange); }
    .nav-links { display: flex; gap: 32px; list-style: none; }
    .nav-links a { color: var(--muted); text-decoration: none; font-size: 14px; font-weight: 500; transition: color 0.2s; }
    .nav-links a:hover { color: var(--white); }
    .nav-cta { background: var(--blue); color: #fff !important; padding: 8px 18px; border-radius: 8px; font-weight: 600 !important; transition: background 0.2s !important; }
    .nav-cta:hover { background: var(--blue-dim) !important; }
    @media (max-width: 768px) { .nav-links { display: none; } }

    /* HERO */
    .hero { min-height: 100vh; display: flex; align-items: center; justify-content: center; text-align: center; position: relative; overflow: hidden; padding-top: 64px; }
    .hero-grid-bg { position: absolute; inset: 0; background-image: linear-gradient(rgba(42,147,193,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(42,147,193,0.04) 1px, transparent 1px); background-size: 60px 60px; mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, #000 40%, transparent 100%); }
    .hero-glow { position: absolute; top: 20%; left: 50%; transform: translateX(-50%); width: 700px; height: 400px; background: radial-gradient(ellipse, rgba(42,147,193,0.12) 0%, transparent 70%); pointer-events: none; }
    .hero-neural-bg { position: absolute; inset: 0; pointer-events: none; }
    .hero-neural-bg canvas { width: 100%; height: 100%; }
    .hero-content { position: relative; z-index: 1; max-width: 860px; padding: 0 24px; }
    .hero-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(42,147,193,0.1); border: 1px solid var(--border-blue); border-radius: 100px; padding: 6px 16px; font-size: 12px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--blue); margin-bottom: 32px; }
    .hero-badge-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--blue); animation: pulse-dot 2s ease-in-out infinite; }
    @keyframes pulse-dot { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(0.8); } }
    .hero-title { font-family: var(--font-serif); font-size: clamp(52px, 8vw, 96px); font-weight: 700; letter-spacing: -0.03em; color: var(--white); margin-bottom: 24px; line-height: 1.0; }
    .hero-subtitle { font-size: clamp(17px, 2.5vw, 21px); color: var(--muted); max-width: 620px; margin: 0 auto 20px; font-weight: 400; line-height: 1.55; }
    .hero-tagline { font-size: 14px; color: var(--blue); font-style: italic; font-family: var(--font-serif); letter-spacing: 0.01em; }
    .hero-stats { display: flex; gap: 40px; justify-content: center; margin-top: 48px; flex-wrap: wrap; }
    .hero-stat { text-align: center; }
    .hero-stat-value { font-size: 32px; font-weight: 800; color: var(--blue); line-height: 1; font-variant-numeric: tabular-nums; }
    .hero-stat-value .orange { color: var(--orange); }
    .hero-stat-label { font-size: 12px; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; margin-top: 4px; }
    .hero-scroll { margin-top: 56px; display: flex; justify-content: center; }
    .scroll-indicator { display: flex; flex-direction: column; align-items: center; gap: 8px; color: var(--muted); font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; }
    .scroll-line { width: 1px; height: 48px; background: linear-gradient(to bottom, var(--blue), transparent); animation: scroll-anim 2s ease-in-out infinite; }
    @keyframes scroll-anim { 0%, 100% { opacity: 0.4; } 50% { opacity: 1; } }

    /* SHARED */
    .section-header { margin-bottom: 60px; }
    .section-header h2 { font-size: clamp(32px, 4vw, 48px); font-weight: 700; color: var(--white); margin-bottom: 16px; }
    .section-header p { font-size: 17px; color: var(--muted); max-width: 600px; line-height: 1.6; }
    .section-divider { width: 60px; height: 3px; background: linear-gradient(90deg, var(--blue), var(--orange)); border-radius: 2px; margin: 0 0 28px 0; }

    /* PROBLEM */
    #problem { background: var(--bg-2); position: relative; overflow: hidden; }
    #problem::before { content: ''; position: absolute; top: -100px; right: -200px; width: 600px; height: 600px; background: radial-gradient(ellipse, rgba(241,66,11,0.06) 0%, transparent 70%); pointer-events: none; }
    .problem-intro { max-width: 760px; margin-bottom: 64px; }
    .problem-intro h2 { font-size: clamp(36px, 5vw, 60px); font-weight: 700; line-height: 1.1; margin-bottom: 24px; }
    .problem-intro h2 em { font-style: normal; color: var(--orange); }
    .problem-intro p { font-size: 18px; color: var(--muted-2); line-height: 1.7; }
    .problem-approaches { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-bottom: 60px; }
    .approach-card { background: rgba(255,255,255,0.02); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 28px; transition: all 0.3s; }
    .approach-card:hover { border-color: rgba(241,66,11,0.2); transform: translateY(-2px); }
    .approach-label { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--orange); margin-bottom: 12px; display: block; }
    .approach-card h3 { font-size: 17px; font-weight: 700; color: var(--white); margin-bottom: 8px; }
    .approach-cost { font-size: 22px; font-weight: 800; color: var(--orange); margin-bottom: 10px; }
    .approach-card p { font-size: 14px; color: var(--muted); line-height: 1.6; }
    .approach-verdict { margin-top: 14px; padding: 10px 14px; background: rgba(241,66,11,0.06); border: 1px solid rgba(241,66,11,0.15); border-radius: 8px; font-size: 13px; color: rgba(255,255,255,0.6); font-style: italic; }
    .problem-insight { background: rgba(42,147,193,0.04); border: 1px solid var(--border-blue); border-radius: var(--radius-lg); padding: 40px; display: grid; grid-template-columns: auto 1fr; gap: 32px; align-items: center; }
    @media (max-width: 640px) { .problem-insight { grid-template-columns: 1fr; } }
    .problem-insight h3 { font-size: 22px; font-weight: 700; color: var(--white); margin-bottom: 12px; }
    .problem-insight p { font-size: 16px; color: var(--muted-2); line-height: 1.7; }
    .problem-insight p strong { color: var(--blue); }

    /* QUESTIONS */
    #questions { background: var(--bg); }
    .questions-grid { display: grid; gap: 20px; }
    .question-card { background: rgba(255,255,255,0.02); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 32px; transition: border-color 0.3s, transform 0.3s; position: relative; overflow: hidden; }
    .question-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; }
    .question-card.implemented::before { background: linear-gradient(90deg, var(--green), transparent); }
    .question-card.partial::before { background: linear-gradient(90deg, var(--orange), transparent); }
    .question-card:hover { border-color: rgba(255,255,255,0.12); transform: translateY(-2px); }
    .question-card.implemented:hover { border-color: var(--border-green); }
    .question-card.partial:hover { border-color: var(--border-orange); }
    .question-header { display: flex; align-items: flex-start; gap: 16px; margin-bottom: 20px; }
    .question-number { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; color: var(--muted); padding-top: 4px; flex-shrink: 0; }
    .question-meta { flex: 1; }
    .question-title { font-size: 18px; font-weight: 700; color: var(--white); margin-bottom: 8px; line-height: 1.3; }
    .status-badge { display: inline-flex; align-items: center; gap: 6px; padding: 4px 12px; border-radius: 100px; font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
    .status-badge.implemented { background: var(--green-glow); border: 1px solid var(--border-green); color: var(--green); }
    .status-badge.partial { background: var(--orange-glow); border: 1px solid var(--border-orange); color: var(--orange); }
    .status-icon { font-size: 14px; }
    .question-answer { font-size: 15px; color: rgba(255,255,255,0.72); line-height: 1.7; }
    .question-answer strong { color: var(--white); font-weight: 600; }
    .gap-note { margin-top: 16px; padding: 12px 16px; background: rgba(241,66,11,0.06); border: 1px solid rgba(241,66,11,0.15); border-radius: 8px; font-size: 13px; color: rgba(255,255,255,0.6); }
    .gap-note strong { color: var(--orange); }

    /* ARCHITECTURE */
    #architecture { background: var(--bg-2); }
    .arch-tower-wrap { margin-bottom: 64px; display: flex; justify-content: center; }
    .arch-tower { width: 100%; max-width: 760px; }
    .arch-layers { display: flex; flex-direction: column; gap: 0; }
    .arch-layer { display: grid; grid-template-columns: 56px 1fr 180px; align-items: stretch; background: rgba(255,255,255,0.02); border: 1px solid var(--border); border-bottom: none; transition: all 0.3s; cursor: default; }
    .arch-layer:first-child { border-radius: var(--radius-lg) var(--radius-lg) 0 0; }
    .arch-layer:last-child { border-radius: 0 0 var(--radius-lg) var(--radius-lg); border-bottom: 1px solid var(--border); }
    .arch-layer:hover { background: rgba(42,147,193,0.04); border-color: var(--border-blue); z-index: 1; position: relative; }
    .arch-layer:hover + .arch-layer { border-top-color: var(--border-blue); }
    .arch-layer-num { display: flex; align-items: center; justify-content: center; background: rgba(42,147,193,0.06); border-right: 1px solid var(--border); font-size: 11px; font-weight: 800; letter-spacing: 0.1em; color: var(--blue); padding: 20px 8px; transition: color 0.2s; }
    .arch-layer:hover .arch-layer-num { color: var(--orange); }
    .arch-layer-body { padding: 20px 24px; }
    .arch-layer-title { font-size: 15px; font-weight: 700; color: var(--white); margin-bottom: 4px; }
    .arch-layer-desc { font-size: 13px; color: var(--muted); line-height: 1.5; }
    .arch-layer-analog { display: flex; align-items: center; padding: 20px; border-left: 1px solid var(--border); }
    @media (max-width: 640px) { .arch-layer { grid-template-columns: 40px 1fr; } .arch-layer-analog { display: none; } }
    .analog-label { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); display: block; margin-bottom: 3px; }
    .analog-value { font-size: 12px; color: rgba(255,255,255,0.75); line-height: 1.3; }
    .arch-detail-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 20px; }
    .arch-card { background: rgba(255,255,255,0.025); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 28px; transition: all 0.3s; }
    .arch-card:hover { background: rgba(42,147,193,0.04); border-color: var(--border-blue); transform: translateY(-3px); box-shadow: 0 20px 60px rgba(0,0,0,0.3), 0 0 40px rgba(42,147,193,0.06); }
    .arch-card-number { font-size: 11px; font-weight: 800; letter-spacing: 0.2em; color: var(--blue); margin-bottom: 14px; display: block; }
    .arch-card-icon { width: 48px; height: 48px; border-radius: 12px; background: var(--blue-glow); border: 1px solid var(--border-blue); display: flex; align-items: center; justify-content: center; margin-bottom: 18px; }
    .arch-card h3 { font-size: 18px; font-weight: 700; color: var(--white); margin-bottom: 12px; }
    .arch-card-description { font-size: 14px; color: rgba(255,255,255,0.72); line-height: 1.7; margin-bottom: 16px; }
    .arch-card-description strong { color: var(--white); }
    .arch-card-analogy { padding: 14px 16px; background: rgba(42,147,193,0.05); border: 1px solid rgba(42,147,193,0.12); border-radius: 8px; margin-bottom: 14px; }
    .analogy-label { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--blue); display: block; margin-bottom: 4px; }
    .analogy-text { font-size: 13px; color: rgba(255,255,255,0.7); line-height: 1.5; font-style: italic; }
    .arch-card-impl { font-size: 13px; color: var(--muted); line-height: 1.55; }
    .arch-card-impl strong { color: rgba(255,255,255,0.8); font-weight: 600; }

    /* NETWORK VISUAL */
    #network-visual { background: var(--bg); padding: 80px 0; }
    .network-visual-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
    @media (max-width: 768px) { .network-visual-inner { grid-template-columns: 1fr; } }
    .network-text h2 { font-size: clamp(28px, 4vw, 40px); font-weight: 700; margin-bottom: 20px; line-height: 1.2; }
    .network-text p { font-size: 16px; color: var(--muted-2); line-height: 1.7; margin-bottom: 20px; }
    .network-text p strong { color: var(--blue); }
    .network-feature-list { list-style: none; display: flex; flex-direction: column; gap: 12px; }
    .network-feature-list li { display: flex; align-items: flex-start; gap: 12px; font-size: 14px; color: rgba(255,255,255,0.75); line-height: 1.5; }
    .nfl-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--blue); flex-shrink: 0; margin-top: 6px; }

    /* COMPARISON */
    #comparison { background: var(--bg-2); }
    .compare-table-wrap { border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; }
    .compare-table-header { display: grid; grid-template-columns: 200px 1fr 1fr; background: rgba(255,255,255,0.02); border-bottom: 1px solid var(--border); }
    @media (max-width: 640px) { .compare-table-header { grid-template-columns: 1fr 1fr; } .compare-th.aspect { display: none; } }
    .compare-th { padding: 16px 20px; font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; }
    .compare-th.traditional { color: var(--orange); background: rgba(241,66,11,0.04); }
    .compare-th.purebrain { color: var(--blue); background: rgba(42,147,193,0.05); }
    .compare-th.aspect { color: var(--muted); }
    .compare-tr { display: grid; grid-template-columns: 200px 1fr 1fr; border-bottom: 1px solid var(--border); transition: background 0.2s; }
    .compare-tr:last-child { border-bottom: none; }
    .compare-tr:hover { background: rgba(255,255,255,0.02); }
    @media (max-width: 640px) { .compare-tr { grid-template-columns: 1fr 1fr; } .compare-td.aspect { display: none; } }
    .compare-td { padding: 14px 20px; font-size: 14px; line-height: 1.5; border-right: 1px solid var(--border); }
    .compare-td:last-child { border-right: none; }
    .compare-td.traditional { color: rgba(255,255,255,0.5); }
    .compare-td.purebrain { color: rgba(255,255,255,0.88); font-weight: 500; }
    .compare-td.aspect { color: var(--muted); font-size: 12px; font-weight: 600; letter-spacing: 0.04em; }
    .td-bad { color: rgba(241,66,11,0.75) !important; }
    .td-good { color: rgba(42,193,147,0.9) !important; font-weight: 600 !important; }
    .shield-section { display: flex; align-items: center; gap: 40px; padding: 40px; background: rgba(42,147,193,0.04); border: 1px solid var(--border-blue); border-radius: var(--radius-lg); margin-top: 60px; flex-wrap: wrap; }
    .shield-text { flex: 1; min-width: 260px; }
    .shield-text h3 { font-size: 22px; font-weight: 700; color: var(--white); margin-bottom: 12px; }
    .shield-text p { font-size: 15px; color: var(--muted-2); line-height: 1.7; }
    .shield-text p strong { color: var(--blue); }

    /* EVIDENCE */
    #evidence { background: var(--bg); }
    .evidence-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; }
    .metric-card { background: rgba(255,255,255,0.025); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 28px 24px; text-align: center; transition: all 0.3s; }
    .metric-card:hover { border-color: var(--border-blue); background: rgba(42,147,193,0.04); transform: translateY(-2px); }
    .metric-value { font-size: clamp(36px, 5vw, 52px); font-weight: 800; letter-spacing: -0.03em; color: var(--blue); line-height: 1; margin-bottom: 10px; font-variant-numeric: tabular-nums; }
    .metric-value span.plus { color: var(--orange); }
    .metric-label { font-size: 14px; font-weight: 600; color: var(--white); margin-bottom: 6px; }
    .metric-desc { font-size: 12px; color: var(--muted); line-height: 1.5; }
    .pipeline-display { margin-top: 56px; display: flex; align-items: center; justify-content: center; gap: 0; flex-wrap: wrap; }
    .pipeline-step { display: flex; align-items: center; }
    .pipeline-label { background: rgba(42,147,193,0.1); border: 1px solid var(--border-blue); border-radius: 8px; padding: 10px 20px; font-size: 13px; font-weight: 700; color: var(--blue); letter-spacing: 0.05em; text-transform: uppercase; white-space: nowrap; }
    .pipeline-arrow { color: var(--muted); font-size: 18px; padding: 0 12px; }

    /* ROADMAP */
    #roadmap { background: var(--bg-2); }
    .roadmap-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; }
    .roadmap-card { background: rgba(255,255,255,0.02); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 32px; position: relative; transition: all 0.3s; }
    .roadmap-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, var(--orange), transparent); border-radius: var(--radius-lg) var(--radius-lg) 0 0; }
    .roadmap-card:hover { border-color: var(--border-orange); background: var(--orange-glow); transform: translateY(-3px); }
    .roadmap-timeline { display: inline-block; background: rgba(241,66,11,0.1); border: 1px solid var(--border-orange); border-radius: 100px; padding: 4px 12px; font-size: 11px; font-weight: 700; color: var(--orange); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px; }
    .roadmap-card h3 { font-size: 19px; font-weight: 700; color: var(--white); margin-bottom: 14px; }
    .roadmap-card p { font-size: 14px; color: var(--muted); line-height: 1.65; }
    .roadmap-card p strong { color: rgba(255,255,255,0.8); }
    .gap-reason { margin-top: 18px; display: flex; align-items: flex-start; gap: 10px; font-size: 13px; color: rgba(255,255,255,0.5); font-style: italic; }
    .gap-reason-icon { color: var(--orange); flex-shrink: 0; margin-top: 1px; }

    /* FORM */
    #challenge { background: var(--bg); }
    .cta-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
    @media (max-width: 768px) { .cta-wrap { grid-template-columns: 1fr; gap: 40px; } }
    .cta-left h2 { font-size: clamp(28px, 4vw, 44px); font-weight: 700; margin-bottom: 20px; line-height: 1.15; }
    .cta-left p { font-size: 16px; color: var(--muted); line-height: 1.65; margin-bottom: 24px; }
    .cta-promise { display: flex; flex-direction: column; gap: 10px; }
    .cta-promise-item { display: flex; align-items: center; gap: 10px; font-size: 14px; color: rgba(255,255,255,0.75); }
    .cta-promise-check { color: var(--blue); font-weight: 700; flex-shrink: 0; }
    .challenge-form { background: rgba(255,255,255,0.025); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 36px; }
    .form-group { margin-bottom: 18px; }
    .form-group label { display: block; font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); margin-bottom: 8px; }
    .form-group input, .form-group textarea { width: 100%; background: rgba(255,255,255,0.04); border: 1px solid var(--border); border-radius: 8px; padding: 12px 16px; font-size: 15px; font-family: var(--font-sans); color: var(--white); transition: border-color 0.2s, background 0.2s; resize: vertical; }
    .form-group input::placeholder, .form-group textarea::placeholder { color: rgba(255,255,255,0.25); }
    .form-group input:focus, .form-group textarea:focus { outline: none; border-color: var(--blue); background: rgba(42,147,193,0.06); }
    .form-group textarea { min-height: 120px; }
    .form-submit { width: 100%; background: var(--blue); color: #fff; border: none; border-radius: 8px; padding: 14px 24px; font-size: 15px; font-weight: 700; font-family: var(--font-sans); cursor: pointer; transition: background 0.2s, transform 0.15s; letter-spacing: 0.02em; }
    .form-submit:hover { background: var(--blue-dim); transform: translateY(-1px); }

    /* FOOTER */
    footer { background: var(--bg); border-top: 1px solid var(--border); padding: 40px 0; }
    .footer-inner { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 20px; }
    .footer-logo { font-size: 16px; font-weight: 800; text-decoration: none; }
    .footer-text { font-size: 13px; color: var(--muted); }
    .footer-links { display: flex; gap: 24px; list-style: none; }
    .footer-links a { font-size: 13px; color: var(--muted); text-decoration: none; transition: color 0.2s; }
    .footer-links a:hover { color: var(--blue); }

    /* SECTION IMAGES */
    .section-image { width: 100%; max-width: 900px; margin: 40px auto; display: block; border-radius: var(--radius-lg); border: 1px solid var(--border); box-shadow: 0 20px 60px rgba(0,0,0,0.4), 0 0 40px rgba(42,147,193,0.06); }
    .section-image.full-width { max-width: 100%; }

    /* ANIMATIONS */
    .fade-in { opacity: 0; transform: translateY(24px); transition: opacity 0.65s ease, transform 0.65s ease; }
    .fade-in.visible { opacity: 1; transform: translateY(0); }
    .fade-in-group > * { opacity: 0; transform: translateY(24px); transition: opacity 0.55s ease, transform 0.55s ease; }
    .fade-in-group.visible > *:nth-child(1) { opacity: 1; transform: none; transition-delay: 0.05s; }
    .fade-in-group.visible > *:nth-child(2) { opacity: 1; transform: none; transition-delay: 0.12s; }
    .fade-in-group.visible > *:nth-child(3) { opacity: 1; transform: none; transition-delay: 0.19s; }
    .fade-in-group.visible > *:nth-child(4) { opacity: 1; transform: none; transition-delay: 0.26s; }
    .fade-in-group.visible > *:nth-child(5) { opacity: 1; transform: none; transition-delay: 0.33s; }
    .fade-in-group.visible > *:nth-child(6) { opacity: 1; transform: none; transition-delay: 0.40s; }

    @media (max-width: 640px) {
      section { padding: 72px 0; }
      .pipeline-display { flex-direction: column; gap: 8px; }
      .pipeline-arrow { transform: rotate(90deg); padding: 4px 0; }
      .footer-inner { flex-direction: column; text-align: center; }
      .footer-links { justify-content: center; }
      .hero-stats { gap: 24px; }
    }
  </style>
</head>
