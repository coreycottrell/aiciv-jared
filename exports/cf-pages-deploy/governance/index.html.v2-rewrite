          <div class="cta-promise-item"><span class="cta-promise-check">&#10003;</span><span>Direct response from the team within 48 hours</span></div>
          <div class="cta-promise-item"><span class="cta-promise-check">&#10003;</span><span>Specific architectural trace for your scenario</span></div>
          <div class="cta-promise-item"><span class="cta-promise-check">&#10003;</span><span>If we find a gap, we&rsquo;ll add it to the roadmap</span></div>
          <div class="cta-promise-item"><span class="cta-promise-check">&#10003;</span><span>No sales call required to get an honest answer</span></div>
        </div>
      </div>
      <div class="fade-in">
        <form class="challenge-form" action="mailto:jared@puretechnology.nyc" method="post" enctype="text/plain">
          <div class="form-group">
            <label for="name">Your Name</label>
            <input type="text" id="name" name="name" placeholder="Jane Smith" required />
          </div>
          <div class="form-group">
            <label for="company">Company</label>
            <input type="text" id="company" name="company" placeholder="Acme Corp" />
          </div>
          <div class="form-group">
            <label for="challenge-input">Governance Scenario</label>
            <textarea id="challenge-input" name="challenge" placeholder="Describe the governance challenge, edge case, or question you want PureBrain to address..." required></textarea>
          </div>
          <div class="form-group">
            <label for="email">Your Email</label>
            <input type="email" id="email" name="email" placeholder="jane@acme.com" required />
          </div>
          <button type="submit" class="form-submit">Submit Challenge &rarr;</button>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="container">
    <div class="footer-inner">
      <a href="https://purebrain.ai" class="footer-logo">
        <span class="blue">PUREBR</span><span class="orange">AI</span><span class="blue">N</span>
      </a>
      <p class="footer-text">An AI Civilization Production &copy; 2026</p>
      <ul class="footer-links">
        <li><a href="https://purebrain.ai">purebrain.ai</a></li>
        <li><a href="https://purebrain.ai/privacy-policy/">Privacy Policy</a></li>
        <li><a href="https://purebrain.ai/terms-of-service/">Terms of Service</a></li>
      </ul>
    </div>
  </div>
</footer>

<script>
(function () {
  'use strict';

  // Fade-in on scroll
  var observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.fade-in, .fade-in-group').forEach(function (el) {
    observer.observe(el);
  });

  // Animate metric values
  function animateCounter(el, target, duration) {
    var startTime = null;
    function step(timestamp) {
      if (!startTime) startTime = timestamp;
      var progress = Math.min((timestamp - startTime) / duration, 1);
      var eased = 1 - Math.pow(1 - progress, 3);
      var current = Math.floor(eased * target);
      var plusSpan = el.querySelector('.plus');
      if (plusSpan) {
        el.childNodes[0].textContent = current.toLocaleString();
      } else {
        el.textContent = current.toLocaleString();
      }
      if (progress < 1) {
        requestAnimationFrame(step);
      } else {
        if (plusSpan) el.childNodes[0].textContent = target.toLocaleString();
        else el.textContent = target.toLocaleString();
      }
    }
    requestAnimationFrame(step);
  }

  var metricObserver = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        var el = entry.target;
        var rawText = el.textContent.replace(/[^0-9]/g, '');
        var target = parseInt(rawText, 10);
        if (!isNaN(target) && target > 0) animateCounter(el, target, 1400);
        metricObserver.unobserve(el);
      }
    });
  }, { threshold: 0.3 });

  document.querySelectorAll('.metric-value').forEach(function (el) {
    metricObserver.observe(el);
  });

  // Nav scroll darkening
  var nav = document.querySelector('nav');
  window.addEventListener('scroll', function () {
    nav.style.background = window.scrollY > 60
      ? 'rgba(8,10,18,0.97)'
      : 'rgba(8,10,18,0.85)';
  }, { passive: true });

  // ========== NEURAL NETWORK CANVAS ANIMATION ==========
  (function initNeuralCanvas() {
    var canvas = document.getElementById('neuralCanvas');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var dpr = window.devicePixelRatio || 1;
    var W, H, nodes = [], connections = [], particles = [];
    var BLUE = { r: 42, g: 147, b: 193 };
    var ORANGE = { r: 241, g: 66, b: 11 };
    var animId;
    var heroSection = document.querySelector('.hero');

    function resize() {
      var rect = canvas.parentElement.getBoundingClientRect();
      W = rect.width; H = rect.height;
      canvas.width = W * dpr; canvas.height = H * dpr;
      canvas.style.width = W + 'px'; canvas.style.height = H + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      initNodes();
    }

    function initNodes() {
      nodes = [];
      var count = Math.min(50, Math.floor(W * H / 12000));
      for (var i = 0; i < count; i++) {
        var isOrange = Math.random() < 0.15;
        nodes.push({
          x: Math.random() * W, y: Math.random() * H,
          vx: (Math.random() - 0.5) * 0.4, vy: (Math.random() - 0.5) * 0.3,
          r: isOrange ? 3 + Math.random() * 3 : 2 + Math.random() * 2.5,
          color: isOrange ? ORANGE : BLUE,
          pulse: Math.random() * Math.PI * 2
        });
      }
      // Build connections for nearby nodes
      connections = [];
      for (var a = 0; a < nodes.length; a++) {
        for (var b = a + 1; b < nodes.length; b++) {
          var dx = nodes[a].x - nodes[b].x, dy = nodes[a].y - nodes[b].y;
          if (Math.sqrt(dx * dx + dy * dy) < 200) {
            connections.push([a, b]);
          }
        }
      }
      // Particles traveling along connections
      particles = [];
      for (var p = 0; p < Math.min(12, connections.length); p++) {
        var ci = Math.floor(Math.random() * connections.length);
        particles.push({ conn: ci, t: Math.random(), speed: 0.002 + Math.random() * 0.004, color: Math.random() < 0.3 ? ORANGE : BLUE });
      }
    }

    function draw(time) {
      ctx.clearRect(0, 0, W, H);
      var t = time * 0.001;

      // Update node positions
      for (var i = 0; i < nodes.length; i++) {
        var n = nodes[i];
        n.x += n.vx; n.y += n.vy;
        if (n.x < -20) n.x = W + 20; if (n.x > W + 20) n.x = -20;
        if (n.y < -20) n.y = H + 20; if (n.y > H + 20) n.y = -20;
        n.pulse += 0.02;
      }

      // Rebuild connections dynamically
      connections = [];
      for (var a = 0; a < nodes.length; a++) {
        for (var b = a + 1; b < nodes.length; b++) {
          var dx = nodes[a].x - nodes[b].x, dy = nodes[a].y - nodes[b].y;
          var dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 180) {
            connections.push([a, b, dist]);
          }
        }
      }

      // Draw connections
      for (var c = 0; c < connections.length; c++) {
        var na = nodes[connections[c][0]], nb = nodes[connections[c][1]];
        var d = connections[c][2];
        var alpha = 0.12 * (1 - d / 180);
        ctx.beginPath();
        ctx.moveTo(na.x, na.y); ctx.lineTo(nb.x, nb.y);
        ctx.strokeStyle = 'rgba(' + BLUE.r + ',' + BLUE.g + ',' + BLUE.b + ',' + alpha + ')';
        ctx.lineWidth = 0.8;
        ctx.stroke();
      }

      // Draw particles
      for (var p = 0; p < particles.length; p++) {
        var part = particles[p];
        part.t += part.speed;
        if (part.t > 1) { part.t = 0; part.conn = Math.floor(Math.random() * connections.length); }
        if (part.conn < connections.length) {
          var ca = nodes[connections[part.conn][0]], cb = nodes[connections[part.conn][1]];
          var px = ca.x + (cb.x - ca.x) * part.t;
          var py = ca.y + (cb.y - ca.y) * part.t;
          ctx.beginPath();
          ctx.arc(px, py, 1.5, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(' + part.color.r + ',' + part.color.g + ',' + part.color.b + ',0.7)';
          ctx.fill();
        }
      }

      // Draw nodes
      for (var i = 0; i < nodes.length; i++) {
        var n = nodes[i];
        var pulseR = n.r + Math.sin(n.pulse) * 0.8;
        // Glow
        ctx.beginPath();
        ctx.arc(n.x, n.y, pulseR * 4, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(' + n.color.r + ',' + n.color.g + ',' + n.color.b + ',0.04)';
        ctx.fill();
        // Core
        ctx.beginPath();
        ctx.arc(n.x, n.y, pulseR, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(' + n.color.r + ',' + n.color.g + ',' + n.color.b + ',' + (0.5 + Math.sin(n.pulse) * 0.2) + ')';
        ctx.fill();
      }

      animId = requestAnimationFrame(draw);
    }

    // Only animate when hero is visible
    var canvasObserver = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting) {
        if (!animId) animId = requestAnimationFrame(draw);
      } else {
        if (animId) { cancelAnimationFrame(animId); animId = null; }
      }
    }, { threshold: 0.05 });
    canvasObserver.observe(heroSection);

    window.addEventListener('resize', resize, { passive: true });
    resize();
    animId = requestAnimationFrame(draw);
  })();
  // ========== END NEURAL NETWORK CANVAS ==========

})();
</script>

</body>
</html>
