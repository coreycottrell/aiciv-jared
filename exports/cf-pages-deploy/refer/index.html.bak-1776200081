            document.getElementById('pb-ref-dashboard-error').style.display = 'none';
            document.getElementById('pb-ref-dashboard-wrap').style.display = 'none';
            document.getElementById('pb-ref-login-gate').style.display = 'block';
            var el = document.getElementById('pb-login-email');
            if (el) {
                if (code) { el.value = code.toUpperCase(); }
                else if (email) { el.value = email; }
            }
        }

        window.pbLoginSubmit = function() {
            var loginInput = document.getElementById('pb-login-email').value.trim();
            var loginPw    = document.getElementById('pb-login-password').value;
            var errEl      = document.getElementById('pb-login-error');
            var btn        = document.getElementById('pb-login-btn');
            errEl.style.display = 'none';
            if (!loginInput) { errEl.textContent = 'Please enter your email or referral code.'; errEl.style.display='block'; return; }
            if (!loginPw) { errEl.textContent = 'Please enter your password.'; errEl.style.display='block'; return; }
            btn.textContent = 'Logging in...'; btn.disabled = true;
            /* Detect if input is a referral code (PB-XXXX or XXXXXXXX) or an email */
            var isRefCode = /^(PB-)?[A-Za-z0-9]{4,10}$/i.test(loginInput) && loginInput.indexOf('@') === -1;
            var payload = isRefCode
                ? {referral_code: loginInput.toUpperCase(), password: loginPw}
                : {email: loginInput, password: loginPw};
            fetch(apiBase + '/session', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(payload)
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                btn.textContent = 'Login'; btn.disabled = false;
                if (data.error) {
                    if (data.error === 'account not found' && !isRefCode) {
                        errEl.textContent = 'Account not found. Try logging in with your referral code (e.g. PB-XXXX) instead of email.'; 
                    } else if (data.error === 'incorrect password') {
                        errEl.textContent = 'Incorrect password. Please try again.'; 
                    } else {
                        errEl.textContent = data.error || 'Login failed.';
                    }
                    errEl.style.display = 'block'; return;
                }
                setSession(data.session_token);
                if (data.referral_code) setStoredCode(data.referral_code);
                document.getElementById('pb-ref-login-gate').style.display = 'none';
                document.getElementById('pb-ref-dashboard-wrap').style.display = 'block';
                document.getElementById('pb-ref-dashboard-loading').style.display = 'block';
                document.getElementById('pb-ref-dashboard-loading').textContent = 'Loading dashboard...';
                loadDashboard(data.referral_code, '', data.session_token);
            })
            .catch(function() {
                btn.textContent = 'Login'; btn.disabled = false;
                errEl.textContent = 'Network error. Please try again.'; errEl.style.display = 'block';
            });
        };

        // ── Forgot Password ──
        window.pbShowForgotPassword = function() {
            document.getElementById('pb-ref-login-gate').style.display = 'none';
            document.getElementById('pb-ref-forgot-gate').style.display = 'block';
        };
        window.pbBackToLogin = function() {
            document.getElementById('pb-ref-forgot-gate').style.display = 'none';
            document.getElementById('pb-ref-login-gate').style.display = 'block';
        };
        window.pbForgotSubmit = function() {
            var input = document.getElementById('pb-forgot-email').value.trim();
            var errEl = document.getElementById('pb-forgot-error');
            var okEl  = document.getElementById('pb-forgot-success');
            var btn   = document.getElementById('pb-forgot-btn');
            errEl.style.display = 'none'; okEl.style.display = 'none';
            if (!input) { errEl.textContent = 'Please enter your email or referral code.'; errEl.style.display='block'; return; }
            btn.textContent = 'Sending...'; btn.disabled = true;
            var isRefCode = /^(PB-)?[A-Za-z0-9]{4,10}$/i.test(input) && input.indexOf('@') === -1;
            var payload = isRefCode ? {referral_code: input.toUpperCase()} : {email: input};
            fetch(apiBase + '/forgot-password', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(payload)
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                btn.textContent = 'Send Reset Link'; btn.disabled = false;
                if (data.ok) {
                    okEl.textContent = 'If that account exists, a reset link has been sent. Check your inbox.'
                        + (isRefCode ? ' Note: the reset email is sent to the email on file for your account.' : '');
                    okEl.style.display = 'block';
                } else {
                    errEl.textContent = data.error || 'Something went wrong.'; errEl.style.display = 'block';
                }
            })
            .catch(function() {
                btn.textContent = 'Send Reset Link'; btn.disabled = false;
                errEl.textContent = 'Network error. Please try again.'; errEl.style.display = 'block';
            });
        };

        // ── Reset Password (from email link ?reset=TOKEN) ──
        window.pbResetSubmit = function() {
            var pw      = document.getElementById('pb-reset-password').value;
            var pwConf  = document.getElementById('pb-reset-password-confirm').value;
            var errEl   = document.getElementById('pb-reset-error');
            var okEl    = document.getElementById('pb-reset-success');
            var btn     = document.getElementById('pb-reset-btn');
            errEl.style.display = 'none'; okEl.style.display = 'none';
            if (!pw || pw.length < 6) { errEl.textContent = 'Password must be at least 6 characters.'; errEl.style.display='block'; return; }
            if (pw !== pwConf) { errEl.textContent = 'Passwords do not match.'; errEl.style.display='block'; return; }
            var resetToken = new URLSearchParams(window.location.search).get('reset');
            if (!resetToken) { errEl.textContent = 'Invalid reset link.'; errEl.style.display='block'; return; }
            btn.textContent = 'Updating...'; btn.disabled = true;
            fetch(apiBase + '/reset-password', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({token: resetToken, password: pw})
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                btn.textContent = 'Set New Password'; btn.disabled = false;
                if (data.ok) {
                    okEl.textContent = 'Password updated! Redirecting to login...';
                    okEl.style.display = 'block';
                    document.getElementById('pb-ref-reset-gate').style.display = 'none';
                    setTimeout(function() {
                        window.location.href = window.location.pathname;
                    }, 2000);
                } else {
                    errEl.textContent = data.error || 'Reset failed.';
                    errEl.style.display = 'block';
                }
            })
            .catch(function() {
                btn.textContent = 'Set New Password'; btn.disabled = false;
                errEl.textContent = 'Network error. Please try again.'; errEl.style.display = 'block';
            });
        };

        // Check if URL has ?reset=TOKEN — show reset form instead of login
        (function() {
            var resetToken = new URLSearchParams(window.location.search).get('reset');
            if (resetToken) {
                document.getElementById('pb-ref-login-gate').style.display = 'none';
                document.getElementById('pb-ref-forgot-gate').style.display = 'none';
                document.getElementById('pb-ref-reset-gate').style.display = 'block';
                document.getElementById('pb-ref-dashboard-loading').style.display = 'none';
                document.getElementById('pb-ref-dashboard-wrap').style.display = 'none';
            }
        })();

        function loadDashboard(resolvedCode, resolvedEmail, sessionToken) {
            var url = apiBase + '/dashboard?_t=' + Date.now() + '&';
            if (resolvedCode) url += 'code=' + encodeURIComponent(resolvedCode);
            else if (resolvedEmail) url += 'email=' + encodeURIComponent(resolvedEmail);
            if (sessionToken) url += '&session=' + encodeURIComponent(sessionToken);

        fetch(url)
        .then(function(r) {
            if (r.status === 401 || r.status === 403) { clearSession(); clearStoredCode(); showLoginGate(); return null; }
            return r.json();
        })
        .then(function(d) {
            if (!d) return;
            if (d.error) {
                document.getElementById('pb-ref-dashboard-loading').style.display = 'none';
                document.getElementById('pb-ref-dashboard-error').textContent = d.error || 'Could not load dashboard.';
                document.getElementById('pb-ref-dashboard-error').style.display = 'block';
                return;
            }

            // Use total_clicks from API response directly (source of truth).
            // d.history is referral *conversion* history — rows do not carry click_count.
            // Summing history rows always produced 0 even when the DB had clicks recorded.
            var totalClicks = parseInt(d.total_clicks || 0, 10);

            var convRate = d.total_referrals > 0
                ? Math.round((d.completed / d.total_referrals) * 100) : 0;

            _dashCode     = d.referral_code;
            _dashEmail    = d.email || '';
            _dashEarnings = parseFloat(d.earnings) || 0;

            document.getElementById('pb-stat-clicks').textContent     = totalClicks;
            document.getElementById('pb-stat-referrals').textContent  = d.total_referrals;
            document.getElementById('pb-stat-completed').textContent  = d.completed;
            document.getElementById('pb-stat-earnings').textContent   = '$' + _dashEarnings.toFixed(2);
            document.getElementById('pb-stat-pending').textContent    = d.pending;
            document.getElementById('pb-conv-rate').textContent       = convRate + '%';
            document.getElementById('pb-dash-link').textContent       = d.referral_link;
            window._pbDashLink = d.referral_link;

            // Pre-fill PayPal email field if we have a saved one
            if (d.paypal_email) {
                document.getElementById('pb-paypal-email-input').value = d.paypal_email;
                document.getElementById('pb-payout-paypal-email').value = d.paypal_email;
            }

            // Reward tiers
            if (d.reward_tiers) {
                var tiersHtml = '';
                d.reward_tiers.forEach(function(t) {
                    tiersHtml += '<div style="background:#080a12; border:1px solid #1a2540; border-radius:8px; padding:12px 14px;">' +
                        '<div style="font-size:0.78rem; color:#8899aa; margin-bottom:4px;">' + pbEscape(t.label) + '</div>' +
                        '<div style="font-size:1rem; font-weight:600; color:#f1420b;">' + pbEscape(t.reward) + '</div>' +
                        '</div>';
                });
                document.getElementById('pb-reward-tiers').innerHTML = tiersHtml;
            }

            // History rows
            var tbody = document.getElementById('pb-history-tbody');
            if (!d.history || d.history.length === 0) {
                document.getElementById('pb-history-table-wrap').style.display = 'none';
                document.getElementById('pb-history-empty').style.display = 'block';
            } else {
                var rows = '';
                d.history.forEach(function(r) {
                    var statusColor = r.status === 'completed' ? '#1a7a50' : '#8899aa';
                    var statusLabel = r.status === 'completed' ? 'Converted' : 'Pending';
                    var dateStr = r.created_at ? r.created_at.slice(0, 10) : '—';
                    var earningsStr = parseFloat(r.earnings || 0) > 0 ? '$' + parseFloat(r.earnings).toFixed(2) : '—';
                    rows += '<tr style="border-bottom:1px solid #1a2540;">' +
                        '<td style="padding:10px 12px; color:#e0e6f0;">' + pbEscape(r.referred_name || r.referred_email || '—') + '</td>' +
                        '<td style="padding:10px 12px;"><span style="color:' + statusColor + '; font-weight:500;">' + statusLabel + '</span></td>' +
                        '<td style="padding:10px 12px; color:#1a7a50;">' + earningsStr + '</td>' +
                        '<td style="padding:10px 12px; color:#8899aa;">' + pbEscape(dateStr) + '</td>' +
                        '</tr>';
                });
                tbody.innerHTML = rows;
            }

            document.getElementById('pb-ref-dashboard-loading').style.display = 'none';
            document.getElementById('pb-ref-dashboard-content').style.display = 'block';

            // Show payout section based on earnings threshold
            var minPayout = 25;
            if (_dashEarnings >= minPayout) {
                document.getElementById('pb-payout-section').style.display = 'block';
                document.getElementById('pb-payout-available').textContent = '$' + _dashEarnings.toFixed(2);
                document.getElementById('pb-payout-amount').max = _dashEarnings.toFixed(2);
                pbLoadPayoutHistory(_dashCode);
            } else {
                document.getElementById('pb-payout-locked').style.display = 'block';
            }
        })
        .catch(function() {
            document.getElementById('pb-ref-dashboard-loading').style.display = 'none';
            document.getElementById('pb-ref-dashboard-error').textContent = 'Failed to load dashboard. Please try again.';
            document.getElementById('pb-ref-dashboard-error').style.display = 'block';
        });
        } // end loadDashboard()
        window.loadDashboard = loadDashboard;

        // ─── Entry point ───────────────────────────────────────────────────
        // sessionStorage clears on tab close, but if session exists always try to load.
        // Previously: required URL ?code= or ?email= param — so bookmarked /refer/ with
        // no params always showed login gate even if session was still valid.
        // Apr 14 2026: `code` now falls back to localStorage pb_affiliate_code so the
        // user can revisit /refer/ without re-pasting ?code=PB-XXXX every session.
        var sessionTok = getSession();
        if (sessionTok) {
            // Session token is proof of auth — show loading state and load dashboard
            document.getElementById('pb-ref-dashboard-loading').style.display = 'block';
            loadDashboard(code || '', email || '', sessionTok);
        } else if (code || email) {
            // No session but URL has identifying params — show login gate pre-filled
            showLoginGate();
        } else {
            showLoginGate();
        }

        // ─────────────────────────────────────────────────────
        // Save PayPal email (v2.2.0)
        // ─────────────────────────────────────────────────────
        window.pbSavePaypalEmail = function() {
            var paypalEmail = document.getElementById('pb-paypal-email-input').value.trim();
            var msgEl = document.getElementById('pb-paypal-email-msg');
            var btn   = document.getElementById('pb-paypal-email-save-btn');

            msgEl.style.display = 'none';

            if (!paypalEmail || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(paypalEmail)) {
                msgEl.textContent = 'Please enter a valid PayPal email address.';
                msgEl.style.color = '#f1420b';
                msgEl.style.display = 'block';
                return;
            }

            if (!_dashEmail) {
                msgEl.textContent = 'Could not identify your account. Please reload the page.';
                msgEl.style.color = '#f1420b';
                msgEl.style.display = 'block';
                return;
            }

            btn.textContent = 'Saving...';
            btn.disabled = true;

            fetch(apiBase + '/paypal-email', {
                method: 'POST',
                headers: {'Content-Type': 'application/json', 'X-Affiliate-Session': getSession()},
                body: JSON.stringify({ email: _dashEmail, paypal_email: paypalEmail, session_token: getSession() })
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                btn.textContent = 'Save PayPal Email';
                btn.disabled = false;
                if (data.code || data.error) {
                    msgEl.textContent = data.message || data.error || 'Could not save. Please try again.';
                    msgEl.style.color = '#f1420b';
                } else {
                    msgEl.textContent = 'PayPal email saved.';
                    msgEl.style.color = '#1a7a50';
                    // Also pre-fill the payout form
                    document.getElementById('pb-payout-paypal-email').value = paypalEmail;
                }
                msgEl.style.display = 'block';
            })
            .catch(function() {
                btn.textContent = 'Save PayPal Email';
                btn.disabled = false;
                msgEl.textContent = 'Network error. Please try again.';
                msgEl.style.color = '#f1420b';
                msgEl.style.display = 'block';
            });
        };

        // ─────────────────────────────────────────────────────
        // Load payout history
        // ─────────────────────────────────────────────────────
        function pbLoadPayoutHistory(referralCode) {
            var sessQ = getSession() ? '&session=' + encodeURIComponent(getSession()) : '';
            fetch(apiBase + '/payout-history?referral_code=' + encodeURIComponent(referralCode) + sessQ)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                document.getElementById('pb-payout-history-loading').style.display = 'none';
                if (!data.requests || data.requests.length === 0) {
                    document.getElementById('pb-payout-history-empty').style.display = 'block';
                    return;
                }
                var rows = '';
                data.requests.forEach(function(req) {
                    var dateStr = req.created_at ? req.created_at.slice(0, 10) : '—';
                    var statusMap = { pending: '#8899aa', approved: '#2a93c1', paid: '#1a7a50' };
                    var statusColor = statusMap[req.status] || '#8899aa';
                    var statusLabel = req.status ? (req.status.charAt(0).toUpperCase() + req.status.slice(1)) : '—';
                    rows += '<tr style="border-bottom:1px solid #1a2540;">' +
                        '<td style="padding:10px 12px; color:#8899aa;">' + pbEscape(dateStr) + '</td>' +
                        '<td style="padding:10px 12px; color:#1a7a50; font-weight:600;">$' + parseFloat(req.amount || 0).toFixed(2) + '</td>' +
                        '<td style="padding:10px 12px; color:#e0e6f0;">' + pbEscape(req.paypal_email || '—') + '</td>' +
                        '<td style="padding:10px 12px;"><span style="color:' + statusColor + '; font-weight:500;">' + statusLabel + '</span></td>' +
                        '</tr>';
                });
                document.getElementById('pb-payout-history-tbody').innerHTML = rows;
                document.getElementById('pb-payout-history-table-wrap').style.display = 'block';
            })
            .catch(function() {
                document.getElementById('pb-payout-history-loading').style.display = 'none';
                document.getElementById('pb-payout-history-empty').textContent = 'Could not load payout history.';
                document.getElementById('pb-payout-history-empty').style.display = 'block';
            });
        }

        // ─────────────────────────────────────────────────────
        // Submit payout request
        // ─────────────────────────────────────────────────────
        window.pbPayoutSubmit = function() {
            var paypalEmail = document.getElementById('pb-payout-paypal-email').value.trim();
            var amount      = parseFloat(document.getElementById('pb-payout-amount').value);
            var errEl       = document.getElementById('pb-payout-error');
            var btn         = document.getElementById('pb-payout-submit-btn');

            errEl.style.display = 'none';

            if (!paypalEmail || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(paypalEmail)) {
                errEl.textContent = 'Please enter a valid PayPal email address.';
                errEl.style.display = 'block';
                return;
            }
            var minPayout = 25;
            if (isNaN(amount) || amount < minPayout) {
                errEl.textContent = 'Minimum payout amount is $' + minPayout.toFixed(0) + '.';
                errEl.style.display = 'block';
                return;
            }
            if (amount > _dashEarnings) {
                errEl.textContent = 'Amount cannot exceed your available earnings of $' + _dashEarnings.toFixed(2) + '.';
                errEl.style.display = 'block';
                return;
            }

            btn.textContent = 'Submitting...';
            btn.disabled = true;

            fetch(apiBase + '/payout-request', {
                method: 'POST',
                headers: {'Content-Type': 'application/json', 'X-Affiliate-Session': getSession()},
                body: JSON.stringify({referral_code: _dashCode, paypal_email: paypalEmail, amount: amount, session_token: getSession()})
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.code || data.error) {
                    errEl.textContent = data.message || data.error || 'Request failed. Please try again.';
                    errEl.style.display = 'block';
                    btn.textContent = 'Request Payout';
                    btn.disabled = false;
                    return;
                }
                document.getElementById('pb-payout-form').style.display = 'none';
                document.getElementById('pb-payout-success').style.display = 'block';
            })
            .catch(function() {
                errEl.textContent = 'Network error. Please try again.';
                errEl.style.display = 'block';
                btn.textContent = 'Request Payout';
                btn.disabled = false;
            });
        };

        function pbEscape(str) {
            if (!str) return '';
            return String(str)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }
    })();

    window._pbDashLink = '';
    function pbDashCopyLink() {
        if (!window._pbDashLink) return;
        navigator.clipboard.writeText(window._pbDashLink).then(function() {
            var btn = document.getElementById('pb-dash-copy-btn');
            btn.textContent = 'Copied!';
            btn.style.background = '#1a7a50';
            setTimeout(function() {
                btn.textContent = 'Copy Link';
                btn.style.background = '#2a93c1';
            }, 2000);
        });
    }
    </script>
    

</div>
</div>

