                // Append ref param
                var separator = parsed.search ? '&' : '?';
                // Remove any existing ref param first
                var cleanSearch = parsed.search.replace(/[?&]ref=[^&]*/g, '').replace(/^\?$/, '').replace(/^&/, '');
