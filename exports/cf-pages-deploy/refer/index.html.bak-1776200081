                var resultEl = document.getElementById('pb-custom-link-result');
                var linkTextEl = document.getElementById('pb-custom-link-text');
                var rawUrl = input.value.trim();

                errorEl.style.display = 'none';
                resultEl.style.display = 'none';

                if (!rawUrl) return;

                // Extract referral code from the dashboard link
                var dashLink = document.getElementById('pb-dash-link');
                var refCode = '';
                if (dashLink && dashLink.textContent) {
                    var match = dashLink.textContent.match(/[?&]ref=([^&]+)/);
                    if (match) refCode = match[1];
                }
                if (!refCode) return;

                // Validate domain
                var parsed;
                try { parsed = new URL(rawUrl); } catch(e) {
                    errorEl.textContent = 'Please enter a valid URL.';
                    errorEl.style.display = 'block';
                    return;
                }
                var host = parsed.hostname.replace(/^www\./, '');
                if (host !== 'purebrain.ai') {
                    errorEl.textContent = 'Only purebrain.ai URLs are supported.';
                    errorEl.style.display = 'block';
                    return;
