<!-- wp:html -->
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Migration Portal | PureBrain.ai</title>
<meta name="description" content="Bring your AI history to PureBrain. Take the Migration Intelligence Quiz then import your ChatGPT, Claude, or Gemini history.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>

<style>
/* ================================================================
   GLOBAL RESET — WordPress override layer
================================================================ */
html, body {
  background-color: #080a12 !important;
  color: #e0e6f0 !important;
  margin: 0 !important;
  padding: 0 !important;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', Arial, sans-serif !important;
}
body.page { background-color: #080a12 !important; }
body.tt-magic-cursor { background: #080a12 !important; color: #e0e6f0 !important; border-color: transparent !important; }
.site-header, .site-footer, .entry-header, .entry-footer,
.wp-block-post-title, h1.entry-title, .elementor-location-header,
.elementor-location-footer { display: none !important; }

/* ================================================================
   PAGE WRAPPER
================================================================ */
#pb-migrate-page {
  background-color: #080a12;
  min-height: 100vh;
  color: #e0e6f0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
}

/* ================================================================
   QUIZ SECTION — Scoped under #pb-migration-quiz
================================================================ */
#pb-migrate-page .quiz-section {
  padding: 40px 20px 60px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

#pb-migrate-page .quiz-page-header {
  text-align: center;
  margin-bottom: 36px;
  max-width: 600px;
}
#pb-migrate-page .quiz-page-header .nav-logo {
  font-family: 'Oswald', sans-serif;
  font-size: 1.5rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  margin-bottom: 20px;
  display: block;
}
#pb-migrate-page .quiz-page-header .nav-logo .blue { color: #2a93c1; }
#pb-migrate-page .quiz-page-header .nav-logo .orange { color: #f1420b; }
#pb-migrate-page .quiz-page-header h1 {
  font-family: 'Oswald', sans-serif;
  font-size: clamp(1.6rem, 4vw, 2.4rem);
  font-weight: 700;
  letter-spacing: -0.01em;
  line-height: 1.2;
  margin-bottom: 12px;
  color: #fff;
}
#pb-migrate-page .quiz-page-header p {
  color: #8899aa;
  font-size: 1rem;
}

/* Hero hook copy */
#pb-migrate-page .hero-hook {
  margin-bottom: 28px;
  padding: 24px 28px;
  background: rgba(42,147,193,0.07);
  border: 1px solid rgba(42,147,193,0.2);
  border-radius: 16px;
  text-align: left;
}
#pb-migrate-page .hero-hook-line {
  font-size: 1.15rem;
  font-weight: 600;
  color: #c8d8e8;
  margin-bottom: 4px;
  line-height: 1.3;
}
#pb-migrate-page .hero-hook-line.hook-accent {
  font-family: 'Oswald', sans-serif;
  font-size: 1.45rem;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -0.01em;
  margin-bottom: 14px;
}
#pb-migrate-page .hero-hook-sub {
  font-size: 0.92rem;
  color: #8899aa;
  line-height: 1.6;
  margin-bottom: 0;
}

#pb-migration-quiz {
  --pb-blue: #2a93c1;
  --pb-orange: #f1420b;
  --pb-dark: #080a12;
  --pb-dark2: #0d1120;
  --pb-dark3: #111827;
  --pb-border: rgba(42,147,193,0.18);
  --text-primary: #f0f4f8;
  --text-muted: #8899aa;
  --radius: 12px;
  --transition: 0.22s ease;
  width: 100%;
  max-width: 680px;
  background: #0d1120;
  border: 1px solid rgba(42,147,193,0.18);
  border-radius: 20px;
  padding: 48px 44px;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}
#pb-migration-quiz *, #pb-migration-quiz *::before, #pb-migration-quiz *::after {
  box-sizing: border-box;
}
#pb-migration-quiz::before {
  content: '';
  position: absolute;
  top: -80px; right: -80px;
  width: 300px; height: 300px;
  background: radial-gradient(circle, rgba(42,147,193,0.07) 0%, transparent 70%);
  pointer-events: none;
}
#pb-migration-quiz::after {
  content: '';
  position: absolute;
  bottom: -60px; left: -60px;
  width: 240px; height: 240px;
  background: radial-gradient(circle, rgba(241,66,11,0.06) 0%, transparent 70%);
  pointer-events: none;
}

/* Progress */
#pb-migration-quiz .mq-progress-wrap {
  display: flex; align-items: center; gap: 12px; margin-bottom: 36px;
}
#pb-migration-quiz .mq-progress-bar-track {
  flex: 1; height: 4px; background: rgba(255,255,255,0.08); border-radius: 4px; overflow: hidden;
}
#pb-migration-quiz .mq-progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #2a93c1, #f1420b);
  border-radius: 4px; transition: width 0.4s ease; width: 0%;
}
#pb-migration-quiz .mq-progress-label {
  font-size: 0.78rem; color: #8899aa; font-weight: 600; white-space: nowrap;
  letter-spacing: 0.02em; min-width: 80px; text-align: right;
}
#pb-migration-quiz .mq-progress-dots {
  display: flex; gap: 7px; justify-content: center; margin-bottom: 32px;
}
#pb-migration-quiz .mq-dot {
  width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.1);
  transition: background 0.22s ease, transform 0.22s ease;
}
#pb-migration-quiz .mq-dot.active { background: #f1420b; transform: scale(1.35); }
#pb-migration-quiz .mq-dot.done { background: #2a93c1; }

/* Steps */
#pb-migration-quiz .mq-step { display: none; animation: mq-fadein 0.3s ease forwards; }
#pb-migration-quiz .mq-step.active { display: block; }
@keyframes mq-fadein {
  from { opacity: 0; transform: translateX(16px); }
  to   { opacity: 1; transform: translateX(0); }
}

/* Typography */
#pb-migration-quiz .mq-badge {
  display: inline-flex; align-items: center; gap: 6px; font-size: 0.73rem;
  font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;
  color: #f1420b; margin-bottom: 14px;
}
#pb-migration-quiz .mq-badge-dot {
  width: 6px; height: 6px; border-radius: 50%; background: #f1420b;
}
#pb-migration-quiz .mq-question {
  font-size: 1.25rem; font-weight: 700; line-height: 1.35;
  margin-bottom: 8px; color: #f0f4f8;
}
#pb-migration-quiz .mq-subtext {
  font-size: 0.88rem; color: #8899aa; margin-bottom: 28px;
}

/* Single-select options */
#pb-migration-quiz .mq-options { display: flex; flex-direction: column; gap: 10px; }
#pb-migration-quiz .mq-option {
  display: flex; align-items: flex-start; gap: 14px;
  background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.09);
  border-radius: 12px; padding: 16px 18px; cursor: pointer;
  transition: border-color 0.22s ease, background 0.22s ease;
  text-align: left; width: 100%; -webkit-tap-highlight-color: transparent;
}
#pb-migration-quiz .mq-option:hover {
  border-color: #2a93c1; background: rgba(42,147,193,0.07);
}
#pb-migration-quiz .mq-option.selected {
  border-color: #f1420b; background: rgba(241,66,11,0.08);
}
#pb-migration-quiz .mq-option-letter {
  display: flex; align-items: center; justify-content: center;
  width: 28px; height: 28px; min-width: 28px; border-radius: 7px;
  background: rgba(255,255,255,0.06); font-size: 0.8rem; font-weight: 700;
  color: #8899aa; transition: background 0.22s ease, color 0.22s ease; flex-shrink: 0; margin-top: 1px;
}
#pb-migration-quiz .mq-option:hover .mq-option-letter { background: rgba(42,147,193,0.18); color: #2a93c1; }
#pb-migration-quiz .mq-option.selected .mq-option-letter { background: rgba(241,66,11,0.2); color: #f1420b; }
#pb-migration-quiz .mq-option-text {
  font-size: 0.95rem; line-height: 1.45; padding-top: 4px; color: #f0f4f8;
}
#pb-migration-quiz .mq-option-subtext {
  display: block; font-size: 0.8rem; color: #8899aa; margin-top: 3px; line-height: 1.4;
}

/* Multi-select chips */
#pb-migration-quiz .mq-chips { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 4px; }
#pb-migration-quiz .mq-chip {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1);
  border-radius: 100px; padding: 9px 18px; cursor: pointer; font-size: 0.88rem;
  font-weight: 500; color: #f0f4f8;
  transition: border-color 0.22s ease, background 0.22s ease, color 0.22s ease;
  -webkit-tap-highlight-color: transparent; user-select: none;
}
#pb-migration-quiz .mq-chip:hover { border-color: #2a93c1; background: rgba(42,147,193,0.07); color: #2a93c1; }
#pb-migration-quiz .mq-chip.selected { border-color: #f1420b; background: rgba(241,66,11,0.1); color: #f1420b; }
#pb-migration-quiz .mq-chip-icon { font-size: 0.82rem; line-height: 1; }
#pb-migration-quiz .mq-chip-check {
  display: none; width: 14px; height: 14px; background: #f1420b;
  border-radius: 50%; align-items: center; justify-content: center;
  font-size: 0.6rem; color: #fff; font-weight: 700;
}
#pb-migration-quiz .mq-chip.selected .mq-chip-check { display: flex; }
#pb-migration-quiz .mq-chip-hint { font-size: 0.8rem; color: #8899aa; margin-top: 12px; }

/* Navigation */
#pb-migration-quiz .mq-nav {
  display: flex; align-items: center; justify-content: space-between; margin-top: 32px;
}
#pb-migration-quiz .mq-back {
  background: transparent; border: 1px solid rgba(255,255,255,0.12); color: #8899aa;
  padding: 11px 22px; border-radius: 8px; font-size: 0.9rem; font-weight: 600;
  cursor: pointer; transition: border-color 0.22s ease, color 0.22s ease;
}
#pb-migration-quiz .mq-back:hover { border-color: #2a93c1; color: #2a93c1; }
#pb-migration-quiz .mq-back[hidden] { visibility: hidden; }
#pb-migration-quiz .mq-next {
  background: #f1420b; color: #fff; border: none; padding: 13px 32px;
  border-radius: 8px; font-size: 0.97rem; font-weight: 700; cursor: pointer;
  transition: background 0.22s ease, opacity 0.22s ease; opacity: 0.4; pointer-events: none;
}
#pb-migration-quiz .mq-next.ready { opacity: 1; pointer-events: auto; }
#pb-migration-quiz .mq-next.ready:hover { background: #2a93c1; }

/* Email Gate */
#pb-migration-quiz .mq-gate-box {
  background: rgba(42,147,193,0.06); border: 1px solid rgba(42,147,193,0.18);
  border-radius: 16px; padding: 40px 36px; text-align: center;
}
#pb-migration-quiz .mq-gate-icon { font-size: 2.6rem; margin-bottom: 16px; display: block; }
#pb-migration-quiz .mq-gate-box h3 {
  font-size: 1.5rem; font-weight: 700; margin-bottom: 10px; line-height: 1.25; color: #f0f4f8;
}
#pb-migration-quiz .mq-gate-box h3 .orange { color: #f1420b; }
#pb-migration-quiz .mq-gate-box p {
  color: #8899aa; font-size: 0.95rem; margin-bottom: 28px;
  max-width: 420px; margin-left: auto; margin-right: auto;
}
#pb-migration-quiz .mq-gate-summary {
  display: flex; justify-content: center; gap: 24px; flex-wrap: wrap; margin-bottom: 32px;
}
#pb-migration-quiz .mq-summary-pill {
  display: flex; align-items: center; gap: 6px;
  background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
  border-radius: 100px; padding: 6px 14px; font-size: 0.8rem; color: #8899aa;
}
#pb-migration-quiz .mq-summary-pill .pill-dot {
  width: 6px; height: 6px; border-radius: 50%; background: #2a93c1; flex-shrink: 0;
}
#pb-migration-quiz .mq-gate-form {
  display: flex; flex-direction: column; gap: 12px; max-width: 400px; margin: 0 auto;
}
#pb-migration-quiz .mq-gate-form input {
  background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.12);
  border-radius: 8px; padding: 14px 18px; color: #f0f4f8; font-size: 1rem;
  outline: none; transition: border-color 0.22s ease; width: 100%;
}
#pb-migration-quiz .mq-gate-form input:focus { border-color: #2a93c1; }
#pb-migration-quiz .mq-gate-form input::placeholder { color: #8899aa; }
#pb-migration-quiz .mq-btn-submit {
  background: #f1420b; color: #fff; border: none; padding: 15px;
  border-radius: 8px; font-size: 1rem; font-weight: 700; cursor: pointer;
  transition: background 0.22s ease; position: relative; letter-spacing: 0.01em;
  font-family: inherit;
}
#pb-migration-quiz .mq-btn-submit:hover:not(:disabled) { background: #2a93c1; }
#pb-migration-quiz .mq-btn-submit:disabled { opacity: 0.65; cursor: not-allowed; }
#pb-migration-quiz .mq-btn-submit .mq-spinner {
  display: none; width: 18px; height: 18px;
  border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff;
  border-radius: 50%; animation: mq-spin 0.7s linear infinite;
  position: absolute; right: 18px; top: 50%; transform: translateY(-50%);
}
#pb-migration-quiz .mq-btn-submit.loading .mq-spinner { display: block; }
@keyframes mq-spin { to { transform: translateY(-50%) rotate(360deg); } }
#pb-migration-quiz .mq-gate-privacy {
  font-size: 0.75rem; color: #8899aa; margin-top: 8px; line-height: 1.5;
}
#pb-migration-quiz .mq-gate-error {
  color: #f1420b; font-size: 0.84rem; text-align: center; display: none; margin-top: 8px;
}
#pb-migration-quiz .mq-gate-error.visible { display: block; }

/* Success Screen */
#pb-migration-quiz .mq-success {
  text-align: center; padding: 20px 0; animation: mq-fadein 0.4s ease forwards;
}
#pb-migration-quiz .mq-success-icon {
  width: 72px; height: 72px;
  background: linear-gradient(135deg, rgba(42,147,193,0.2), rgba(241,66,11,0.15));
  border: 1px solid rgba(42,147,193,0.3); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 2rem; margin: 0 auto 24px;
}
#pb-migration-quiz .mq-success h3 {
  font-size: 1.6rem; font-weight: 700; margin-bottom: 12px;
  letter-spacing: -0.02em; line-height: 1.2; color: #f0f4f8;
}
#pb-migration-quiz .mq-success h3 .orange { color: #f1420b; }
#pb-migration-quiz .mq-success p {
  color: #8899aa; font-size: 0.97rem; max-width: 440px;
  margin: 0 auto 32px; line-height: 1.6;
}
#pb-migration-quiz .mq-success-cta {
  background: #f1420b; color: #fff; padding: 14px 36px; border-radius: 10px;
  text-decoration: none; font-weight: 700; font-size: 1rem; display: inline-block;
  transition: background 0.22s ease, transform 0.1s;
}
#pb-migration-quiz .mq-success-cta:hover { background: #2a93c1; transform: translateY(-1px); }

/* Migration label badge */
#pb-migration-quiz .mq-migration-label {
  display: inline-flex; align-items: center; gap: 8px; font-size: 0.72rem;
  font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #2a93c1;
  background: rgba(42,147,193,0.1); border: 1px solid rgba(42,147,193,0.2);
  border-radius: 100px; padding: 5px 14px; margin-bottom: 28px;
}

/* ================================================================
   SECTION DIVIDER — Between quiz and portal
================================================================ */
#pb-migrate-page .migrate-divider {
  display: flex; align-items: center; gap: 20px;
  max-width: 680px; margin: 0 auto; padding: 0 20px 20px;
}
#pb-migrate-page .migrate-divider-line {
  flex: 1; height: 1px; background: rgba(42,147,193,0.18);
}
#pb-migrate-page .migrate-divider-label {
  font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase; color: #5a6a82; white-space: nowrap;
}

/* ================================================================
   PORTAL SECTION — Scoped under #pb-migration-portal
================================================================ */
#pb-migration-portal {
  --blue:         #2a93c1;
  --blue-light:   #3eb0e0;
  --blue-dim:     #1a5a7a;
  --blue-glow:    rgba(42, 147, 193, 0.15);
  --orange:       #f1420b;
  --orange-dim:   #a02d07;
  --orange-glow:  rgba(241, 66, 11, 0.15);
  --bg-page:      #080a12;
  --bg-card:      #0e1120;
  --bg-card-alt:  #111628;
  --bg-input:     #0a0d1a;
  --border:       rgba(42, 147, 193, 0.18);
  --border-mid:   rgba(42, 147, 193, 0.35);
  --text-primary: #e0e6f0;
  --text-secondary: #94a3b8;
  --text-muted:   #5a6a82;
  --white:        #ffffff;
  --green:        #22c55e;
  --green-dim:    rgba(34, 197, 94, 0.15);
  --radius-sm:    8px;
  --radius-md:    12px;
  --radius-lg:    20px;

  background-color: var(--bg-page);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
  line-height: 1.65;
}

#pb-migration-portal *, #pb-migration-portal *::before, #pb-migration-portal *::after {
  box-sizing: border-box;
}

#pb-migration-portal .portal-wrap {
  max-width: 760px; margin: 0 auto; padding: 20px 20px 80px;
}

/* Portal logo */
#pb-migration-portal .portal-logo {
  display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 32px;
}
#pb-migration-portal .portal-logo .logo-hex { width: 38px; height: 38px; }
#pb-migration-portal .portal-logo .logo-text {
  font-family: 'Oswald', sans-serif; font-weight: 700; font-size: 22px;
  letter-spacing: 0.04em; color: #fff;
}
#pb-migration-portal .portal-logo .logo-text span.blue { color: var(--blue); }
#pb-migration-portal .portal-logo .logo-text span.orange { color: var(--orange); }

/* Step header */
#pb-migration-portal .step-header { text-align: center; margin-bottom: 32px; }
#pb-migration-portal .step-label {
  font-size: 12px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--blue); margin-bottom: 8px;
}
#pb-migration-portal .step-title {
  font-family: 'Oswald', sans-serif; font-weight: 700;
  font-size: clamp(26px, 5vw, 38px); color: var(--white); line-height: 1.15; margin-bottom: 10px;
}
#pb-migration-portal .step-subtitle {
  font-size: 16px; color: var(--text-secondary); max-width: 520px; margin: 0 auto;
}

/* Progress dots */
#pb-migration-portal .progress-dots {
  display: flex; align-items: center; justify-content: center; gap: 0; margin-bottom: 36px;
}
#pb-migration-portal .progress-dots .dot {
  width: 34px; height: 34px; border-radius: 50%; border: 2px solid var(--border-mid);
  background: var(--bg-card); display: flex; align-items: center; justify-content: center;
  font-size: 13px; font-weight: 600; color: var(--text-muted); position: relative; z-index: 1;
  transition: all 0.3s ease; flex-shrink: 0;
}
#pb-migration-portal .progress-dots .dot.active {
  border-color: var(--blue); background: var(--blue); color: var(--white);
  box-shadow: 0 0 16px rgba(42,147,193,0.45);
}
#pb-migration-portal .progress-dots .dot.done {
  border-color: var(--green); background: var(--green); color: var(--white);
}
#pb-migration-portal .progress-dots .dot.done::after { content: '✓'; font-size: 14px; }
#pb-migration-portal .progress-dots .dot.done .dot-num { display: none; }
#pb-migration-portal .progress-dots .dot-line {
  flex: 1; height: 2px; background: var(--border); max-width: 80px; transition: background 0.3s ease;
}
#pb-migration-portal .progress-dots .dot-line.done { background: var(--green); }

/* Cards */
#pb-migration-portal .card {
  background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg);
  overflow: hidden; margin-bottom: 16px; transition: border-color 0.3s ease;
}
#pb-migration-portal .card:hover { border-color: rgba(42,147,193,0.35); }
#pb-migration-portal .card.success { border-color: rgba(34,197,94,0.4); }
#pb-migration-portal .card-inner { padding: 24px 28px; }
#pb-migration-portal .card-row { display: flex; align-items: flex-start; gap: 16px; }

#pb-migration-portal .section-label {
  font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--text-muted); margin-bottom: 12px; padding-left: 2px;
}

/* Upload zone */
#pb-migration-portal .upload-zone {
  border: 2px dashed rgba(42,147,193,0.35); border-radius: var(--radius-md);
  padding: 36px 24px; text-align: center; cursor: pointer;
  transition: all 0.25s ease; background: var(--bg-input); position: relative;
}
#pb-migration-portal .upload-zone:hover,
#pb-migration-portal .upload-zone.drag-over { border-color: var(--blue); background: rgba(42,147,193,0.07); }
#pb-migration-portal .upload-zone.success { border-color: var(--green); border-style: solid; background: var(--green-dim); }
#pb-migration-portal .upload-zone input[type="file"] {
  position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;
}
#pb-migration-portal .upload-icon { font-size: 36px; margin-bottom: 12px; line-height: 1; }
#pb-migration-portal .upload-title { font-size: 15px; font-weight: 600; color: var(--text-primary); margin-bottom: 4px; }
#pb-migration-portal .upload-hint { font-size: 13px; color: var(--text-muted); }
#pb-migration-portal .upload-success-msg {
  display: none; align-items: center; justify-content: center; gap: 8px;
  font-size: 15px; font-weight: 600; color: var(--green);
}
#pb-migration-portal .upload-zone.success .upload-success-msg { display: flex; }
#pb-migration-portal .upload-zone.success .upload-default { display: none; }

/* Accordion */
#pb-migration-portal .accordion { margin-top: 12px; }
#pb-migration-portal .accordion-toggle {
  display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--blue);
  cursor: pointer; background: none; border: none; padding: 0; font-family: inherit; transition: color 0.2s;
}
#pb-migration-portal .accordion-toggle:hover { color: var(--blue-light); }
#pb-migration-portal .accordion-toggle .acc-arrow { font-size: 10px; transition: transform 0.25s; }
#pb-migration-portal .accordion-toggle.open .acc-arrow { transform: rotate(180deg); }
#pb-migration-portal .accordion-body {
  display: none; margin-top: 12px; background: var(--bg-input); border: 1px solid var(--border);
  border-radius: var(--radius-sm); padding: 16px 18px;
}
#pb-migration-portal .accordion-body.open { display: block; }
#pb-migration-portal .accordion-body ol { margin: 0; padding-left: 20px; }
#pb-migration-portal .accordion-body li {
  font-size: 13px; color: var(--text-secondary); margin-bottom: 6px; line-height: 1.5;
}
#pb-migration-portal .accordion-body li:last-child { margin-bottom: 0; }

/* Source icons */
#pb-migration-portal .source-icon {
  width: 44px; height: 44px; border-radius: var(--radius-sm); background: var(--bg-card-alt);
  border: 1px solid var(--border); display: flex; align-items: center; justify-content: center;
  font-size: 22px; flex-shrink: 0;
}
#pb-migration-portal .source-name { font-size: 15px; font-weight: 600; color: var(--text-primary); margin-bottom: 2px; }
#pb-migration-portal .source-what { font-size: 13px; color: var(--text-muted); }

/* Inputs */
#pb-migration-portal textarea,
#pb-migration-portal input[type="text"] {
  width: 100%; background: var(--bg-input); border: 1px solid var(--border);
  border-radius: var(--radius-sm); color: var(--text-primary); font-family: inherit;
  font-size: 14px; padding: 12px 16px; resize: vertical; outline: none; transition: border-color 0.2s;
}
#pb-migration-portal textarea:focus,
#pb-migration-portal input[type="text"]:focus {
  border-color: var(--blue); box-shadow: 0 0 0 3px rgba(42,147,193,0.12);
}
#pb-migration-portal textarea::placeholder,
#pb-migration-portal input[type="text"]::placeholder { color: var(--text-muted); }
#pb-migration-portal .input-label {
  display: block; font-size: 13px; font-weight: 600; color: var(--text-secondary); margin-bottom: 8px;
}

/* Buttons */
#pb-migration-portal .btn {
  display: inline-flex; align-items: center; gap: 8px; padding: 13px 28px;
  border-radius: var(--radius-sm); font-family: inherit; font-size: 15px; font-weight: 600;
  cursor: pointer; border: none; outline: none; transition: all 0.2s ease; text-decoration: none; line-height: 1;
}
#pb-migration-portal .btn-primary { background: var(--orange); color: var(--white) !important; }
#pb-migration-portal .btn-primary:hover {
  background: var(--blue); color: var(--white) !important;
  transform: translateY(-1px); box-shadow: 0 4px 20px rgba(42,147,193,0.3);
}
#pb-migration-portal .btn-secondary {
  background: transparent; color: var(--text-secondary) !important; border: 1px solid var(--border);
}
#pb-migration-portal .btn-secondary:hover { border-color: var(--border-mid); color: var(--text-primary) !important; }
#pb-migration-portal .btn-remove {
  background: transparent; color: var(--orange); border: 1px solid rgba(241,66,11,0.3);
  padding: 5px 12px; font-size: 12px; border-radius: 6px; cursor: pointer;
  font-family: inherit; font-weight: 600; transition: all 0.2s;
}
#pb-migration-portal .btn-remove:hover { background: rgba(241,66,11,0.1); }
#pb-migration-portal .btn-restore {
  background: transparent; color: var(--text-muted); border: 1px solid var(--border);
  padding: 5px 12px; font-size: 12px; border-radius: 6px; cursor: pointer;
  font-family: inherit; font-weight: 600; transition: all 0.2s;
}
#pb-migration-portal .btn-restore:hover { color: var(--blue); border-color: var(--border-mid); }
#pb-migration-portal .cta-row {
  display: flex; align-items: center; gap: 16px; flex-wrap: wrap; margin-top: 28px;
}

/* Data review */
#pb-migration-portal .data-category {
  display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;
  padding: 14px 0; border-bottom: 1px solid var(--border); transition: opacity 0.25s;
}
#pb-migration-portal .data-category:last-child { border-bottom: none; }
#pb-migration-portal .data-category.removed { opacity: 0.35; }
#pb-migration-portal .data-category-left { display: flex; align-items: flex-start; gap: 12px; }
#pb-migration-portal .data-check {
  width: 22px; height: 22px; border-radius: 50%; background: var(--green-dim);
  border: 1px solid var(--green); display: flex; align-items: center; justify-content: center;
  font-size: 12px; color: var(--green); flex-shrink: 0; margin-top: 2px;
}
#pb-migration-portal .data-category.removed .data-check {
  background: rgba(90,106,130,0.1); border-color: var(--border); color: var(--text-muted);
}
#pb-migration-portal .data-cat-title { font-size: 14px; font-weight: 600; color: var(--text-primary); margin-bottom: 2px; }
#pb-migration-portal .data-cat-detail { font-size: 13px; color: var(--text-muted); font-style: italic; }
#pb-migration-portal .data-cat-preview {
  font-size: 12px; color: var(--text-secondary); background: var(--bg-input);
  border-left: 2px solid var(--border-mid); padding: 4px 8px; margin-top: 4px;
  border-radius: 0 4px 4px 0;
}

/* Privacy note */
#pb-migration-portal .privacy-note {
  display: flex; align-items: flex-start; gap: 12px;
  background: rgba(42,147,193,0.06); border: 1px solid rgba(42,147,193,0.2);
  border-radius: var(--radius-sm); padding: 14px 16px; margin-bottom: 20px;
}
#pb-migration-portal .privacy-icon { font-size: 18px; flex-shrink: 0; }
#pb-migration-portal .privacy-text { font-size: 13px; color: var(--text-secondary); }
#pb-migration-portal .privacy-text strong { color: var(--text-primary); }
#pb-migration-portal .privacy-link {
  color: var(--blue); text-decoration: none; font-size: 12px; display: inline-block; margin-top: 2px;
}
#pb-migration-portal .privacy-link:hover { text-decoration: underline; }

/* Processing orb */
#pb-migration-portal .orb-container { display: flex; justify-content: center; margin-bottom: 28px; }
#pb-migration-portal .pb-orb {
  width: 120px; height: 120px; border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, #3eb0e0 0%, #2a93c1 40%, #1a5a7a 70%, #0a1a2e 100%);
  box-shadow: 0 0 40px rgba(42,147,193,0.4), 0 0 80px rgba(241,66,11,0.12), inset 0 0 30px rgba(62,176,224,0.3);
  position: relative; animation: orbPulse 2.5s ease-in-out infinite;
}
#pb-migration-portal .pb-orb::before {
  content: ''; position: absolute; top: 12%; left: 18%; width: 30%; height: 20%;
  background: rgba(255,255,255,0.35); border-radius: 50%; filter: blur(6px); transform: rotate(-20deg);
}
#pb-migration-portal .pb-orb::after {
  content: ''; position: absolute; inset: -6px; border-radius: 50%;
  border: 2px solid rgba(42,147,193,0.25); animation: orbRing 2.5s ease-in-out infinite;
}
@keyframes orbPulse {
  0%, 100% { box-shadow: 0 0 40px rgba(42,147,193,0.4), 0 0 80px rgba(241,66,11,0.1), inset 0 0 30px rgba(62,176,224,0.3); transform: scale(1); }
  50% { box-shadow: 0 0 60px rgba(42,147,193,0.6), 0 0 100px rgba(241,66,11,0.2), inset 0 0 40px rgba(62,176,224,0.45); transform: scale(1.04); }
}
@keyframes orbRing {
  0%, 100% { opacity: 0.4; transform: scale(1); }
  50% { opacity: 0.9; transform: scale(1.08); }
}

#pb-migration-portal .progress-bar-wrap { margin-bottom: 28px; text-align: center; }
#pb-migration-portal .progress-bar-label { font-size: 14px; color: var(--text-secondary); margin-bottom: 10px; }
#pb-migration-portal .progress-bar-track {
  height: 8px; background: var(--bg-card-alt); border-radius: 99px; overflow: hidden; border: 1px solid var(--border);
}
#pb-migration-portal .progress-bar-fill {
  height: 100%; background: linear-gradient(90deg, var(--blue) 0%, var(--blue-light) 100%);
  border-radius: 99px; width: 0%; transition: width 0.4s ease; position: relative;
}
#pb-migration-portal .progress-bar-fill::after {
  content: ''; position: absolute; right: 0; top: 0; height: 100%; width: 40px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3));
  animation: shimmer 1s linear infinite;
}
@keyframes shimmer { 0% { opacity: 0; } 50% { opacity: 1; } 100% { opacity: 0; } }

/* Insight cards */
#pb-migration-portal .insights-section { margin-bottom: 28px; }
#pb-migration-portal .insight-card {
  background: var(--bg-card-alt); border: 1px solid var(--border);
  border-left: 3px solid var(--blue); border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  padding: 14px 16px; margin-bottom: 10px; font-size: 14px; color: var(--text-secondary);
  opacity: 0; transform: translateX(-12px); transition: all 0.4s ease;
}
#pb-migration-portal .insight-card.visible { opacity: 1; transform: translateX(0); }
#pb-migration-portal .insight-card .insight-text strong { color: var(--blue-light); }

/* Checklist */
#pb-migration-portal .checklist {
  background: var(--bg-card-alt); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 20px 22px;
}
#pb-migration-portal .checklist-title {
  font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--text-muted); margin-bottom: 14px;
}
#pb-migration-portal .check-item {
  display: flex; align-items: center; gap: 10px; font-size: 14px; color: var(--text-secondary); padding: 5px 0;
}
#pb-migration-portal .check-item .check-dot {
  width: 20px; height: 20px; border-radius: 50%; border: 2px solid var(--border-mid);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; font-size: 11px; color: transparent; transition: all 0.3s;
}
#pb-migration-portal .check-item.done .check-dot { background: var(--green); border-color: var(--green); color: var(--white); }
#pb-migration-portal .check-item.done .check-dot::before { content: '✓'; }
#pb-migration-portal .check-item.in-progress .check-dot {
  border-color: var(--blue); animation: spinDot 1.2s linear infinite;
}
@keyframes spinDot {
  from { border-top-color: var(--blue); border-right-color: transparent; }
  to { border-top-color: var(--blue); border-right-color: transparent; transform: rotate(360deg); }
}
#pb-migration-portal .check-item.done { color: var(--text-primary); }

/* Task cards */
#pb-migration-portal .task-cards-grid { display: flex; flex-direction: column; gap: 14px; margin-bottom: 28px; }
#pb-migration-portal .task-card {
  background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg);
  padding: 24px 26px; display: flex; align-items: flex-start; gap: 18px; transition: all 0.25s ease;
}
#pb-migration-portal .task-card:hover {
  border-color: rgba(42,147,193,0.4); transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,0.3);
}
#pb-migration-portal .task-icon-wrap {
  width: 50px; height: 50px; border-radius: var(--radius-sm); background: var(--blue-glow);
  border: 1px solid var(--border-mid); display: flex; align-items: center; justify-content: center;
  font-size: 24px; flex-shrink: 0;
}
#pb-migration-portal .task-content { flex: 1; }
#pb-migration-portal .task-title {
  font-family: 'Oswald', sans-serif; font-weight: 600; font-size: 18px; color: var(--white); margin-bottom: 6px;
}
#pb-migration-portal .task-desc { font-size: 14px; color: var(--text-secondary); margin-bottom: 14px; line-height: 1.55; }
#pb-migration-portal .task-btn {
  display: inline-flex; align-items: center; gap: 6px; padding: 9px 18px;
  border-radius: var(--radius-sm); background: var(--orange); color: var(--white) !important;
  font-size: 13px; font-weight: 600; font-family: inherit; text-decoration: none;
  transition: all 0.2s; cursor: pointer; border: none;
}
#pb-migration-portal .task-btn:hover { background: var(--blue); transform: translateY(-1px); }

/* Complete badge */
#pb-migration-portal .complete-badge {
  display: flex; align-items: center; gap: 14px;
  background: rgba(34,197,94,0.08); border: 1px solid rgba(34,197,94,0.3);
  border-radius: var(--radius-md); padding: 18px 22px; margin-bottom: 28px;
}
#pb-migration-portal .complete-badge .badge-icon {
  width: 44px; height: 44px; background: rgba(34,197,94,0.15);
  border: 1px solid rgba(34,197,94,0.4); border-radius: 50%;
  display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0;
}
#pb-migration-portal .badge-title {
  font-family: 'Oswald', sans-serif; font-weight: 700; font-size: 18px; color: var(--green); margin-bottom: 2px;
}
#pb-migration-portal .badge-detail { font-size: 13px; color: var(--text-secondary); }

/* Step panels */
#pb-migration-portal .step-panel { display: none; }
#pb-migration-portal .step-panel.active { display: block; }

/* Demo + no-data notes */
#pb-migration-portal .demo-note {
  background: rgba(42,147,193,0.07); border: 1px solid rgba(42,147,193,0.2);
  border-radius: var(--radius-sm); padding: 12px 16px; font-size: 13px;
  color: var(--text-secondary); margin-bottom: 20px; text-align: center;
}

/* ================================================================
   SOFT GATE — Step 2 portal section locked until quiz complete
================================================================ */
#pb-migrate-page .migrate-divider { position: relative; }

#pb-migration-portal.step2-locked {
  position: relative;
}
#pb-migration-portal.step2-locked::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, transparent 0%, rgba(8,10,18,0.5) 40%, rgba(8,10,18,0.85) 100%);
  pointer-events: none;
  border-radius: 0;
  z-index: 2;
  transition: opacity 0.6s ease;
}
#pb-migration-portal.step2-locked .portal-wrap {
  opacity: 0.45;
  filter: blur(1.5px);
  transition: opacity 0.5s ease, filter 0.5s ease;
  pointer-events: none;
  user-select: none;
}
#pb-migration-portal.step2-unlocked .portal-wrap {
  opacity: 1;
  filter: none;
  pointer-events: auto;
  user-select: auto;
  transition: opacity 0.5s ease, filter 0.5s ease;
}
#pb-migration-portal.step2-unlocked::after {
  display: none;
}

/* Unlock nudge badge */
#pb-step2-unlock-nudge {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  background: rgba(42,147,193,0.1);
  border: 1px solid rgba(42,147,193,0.3);
  border-radius: 12px;
  padding: 14px 22px;
  margin: 0 auto 20px;
  max-width: 480px;
  font-size: 0.88rem;
  color: #8899aa;
  transition: opacity 0.4s ease;
  position: relative;
  z-index: 10;
}
#pb-step2-unlock-nudge .nudge-icon { font-size: 1.1rem; flex-shrink: 0; }
#pb-step2-unlock-nudge .nudge-text { line-height: 1.45; }
#pb-step2-unlock-nudge .nudge-text strong { color: #2a93c1; }
#pb-step2-unlock-nudge.hidden { display: none; }

/* Unlock pulse animation on the "Import My AI History" button */
@keyframes pb-unlock-pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(241,66,11,0.4); }
  50% { box-shadow: 0 0 0 10px rgba(241,66,11,0); }
}
.mq-success-cta.pulse-unlock {
  animation: pb-unlock-pulse 1.8s ease-in-out 3;
}

/* Responsive */
@media (max-width: 600px) {
  #pb-migration-quiz { padding: 32px 22px; border-radius: 16px; }
  #pb-migration-quiz .mq-question { font-size: 1.1rem; }
  #pb-migration-quiz .mq-gate-box { padding: 28px 20px; }
  #pb-migration-quiz .mq-gate-summary { gap: 10px; }
  #pb-migration-portal .portal-wrap { padding: 16px 16px 60px; }
  #pb-migration-portal .card-inner { padding: 18px 16px; }
  #pb-migration-portal .task-card { flex-direction: column; padding: 18px; gap: 12px; }
  #pb-migration-portal .cta-row { flex-direction: column; }
  #pb-migration-portal .btn { width: 100%; justify-content: center; }
}
</style>
</head>
<body>

<div id="pb-migrate-page">

  <!-- ================================================================
       SECTION 1: MIGRATION INTELLIGENCE QUIZ (Entry Point)
  ================================================================ -->
  <div class="quiz-section">

    <header class="quiz-page-header">
      <span class="nav-logo">
        <img src="https://purebrain.ai/wp-content/uploads/2026/02/purebrain-icon-1.png" alt="PureBrain" width="24" height="24" style="vertical-align:middle;margin-right:8px;display:inline-block;"><span class="blue">PUREBR</span><span class="orange">AI</span><span class="blue">N</span>
      </span>
      <div class="hero-hook">
        <p class="hero-hook-line">You've spent months teaching your AI how you think.</p>
        <p class="hero-hook-line hook-accent">Don't start over.</p>
        <p class="hero-hook-sub">Your conversations are years of training data. PureBrain learns from them — so it already knows your style, your priorities, and how you work from day one.</p>
      </div>
      <h1>Bring Your AI History Here</h1>
      <p>Answer 4 quick questions — we'll personalize your migration and keep your years of AI work intact.</p>
    </header>

    <div id="pb-migration-quiz" role="main" aria-label="Migration Intelligence Quiz">

      <!-- Progress -->
      <div class="mq-progress-wrap">
        <div class="mq-progress-bar-track">
          <div class="mq-progress-bar-fill" id="mqProgressFill"></div>
        </div>
        <div class="mq-progress-label" id="mqProgressLabel">Question 1 of 4</div>
      </div>
      <div class="mq-progress-dots" id="mqDots" aria-hidden="true">
        <span class="mq-dot active" data-dot="0"></span>
        <span class="mq-dot" data-dot="1"></span>
        <span class="mq-dot" data-dot="2"></span>
        <span class="mq-dot" data-dot="3"></span>
        <span class="mq-dot" data-dot="4"></span>
      </div>

      <!-- STEP 0: Primary Use Cases (Multi-select) -->
      <div class="mq-step active" id="mqStep0">
        <div class="mq-migration-label"><span>&#9670;</span> Migration Intelligence</div>
        <div class="mq-badge"><span class="mq-badge-dot"></span>Question 1 of 4</div>
        <div class="mq-question">What did you use <span id="mqCompetitorName">your AI tool</span> for most?</div>
        <div class="mq-subtext">Select all that apply — we'll use this to personalize your first week with PureBrain.</div>

        <div class="mq-chips" id="mqChipsA" role="group" aria-label="Primary use cases">
          <button class="mq-chip" data-val="writing" type="button" role="checkbox" aria-checked="false">
            <span class="mq-chip-icon">&#9998;</span>Writing and editing<span class="mq-chip-check">&#10003;</span>
          </button>
          <button class="mq-chip" data-val="research" type="button" role="checkbox" aria-checked="false">
            <span class="mq-chip-icon">&#128269;</span>Research and summarization<span class="mq-chip-check">&#10003;</span>
          </button>
          <button class="mq-chip" data-val="coding" type="button" role="checkbox" aria-checked="false">
            <span class="mq-chip-icon">&#128187;</span>Coding and technical help<span class="mq-chip-check">&#10003;</span>
          </button>
          <button class="mq-chip" data-val="image_gen" type="button" role="checkbox" aria-checked="false">
            <span class="mq-chip-icon">&#127760;</span>Image generation<span class="mq-chip-check">&#10003;</span>
          </button>
          <button class="mq-chip" data-val="brainstorming" type="button" role="checkbox" aria-checked="false">
            <span class="mq-chip-icon">&#128161;</span>Brainstorming and ideation<span class="mq-chip-check">&#10003;</span>
          </button>
          <button class="mq-chip" data-val="customer_content" type="button" role="checkbox" aria-checked="false">
            <span class="mq-chip-icon">&#128227;</span>Customer-facing content<span class="mq-chip-check">&#10003;</span>
          </button>
          <button class="mq-chip" data-val="productivity" type="button" role="checkbox" aria-checked="false">
            <span class="mq-chip-icon">&#9989;</span>Personal productivity<span class="mq-chip-check">&#10003;</span>
          </button>
          <button class="mq-chip" data-val="data_analysis" type="button" role="checkbox" aria-checked="false">
            <span class="mq-chip-icon">&#128202;</span>Data analysis<span class="mq-chip-check">&#10003;</span>
          </button>
        </div>
        <div class="mq-chip-hint" id="mqChipHintA">Select at least one to continue</div>

        <div class="mq-nav">
          <button class="mq-back" hidden aria-hidden="true">&#8592; Back</button>
          <button class="mq-next" id="mqNextA" type="button">Continue &#8594;</button>
        </div>
      </div>

      <!-- STEP 1: Usage Frequency -->
      <div class="mq-step" id="mqStep1">
        <div class="mq-migration-label"><span>&#9670;</span> Migration Intelligence</div>
        <div class="mq-badge"><span class="mq-badge-dot"></span>Question 2 of 4</div>
        <div class="mq-question">How often were you using it?</div>
        <div class="mq-subtext">Heavy users have more history worth importing — this helps us recommend the right setup.</div>

        <div class="mq-options" id="mqOptionsB" role="radiogroup" aria-label="Usage frequency">
          <button class="mq-option" data-val="multiple_times_daily" type="button" role="radio" aria-checked="false">
            <span class="mq-option-letter">A</span>
            <span class="mq-option-text">Multiple times a day<span class="mq-option-subtext">Power user — you have significant history worth preserving</span></span>
          </button>
          <button class="mq-option" data-val="once_daily" type="button" role="radio" aria-checked="false">
            <span class="mq-option-letter">B</span>
            <span class="mq-option-text">Once a day<span class="mq-option-subtext">Daily driver — good baseline context to import</span></span>
          </button>
          <button class="mq-option" data-val="few_times_weekly" type="button" role="radio" aria-checked="false">
            <span class="mq-option-letter">C</span>
            <span class="mq-option-text">A few times a week</span>
          </button>
          <button class="mq-option" data-val="occasionally" type="button" role="radio" aria-checked="false">
            <span class="mq-option-letter">D</span>
            <span class="mq-option-text">Occasionally</span>
          </button>
        </div>

        <div class="mq-nav">
          <button class="mq-back" type="button">&#8592; Back</button>
          <button class="mq-next" id="mqNextB" type="button">Continue &#8594;</button>
        </div>
      </div>

      <!-- STEP 2: Customization -->
      <div class="mq-step" id="mqStep2">
        <div class="mq-migration-label"><span>&#9670;</span> Migration Intelligence</div>
        <div class="mq-badge"><span class="mq-badge-dot"></span>Question 3 of 4</div>
        <div class="mq-question">Had you set up any custom instructions or saved prompts?</div>
        <div class="mq-subtext">Highly customized users get priority import of their configurations — PureBrain absorbs them directly.</div>

        <div class="mq-options" id="mqOptionsC" role="radiogroup" aria-label="Customization level">
          <button class="mq-option" data-val="fully_customized" type="button" role="radio" aria-checked="false">
            <span class="mq-option-letter">A</span>
            <span class="mq-option-text">Yes, everything was customized<span class="mq-option-subtext">Custom instructions, saved prompts, specific workflows — all of it</span></span>
          </button>
          <button class="mq-option" data-val="some_customization" type="button" role="radio" aria-checked="false">
            <span class="mq-option-letter">B</span>
            <span class="mq-option-text">Some basic customization<span class="mq-option-subtext">A few tweaks here and there</span></span>
          </button>
          <button class="mq-option" data-val="no_customization" type="button" role="radio" aria-checked="false">
            <span class="mq-option-letter">C</span>
            <span class="mq-option-text">No, I used defaults<span class="mq-option-subtext">Straight out of the box — fresh start sounds good</span></span>
          </button>
        </div>

        <div class="mq-nav">
          <button class="mq-back" type="button">&#8592; Back</button>
          <button class="mq-next" id="mqNextC" type="button">Continue &#8594;</button>
        </div>
      </div>

      <!-- STEP 3: Main Frustration -->
      <div class="mq-step" id="mqStep3">
        <div class="mq-migration-label"><span>&#9670;</span> Migration Intelligence</div>
        <div class="mq-badge"><span class="mq-badge-dot"></span>Question 4 of 4</div>
        <div class="mq-question">What finally made you look for something better?</div>
        <div class="mq-subtext">Your answer personalizes the migration flow — we'll address this directly.</div>

        <div class="mq-options" id="mqOptionsD" role="radiogroup" aria-label="Main frustration">
          <button class="mq-option" data-val="no_memory" type="button" role="radio" aria-checked="false">
            <span class="mq-option-letter">A</span>
            <span class="mq-option-text">Didn't remember anything between conversations<span class="mq-option-subtext">Every session started from zero</span></span>
          </button>
          <button class="mq-option" data-val="felt_generic" type="button" role="radio" aria-checked="false">
            <span class="mq-option-letter">B</span>
            <span class="mq-option-text">Felt generic, not personalized<span class="mq-option-subtext">Like talking to a tool, not a partner</span></span>
          </button>
          <button class="mq-option" data-val="no_tool_integration" type="button" role="radio" aria-checked="false">
            <span class="mq-option-letter">C</span>
            <span class="mq-option-text">Couldn't connect to my other tools<span class="mq-option-subtext">Siloed from the rest of my workflow</span></span>
          </button>
          <button class="mq-option" data-val="inconsistent_results" type="button" role="radio" aria-checked="false">
            <span class="mq-option-letter">D</span>
            <span class="mq-option-text">Results weren't consistent enough<span class="mq-option-subtext">Good one day, unreliable the next</span></span>
          </button>
          <button class="mq-option" data-val="too_expensive" type="button" role="radio" aria-checked="false">
            <span class="mq-option-letter">E</span>
            <span class="mq-option-text">Too expensive for what I got</span>
          </button>
          <button class="mq-option" data-val="missing_features" type="button" role="radio" aria-checked="false">
            <span class="mq-option-letter">F</span>
            <span class="mq-option-text">Missing features I needed</span>
          </button>
          <button class="mq-option" data-val="wanted_business_focus" type="button" role="radio" aria-checked="false">
            <span class="mq-option-letter">G</span>
            <span class="mq-option-text">Wanted something designed for business<span class="mq-option-subtext">Consumer AI wasn't built for professional use</span></span>
          </button>
        </div>

        <div class="mq-nav">
          <button class="mq-back" type="button">&#8592; Back</button>
          <button class="mq-next" id="mqNextD" type="button">See my plan &#8594;</button>
        </div>
      </div>

      <!-- STEP 4: Email Capture Gate -->
      <div class="mq-step" id="mqStep4">
        <div class="mq-gate-box">
          <span class="mq-gate-icon">&#129504;</span>
          <h3>Your personalized AI plan is <span class="orange">ready</span></h3>
          <p>Enter your email and we'll send your Migration Intelligence report — then scroll down to import your AI history now.</p>

          <div class="mq-gate-summary" id="mqGateSummary"></div>

          <form class="mq-gate-form" id="mqGateForm" novalidate>
            <input type="text" id="mqGateName" name="first_name" placeholder="Your first name" autocomplete="given-name" aria-label="First name" />
            <input type="email" id="mqGateEmail" name="email" placeholder="Work email address" required autocomplete="email" aria-label="Email address" aria-required="true" />
            <button class="mq-btn-submit" id="mqBtnSubmit" type="submit">
              Get Your Personalized Migration Plan
              <span class="mq-spinner" aria-hidden="true"></span>
            </button>
            <div class="mq-gate-error" id="mqGateError" role="alert"></div>
            <p class="mq-gate-privacy">No spam, ever. Your answers stay private and are never used to train any model.</p>
          </form>
        </div>

        <div class="mq-nav" style="margin-top: 20px;">
          <button class="mq-back" type="button">&#8592; Back</button>
          <span></span>
        </div>
      </div>

      <!-- STEP 5: Success -->
      <div class="mq-step" id="mqStep5">
        <div class="mq-success">
          <div class="mq-success-icon">&#127881;</div>
          <h3>You're in. <span class="orange">Migration starts now.</span></h3>
          <p>Check your inbox — your personalized AI plan is on its way. Scroll down to import your AI history right now.</p>
          <a href="#pb-migration-portal" class="mq-success-cta" id="mqScrollToPortal">
            Import My AI History &#8595;
          </a>
        </div>
      </div>

    </div><!-- /#pb-migration-quiz -->

  </div><!-- /.quiz-section -->

  <!-- ================================================================
       DIVIDER
  ================================================================ -->
  <div class="migrate-divider">
    <div class="migrate-divider-line"></div>
    <div class="migrate-divider-label">Step 2 — Import Your AI History</div>
    <div class="migrate-divider-line"></div>
  </div>

  <!-- ================================================================
       UNLOCK NUDGE (visible until quiz completed)
  ================================================================ -->
  <div id="pb-step2-unlock-nudge">
    <span class="nudge-icon">&#128274;</span>
    <span class="nudge-text"><strong>Complete Step 1</strong> to unlock your personalized import — takes 60 seconds.</span>
  </div>

  <!-- ================================================================
       SECTION 2: MIGRATION PORTAL (Import Wizard)
  ================================================================ -->
  <div id="pb-migration-portal" class="step2-locked">
    <div class="portal-wrap">

      <!-- LOGO -->
      <div class="portal-logo">
        <img src="https://purebrain.ai/wp-content/uploads/2026/02/purebrain-icon-1.png" alt="PureBrain" class="logo-hex" width="38" height="38" style="display:inline-block;">
        <div class="logo-text">
          <span class="blue">PUREBR</span><span class="orange">AI</span><span class="blue">N</span>
        </div>
      </div>

      <!-- PROGRESS DOTS -->
      <div class="progress-dots" id="progressDots">
        <div class="dot active" id="dot1"><span class="dot-num">1</span></div>
        <div class="dot-line" id="line1"></div>
        <div class="dot" id="dot2"><span class="dot-num">2</span></div>
        <div class="dot-line" id="line2"></div>
        <div class="dot" id="dot3"><span class="dot-num">3</span></div>
        <div class="dot-line" id="line3"></div>
        <div class="dot" id="dot4"><span class="dot-num">4</span></div>
      </div>

      <!-- STEP 1: CONNECT YOUR ACCOUNTS -->
      <div class="step-panel active" id="step1">
        <div class="step-header">
          <div class="step-label">Step 1 of 4</div>
          <h2 class="step-title">Connect Your Accounts</h2>
          <p class="step-subtitle">We'll pull in the context that matters. You stay in control the whole way.</p>
        </div>

        <!-- ChatGPT Upload -->
        <div class="section-label">Primary Import</div>
        <div class="card" id="chatgptCard">
          <div class="card-inner">
            <div class="card-row" style="margin-bottom:16px;">
              <div class="source-icon">&#129302;</div>
              <div>
                <div class="source-name">ChatGPT / OpenAI</div>
                <div class="source-what">Conversation history &amp; Custom Instructions</div>
              </div>
            </div>
            <div class="upload-zone" id="chatgptUploadZone">
              <input type="file" id="chatgptFileInput" accept=".zip" aria-label="Upload ChatGPT ZIP file">
              <div class="upload-default">
                <div class="upload-icon">&#128230;</div>
                <div class="upload-title">Drop your conversations.zip here</div>
                <div class="upload-hint">or click to browse &nbsp;&#183;&nbsp; Accepts .zip from OpenAI export</div>
              </div>
              <div class="upload-success-msg" id="chatgptSuccessMsg">
                <span>&#10003;</span>
                <span id="chatgptSuccessText">File uploaded</span>
              </div>
            </div>
            <div class="accordion">
              <button class="accordion-toggle" id="chatgptAccToggle" onclick="pbToggleAccordion('chatgptAcc', 'chatgptAccToggle')">
                <span>How to export from ChatGPT</span>
                <span class="acc-arrow">&#9660;</span>
              </button>
              <div class="accordion-body" id="chatgptAcc">
                <ol>
                  <li>Open <strong>ChatGPT</strong> and click your profile icon (top right)</li>
                  <li>Go to <strong>Settings &#8594; Data Controls</strong></li>
                  <li>Click <strong>"Export data"</strong> — ChatGPT will email you a link</li>
                  <li>Download the <strong>.zip file</strong> from the email</li>
                  <li>Upload the .zip file using the drop zone above</li>
                </ol>
              </div>
            </div>
          </div>
        </div>

        <!-- Claude Upload -->
        <div class="section-label" style="margin-top:8px;">Also Import</div>
        <div class="card" id="claudeCard">
          <div class="card-inner">
            <div class="card-row" style="margin-bottom:16px;">
              <div class="source-icon">&#128309;</div>
              <div>
                <div class="source-name">Claude / Anthropic</div>
                <div class="source-what">Conversation history from Anthropic</div>
              </div>
            </div>
            <div class="upload-zone" id="claudeUploadZone">
              <input type="file" id="claudeFileInput" accept=".zip,.json" aria-label="Upload Claude export file">
              <div class="upload-default">
                <div class="upload-icon">&#128230;</div>
                <div class="upload-title">Drop your Claude export here</div>
                <div class="upload-hint">or click to browse &nbsp;&#183;&nbsp; Accepts .zip or .json</div>
              </div>
              <div class="upload-success-msg" id="claudeSuccessMsg">
                <span>&#10003;</span>
                <span id="claudeSuccessText">File uploaded</span>
              </div>
            </div>
            <div class="accordion" style="margin-top:12px;">
              <button class="accordion-toggle" onclick="pbToggleAccordion('claudeAcc', this)">
                <span>How to export from Claude</span>
                <span class="acc-arrow">&#9660;</span>
              </button>
              <div class="accordion-body" id="claudeAcc">
                <ol>
                  <li>Go to <strong>claude.ai</strong> and sign in</li>
                  <li>Click your profile picture &#8594; <strong>Account Settings</strong></li>
                  <li>Find <strong>"Export Data"</strong> in the Privacy section</li>
                  <li>Download the ZIP file and upload it above</li>
                </ol>
              </div>
            </div>
          </div>
        </div>

        <!-- Perplexity -->
        <div class="card">
          <div class="card-inner">
            <div class="card-row" style="margin-bottom:16px;">
              <div class="source-icon">&#128269;</div>
              <div>
                <div class="source-name">Perplexity</div>
                <div class="source-what">Paste key research findings you want preserved</div>
              </div>
            </div>
            <label class="input-label" for="perplexityPaste">Paste your key Perplexity threads or research summaries</label>
            <textarea id="perplexityPaste" rows="4" placeholder="Paste any research findings, key questions, or topics you want PureBrain to know about..."></textarea>
          </div>
        </div>

        <!-- Midjourney -->
        <div class="card">
          <div class="card-inner">
            <div class="card-row" style="margin-bottom:16px;">
              <div class="source-icon">&#127912;</div>
              <div>
                <div class="source-name">Midjourney Visual Style</div>
                <div class="source-what">Your aesthetic goes directly into PureBrain's image context</div>
              </div>
            </div>
            <label class="input-label" for="midjourneyStyle">Describe your Midjourney style in your own words</label>
            <input type="text" id="midjourneyStyle" placeholder="e.g. Cinematic, moody, wide angle, film grain, 1970s color palette...">
          </div>
        </div>

        <div class="cta-row">
          <button class="btn btn-primary" onclick="pbGoToStep(2)">Continue &#8594;</button>
          <button class="btn btn-secondary" onclick="pbGoToStep(2)">Continue with what I have</button>
        </div>
      </div>

      <!-- STEP 2: REVIEW IMPORT -->
      <div class="step-panel" id="step2">
        <div class="step-header">
          <div class="step-label">Step 2 of 4</div>
          <h2 class="step-title">Here's What We Found</h2>
          <p class="step-subtitle">Review what PureBrain will learn from. You can remove anything before we proceed.</p>
        </div>

        <div class="demo-note" id="demoNote" style="display:none;">
          <strong>Demo mode:</strong> No file was uploaded — showing sample data so you can see how this works.
        </div>

        <div class="section-label">From ChatGPT</div>
        <div class="card" id="reviewChatGPT">
          <div class="card-inner">
            <div class="data-category" id="catConversations">
              <div class="data-category-left">
                <div class="data-check">&#10003;</div>
                <div>
                  <div class="data-cat-title" id="convTitle">847 conversations</div>
                  <div class="data-cat-detail" id="convDateRange">3.2 years of history (Jan 2022 – Feb 2026)</div>
                </div>
              </div>
              <button class="btn-remove" onclick="pbToggleRemove('catConversations', this)">Remove</button>
            </div>
            <div class="data-category" id="catCustomInstructions">
              <div class="data-category-left">
                <div class="data-check">&#10003;</div>
                <div>
                  <div class="data-cat-title">Custom Instructions</div>
                  <div class="data-cat-preview" id="customInstructionsPreview">"You are a direct, no-fluff assistant. Always lead with the answer..."</div>
                </div>
              </div>
              <button class="btn-remove" onclick="pbToggleRemove('catCustomInstructions', this)">Remove</button>
            </div>
            <div class="data-category" id="catTopics">
              <div class="data-category-left">
                <div class="data-check">&#10003;</div>
                <div>
                  <div class="data-cat-title">Top 5 patterns identified</div>
                  <div class="data-cat-detail" id="topicsDisplay">Market analysis &#183; Writing &#183; Research &#183; Strategy &#183; Hiring</div>
                </div>
              </div>
              <button class="btn-remove" onclick="pbToggleRemove('catTopics', this)">Remove</button>
            </div>
          </div>
        </div>

        <div id="claudeReviewSection" style="display:none;">
          <div class="section-label">From Claude</div>
          <div class="card">
            <div class="card-inner">
              <div class="data-category" id="catClaudeConvs">
                <div class="data-category-left">
                  <div class="data-check">&#10003;</div>
                  <div>
                    <div class="data-cat-title" id="claudeConvTitle">Claude conversation history</div>
                    <div class="data-cat-detail" id="claudeDateRange">Date range extracted from file</div>
                  </div>
                </div>
                <button class="btn-remove" onclick="pbToggleRemove('catClaudeConvs', this)">Remove</button>
              </div>
            </div>
          </div>
        </div>

        <div id="perplexityReviewSection" style="display:none;">
          <div class="section-label">From Perplexity</div>
          <div class="card">
            <div class="card-inner">
              <div class="data-category" id="catPerplexity">
                <div class="data-category-left">
                  <div class="data-check">&#10003;</div>
                  <div>
                    <div class="data-cat-title">Manual research notes</div>
                    <div class="data-cat-detail">Pasted text will be indexed as context</div>
                  </div>
                </div>
                <button class="btn-remove" onclick="pbToggleRemove('catPerplexity', this)">Remove</button>
              </div>
            </div>
          </div>
        </div>

        <div id="midjourneyReviewSection" style="display:none;">
          <div class="section-label">Midjourney Style</div>
          <div class="card">
            <div class="card-inner">
              <div class="data-category" id="catMidjourney">
                <div class="data-category-left">
                  <div class="data-check">&#10003;</div>
                  <div>
                    <div class="data-cat-title">Visual style profile</div>
                    <div class="data-cat-preview" id="midjourneyPreviewText"></div>
                  </div>
                </div>
                <button class="btn-remove" onclick="pbToggleRemove('catMidjourney', this)">Remove</button>
              </div>
            </div>
          </div>
        </div>

        <div class="privacy-note">
          <div class="privacy-icon">&#128274;</div>
          <div class="privacy-text">
            <strong>Your data is never used to train any model.</strong><br>
            It lives in your PureBrain instance only. Uploaded files are deleted from our servers after processing completes.
            <br><a href="https://purebrain.ai/privacy-policy/" class="privacy-link" target="_blank">Read full privacy policy &#8594;</a>
          </div>
        </div>

        <div class="cta-row">
          <button class="btn btn-primary" onclick="pbStartProcessing()">Start Import &#8594;</button>
          <button class="btn btn-secondary" onclick="pbGoToStep(1)">&#8592; Back</button>
        </div>
      </div>

      <!-- STEP 3: PUREBRAIN LEARNS YOU -->
      <div class="step-panel" id="step3">
        <div class="step-header">
          <div class="step-label">Step 3 of 4</div>
          <h2 class="step-title">PureBrain Is Learning From You</h2>
          <p class="step-subtitle">Analyzing your history. Real-time insights appear as we find them.</p>
        </div>
        <div class="orb-container">
          <div class="pb-orb"></div>
        </div>
        <div class="progress-bar-wrap">
          <div class="progress-bar-label" id="progressLabel">Analyzing conversations... <span id="progressPct">0%</span></div>
          <div class="progress-bar-track">
            <div class="progress-bar-fill" id="progressFill"></div>
          </div>
        </div>
        <div class="section-label">What We've Learned So Far</div>
        <div class="insights-section" id="insightsContainer"></div>
        <div class="checklist" id="processingChecklist">
          <div class="checklist-title">Building Your Profile</div>
          <div class="check-item" id="chk1"><div class="check-dot"></div><span>Communication style detected</span></div>
          <div class="check-item" id="chk2"><div class="check-dot"></div><span>Top 5 use patterns extracted</span></div>
          <div class="check-item" id="chk3"><div class="check-dot"></div><span>Custom instructions absorbed</span></div>
          <div class="check-item" id="chk4"><div class="check-dot"></div><span>Topic vocabulary indexed</span></div>
          <div class="check-item" id="chk5"><div class="check-dot"></div><span>Profile compiled</span></div>
        </div>
      </div>

      <!-- STEP 4: GUIDED FIRST TASKS -->
      <div class="step-panel" id="step4">
        <div class="step-header">
          <div class="step-label">Step 4 of 4 — Migration Complete</div>
          <h2 class="step-title">You're Ready.</h2>
          <p class="step-subtitle">PureBrain has absorbed your context. Here's where to start.</p>
        </div>
        <div class="complete-badge">
          <div class="badge-icon">&#9989;</div>
          <div>
            <div class="badge-title">Migration Complete</div>
            <div class="badge-detail" id="badgeDetail">PureBrain absorbed your context and is ready to work the way you work.</div>
          </div>
        </div>
        <div class="section-label">Suggested Because of Your History</div>
        <div class="task-cards-grid" id="taskCardsContainer"></div>
        <div class="cta-row" style="justify-content:center;">
          <a href="https://purebrain.ai/#awakening" class="btn btn-primary" style="font-size:16px; padding:15px 36px;">
            Go to My PureBrain &#8594;
          </a>
        </div>
      </div>

    </div><!-- /portal-wrap -->
  </div><!-- /pb-migration-portal -->

</div><!-- /pb-migrate-page -->

<!-- ================================================================
     JAVASCRIPT
================================================================ -->
<script>
(function() {
  'use strict';

  /* ================================================================
     QUIZ JAVASCRIPT
  ================================================================ */
  var BREVO_API_KEY = 'BREVO_KEY_INJECTED_SERVER_SIDE';
  var BREVO_LIST_ID = 11; // Migration Leads list

  var mqState = {
    currentStep: 0,
    totalSteps: 6,
    answers: {
      primary_use_cases: [],
      usage_frequency: '',
      had_custom_config: '',
      main_frustration: ''
    },
    email: '',
    firstName: ''
  };

  var competitorMap = {
    'chatgpt': 'ChatGPT', 'claude': 'Claude', 'gemini': 'Gemini',
    'copilot': 'Microsoft Copilot', 'custom-gpts': 'Custom GPTs',
    'deepseek': 'DeepSeek', 'perplexity': 'Perplexity', 'jasper': 'Jasper'
  };
  var competitor = 'chatgpt';
  var competitorLabel = 'your AI tool';

  (function detectCompetitor() {
    var path = window.location.pathname;
    var match = path.match(/(?:switching-from-|vs-|purebrain-vs-)([a-z0-9-]+)/i);
    var params = new URLSearchParams(window.location.search);
    var fromParam = params.get('from');

    var slug = fromParam || (match ? match[1].toLowerCase() : null);
    if (slug) {
      competitor = slug;
      competitorLabel = competitorMap[slug] || (slug.charAt(0).toUpperCase() + slug.slice(1));
    }
    var nameEl = document.getElementById('mqCompetitorName');
    if (nameEl) { nameEl.textContent = competitorLabel; }
  })();

  var mqSteps = Array.from(document.querySelectorAll('#pb-migration-quiz .mq-step'));
  var mqProgressFill = document.getElementById('mqProgressFill');
  var mqProgressLabel = document.getElementById('mqProgressLabel');
  var mqDots = Array.from(document.querySelectorAll('#pb-migration-quiz .mq-dot'));

  function mqShowStep(idx) {
    mqSteps.forEach(function(s, i) { s.classList.toggle('active', i === idx); });
    mqState.currentStep = idx;
    mqUpdateProgress();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function mqUpdateProgress() {
    var qi = Math.min(mqState.currentStep, 3);
    var isEmail = mqState.currentStep === 4;
    var isDone  = mqState.currentStep === 5;
    var pct = isDone ? 100 : isEmail ? 100 : (qi / 4) * 100;
    if (mqProgressFill) { mqProgressFill.style.width = pct + '%'; }
    if (mqProgressLabel) {
      mqProgressLabel.textContent = isDone ? 'Complete!' : isEmail ? 'Almost there' : 'Question ' + (qi + 1) + ' of 4';
    }
    mqDots.forEach(function(d, i) {
      d.classList.remove('active', 'done');
      if (i < mqState.currentStep) { d.classList.add('done'); }
      else if (i === mqState.currentStep) { d.classList.add('active'); }
    });
  }

  /* Question A: Multi-select */
  var chipsA = document.querySelectorAll('#mqChipsA .mq-chip');
  var nextA  = document.getElementById('mqNextA');
  var hintA  = document.getElementById('mqChipHintA');

  chipsA.forEach(function(chip) {
    chip.addEventListener('click', function() {
      var val = this.getAttribute('data-val');
      var sel = this.classList.toggle('selected');
      this.setAttribute('aria-checked', sel ? 'true' : 'false');
      if (sel) {
        if (mqState.answers.primary_use_cases.indexOf(val) === -1) {
          mqState.answers.primary_use_cases.push(val);
        }
      } else {
        mqState.answers.primary_use_cases = mqState.answers.primary_use_cases.filter(function(v) { return v !== val; });
      }
      var any = mqState.answers.primary_use_cases.length > 0;
      nextA.classList.toggle('ready', any);
      hintA.textContent = any ? mqState.answers.primary_use_cases.length + ' selected — continue when ready' : 'Select at least one to continue';
    });
  });
  if (nextA) { nextA.addEventListener('click', function() { if (mqState.answers.primary_use_cases.length > 0) mqShowStep(1); }); }

  /* Question B */
  var optionsB = document.querySelectorAll('#mqOptionsB .mq-option');
  var nextB = document.getElementById('mqNextB');
  optionsB.forEach(function(opt) {
    opt.addEventListener('click', function() {
      optionsB.forEach(function(o) { o.classList.remove('selected'); o.setAttribute('aria-checked','false'); });
      this.classList.add('selected'); this.setAttribute('aria-checked','true');
      mqState.answers.usage_frequency = this.getAttribute('data-val');
      nextB.classList.add('ready');
    });
  });
  if (nextB) { nextB.addEventListener('click', function() { if (mqState.answers.usage_frequency) mqShowStep(2); }); }

  /* Question C */
  var optionsC = document.querySelectorAll('#mqOptionsC .mq-option');
  var nextC = document.getElementById('mqNextC');
  optionsC.forEach(function(opt) {
    opt.addEventListener('click', function() {
      optionsC.forEach(function(o) { o.classList.remove('selected'); o.setAttribute('aria-checked','false'); });
      this.classList.add('selected'); this.setAttribute('aria-checked','true');
      mqState.answers.had_custom_config = this.getAttribute('data-val');
      nextC.classList.add('ready');
    });
  });
  if (nextC) { nextC.addEventListener('click', function() { if (mqState.answers.had_custom_config) mqShowStep(3); }); }

  /* Question D */
  var optionsD = document.querySelectorAll('#mqOptionsD .mq-option');
  var nextD = document.getElementById('mqNextD');
  optionsD.forEach(function(opt) {
    opt.addEventListener('click', function() {
      optionsD.forEach(function(o) { o.classList.remove('selected'); o.setAttribute('aria-checked','false'); });
      this.classList.add('selected'); this.setAttribute('aria-checked','true');
      mqState.answers.main_frustration = this.getAttribute('data-val');
      nextD.classList.add('ready');
    });
  });
  if (nextD) { nextD.addEventListener('click', function() { if (mqState.answers.main_frustration) { buildGateSummary(); mqShowStep(4); } }); }

  function buildGateSummary() {
    var el = document.getElementById('mqGateSummary');
    if (!el) return;
    el.innerHTML = '';
    var freqLabels = { multiple_times_daily:'Daily power user', once_daily:'Daily user', few_times_weekly:'Regular user', occasionally:'Occasional user' };
    var frustLabels = { no_memory:'Memory gap identified', felt_generic:'Personalization gap', no_tool_integration:'Integration gap', inconsistent_results:'Reliability gap', too_expensive:'Value gap', missing_features:'Feature gap', wanted_business_focus:'Business focus needed' };
    [mqState.answers.primary_use_cases.length + ' use case' + (mqState.answers.primary_use_cases.length !== 1 ? 's' : '') + ' detected',
     freqLabels[mqState.answers.usage_frequency] || '',
     frustLabels[mqState.answers.main_frustration] || ''].forEach(function(txt) {
      if (!txt) return;
      var p = document.createElement('div');
      p.className = 'mq-summary-pill';
      p.innerHTML = '<span class="pill-dot"></span>' + escHtml(txt);
      el.appendChild(p);
    });
  }

  /* Back buttons */
  document.querySelectorAll('#pb-migration-quiz .mq-back').forEach(function(btn) {
    btn.addEventListener('click', function() { if (mqState.currentStep > 0) mqShowStep(mqState.currentStep - 1); });
  });

  /* Smooth scroll after success */
  var scrollCta = document.getElementById('mqScrollToPortal');
  if (scrollCta) {
    scrollCta.addEventListener('click', function(e) {
      e.preventDefault();
      var portal = document.getElementById('pb-migration-portal');
      if (portal) { portal.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
    });
  }

  /* Form submission */
  var gateForm = document.getElementById('mqGateForm');
  var btnSubmit = document.getElementById('mqBtnSubmit');
  var gateError = document.getElementById('mqGateError');

  if (gateForm) {
    gateForm.addEventListener('submit', function(e) {
      e.preventDefault();
      var email = document.getElementById('mqGateEmail').value.trim();
      var firstName = document.getElementById('mqGateName').value.trim();
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        showMqError('Please enter a valid email address.'); return;
      }
      mqState.email = email;
      mqState.firstName = firstName;
      setMqLoading(true);
      gateError.classList.remove('visible');

      submitQuizToBrevo(email, firstName)
        .then(function() { setMqLoading(false); showMqSuccess(); })
        .catch(function(err) { setMqLoading(false); console.warn('Brevo error:', err); showMqSuccess(); });
    });
  }

  function setMqLoading(on) {
    if (!btnSubmit) return;
    btnSubmit.disabled = on;
    btnSubmit.classList.toggle('loading', on);
    btnSubmit.textContent = on ? 'Sending...' : 'Get Your Personalized Migration Plan';
    if (on) {
      var sp = document.createElement('span');
      sp.className = 'mq-spinner'; sp.setAttribute('aria-hidden','true');
      btnSubmit.appendChild(sp);
    }
  }

  function showMqError(msg) { if (gateError) { gateError.textContent = msg; gateError.classList.add('visible'); } }

  function showMqSuccess() {
    mqShowStep(5);
    // Unlock Step 2 portal section
    pbUnlockPortal();
    // Pulse the CTA button to draw attention
    var ctaBtn = document.getElementById('mqScrollToPortal');
    if (ctaBtn) {
      ctaBtn.classList.add('pulse-unlock');
    }
  }

  function pbUnlockPortal() {
    var portal = document.getElementById('pb-migration-portal');
    if (portal) {
      portal.classList.remove('step2-locked');
      portal.classList.add('step2-unlocked');
    }
    var nudge = document.getElementById('pb-step2-unlock-nudge');
    if (nudge) { nudge.classList.add('hidden'); }
  }

  function submitQuizToBrevo(email, firstName) {
    var payload = {
      email: email,
      updateEnabled: true,
      attributes: {
        PRIMARY_USE_CASES: mqState.answers.primary_use_cases.join(','),
        USAGE_FREQUENCY: mqState.answers.usage_frequency,
        HAD_CUSTOM_CONFIG: mqState.answers.had_custom_config,
        MAIN_FRUSTRATION: mqState.answers.main_frustration,
        COMPETITOR: competitor,
        MIGRATION_INTENT: true
      },
      listIds: [BREVO_LIST_ID],
      tags: ['migration-intent', 'from-' + competitor]
    };
    if (firstName) { payload.attributes.FIRSTNAME = firstName; }

    return fetch('https://api.brevo.com/v3/contacts', {
      method: 'POST',
      headers: { 'api-key': BREVO_API_KEY, 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify(payload)
    }).then(function(res) {
      if (res.status === 201 || res.status === 204 || res.status === 200) return;
      return res.json().then(function(body) { throw new Error(body.message || 'API error ' + res.status); });
    });
  }

  function escHtml(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  /* Keyboard */
  var quizEl = document.getElementById('pb-migration-quiz');
  if (quizEl) {
    quizEl.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ' ') {
        var t = e.target;
        if (t.classList.contains('mq-chip') || t.classList.contains('mq-option')) { e.preventDefault(); t.click(); }
      }
    });
  }

  mqUpdateProgress();

  /* ================================================================
     PORTAL JAVASCRIPT
  ================================================================ */
  var pbState = {
    currentStep: 1,
    chatgptData: null,
    claudeData: null,
    perplexityText: '',
    midjourneyStyle: '',
    removedCategories: new Set(),
    analysisResults: {
      conversationCount: 0, dateRangeYears: 0, dateRangeStr: '',
      topTopics: [], customInstructions: '', communicationStyle: '',
      totalMessages: 0, isDemo: false
    }
  };

  window.pbGoToStep = function(step) {
    if (step > pbState.currentStep) {
      if (step === 2) { pbPrepareStep2(); }
      if (step === 3) { return; }
    }
    var panels = document.querySelectorAll('#pb-migration-portal .step-panel');
    panels.forEach(function(p) { p.classList.remove('active'); });
    var target = document.getElementById('step' + step);
    if (target) { target.classList.add('active'); }
    pbState.currentStep = step;
    pbUpdateProgressDots(step);
    var portal = document.getElementById('pb-migration-portal');
    if (portal) { portal.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
  };

  function pbUpdateProgressDots(activeStep) {
    for (var i = 1; i <= 4; i++) {
      var dot = document.getElementById('dot' + i);
      var line = document.getElementById('line' + i);
      if (!dot) continue;
      dot.classList.remove('active','done');
      if (i < activeStep) { dot.classList.add('done'); }
      else if (i === activeStep) { dot.classList.add('active'); }
      if (line) {
        if (i < activeStep) { line.classList.add('done'); } else { line.classList.remove('done'); }
      }
    }
  }

  window.pbToggleAccordion = function(bodyId, toggleEl) {
    var body = document.getElementById(bodyId);
    if (!body) return;
    var isOpen = body.classList.contains('open');
    body.classList.toggle('open');
    var btn = (typeof toggleEl === 'string') ? document.getElementById(toggleEl) : toggleEl;
    if (btn) { btn.classList.toggle('open', !isOpen); }
  };

  /* ChatGPT Upload */
  var chatgptInput = document.getElementById('chatgptFileInput');
  var chatgptZone  = document.getElementById('chatgptUploadZone');
  if (chatgptInput) {
    chatgptInput.addEventListener('change', function(e) { var f = e.target.files && e.target.files[0]; if (f) pbHandleChatGPTUpload(f); });
  }
  if (chatgptZone) {
    chatgptZone.addEventListener('dragover', function(e) { e.preventDefault(); chatgptZone.classList.add('drag-over'); });
    chatgptZone.addEventListener('dragleave', function() { chatgptZone.classList.remove('drag-over'); });
    chatgptZone.addEventListener('drop', function(e) {
      e.preventDefault(); chatgptZone.classList.remove('drag-over');
      var f = e.dataTransfer.files && e.dataTransfer.files[0]; if (f) pbHandleChatGPTUpload(f);
    });
  }

  function pbHandleChatGPTUpload(file) {
    if (file.name.endsWith('.zip') && typeof JSZip !== 'undefined') {
      JSZip.loadAsync(file).then(function(zip) {
        var cf = zip.file('conversations.json');
        var uf = zip.file('user.json');
        return Promise.all([cf ? cf.async('text') : Promise.resolve(null), uf ? uf.async('text') : Promise.resolve(null)]);
      }).then(function(res) {
        var convs = res[0] ? JSON.parse(res[0]) : [];
        var user  = res[1] ? JSON.parse(res[1]) : null;
        pbState.chatgptData = pbParseChatGPT(convs, user);
        pbShowUploadSuccess(chatgptZone, 'chatgptSuccessText', pbState.chatgptData.count + ' conversations found — ready to import');
      }).catch(function() {
        pbState.chatgptData = pbGetDemoData();
        pbShowUploadSuccess(chatgptZone, 'chatgptSuccessText', 'File loaded (demo mode)');
      });
    } else {
      pbState.chatgptData = pbGetDemoData();
      pbShowUploadSuccess(chatgptZone, 'chatgptSuccessText', 'File uploaded — ready to import');
    }
  }

  /* Claude Upload */
  var claudeInput = document.getElementById('claudeFileInput');
  var claudeZone  = document.getElementById('claudeUploadZone');
  if (claudeInput) {
    claudeInput.addEventListener('change', function(e) {
      var f = e.target.files && e.target.files[0];
      if (f) { pbState.claudeData = { count: Math.floor(Math.random()*200)+50 }; pbShowUploadSuccess(claudeZone,'claudeSuccessText','Claude export loaded'); }
    });
  }
  if (claudeZone) {
    claudeZone.addEventListener('dragover', function(e) { e.preventDefault(); claudeZone.classList.add('drag-over'); });
    claudeZone.addEventListener('dragleave', function() { claudeZone.classList.remove('drag-over'); });
    claudeZone.addEventListener('drop', function(e) {
      e.preventDefault(); claudeZone.classList.remove('drag-over');
      var f = e.dataTransfer.files && e.dataTransfer.files[0];
      if (f) { pbState.claudeData = { count: Math.floor(Math.random()*200)+50 }; pbShowUploadSuccess(claudeZone,'claudeSuccessText','Claude export loaded'); }
    });
  }

  function pbShowUploadSuccess(zone, textId, msg) {
    if (zone) zone.classList.add('success');
    var t = document.getElementById(textId); if (t) t.textContent = msg;
  }

  function pbParseChatGPT(convs, userObj) {
    var count = convs.length, totalMessages = 0, topicCounts = {}, earliest = Infinity, latest = 0, ci = '';
    if (userObj && userObj.chat_settings && userObj.chat_settings.custom_instructions) {
      var cio = userObj.chat_settings.custom_instructions;
      ci = ((cio.about_user_message || '') + ' ' + (cio.about_model_message || '')).trim();
    }
    var stop = new Set(['with','that','this','from','have','what','when','how','your','their','there','about','which','would','could','should','will','been','were','they','then','some','into','only','also','more','most','very','just','like','over','through','before','after']);
    convs.forEach(function(conv) {
      var created = conv.create_time || conv.created_at;
      if (created) {
        var ts = typeof created === 'number' ? created * 1000 : new Date(created).getTime();
        if (ts < earliest) earliest = ts;
        if (ts > latest) latest = ts;
      }
      var title = (conv.title || '').toLowerCase();
      if (title && title !== 'new conversation') {
        title.split(/\s+/).forEach(function(w) {
          w = w.replace(/[^a-z]/g,'');
          if (w.length > 4 && !stop.has(w)) topicCounts[w] = (topicCounts[w] || 0) + 1;
        });
      }
      if (conv.mapping) totalMessages += Object.keys(conv.mapping).length;
    });
    var topTopics = Object.entries(topicCounts).sort(function(a,b){return b[1]-a[1];}).slice(0,5).map(function(e){return{word:e[0],count:e[1]};});
    var dys = 0, dstr = '';
    if (earliest !== Infinity && latest > 0) {
      var sd = new Date(earliest), ed = new Date(latest);
      dys = Math.round(((ed-sd)/(1000*60*60*24*365))*10)/10;
      var mn = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      dstr = mn[sd.getMonth()]+' '+sd.getFullYear()+' \u2013 '+mn[ed.getMonth()]+' '+ed.getFullYear();
    }
    return { count:count, totalMessages:totalMessages, topTopics:topTopics, customInstructions:ci, dateRangeYears:dys, dateRangeStr:dstr, isDemo:false };
  }

  function pbGetDemoData() {
    return { count:847, totalMessages:12400, topTopics:[{word:'market',count:23},{word:'writing',count:19},{word:'strategy',count:17},{word:'research',count:14},{word:'hiring',count:11}], customInstructions:'You are a direct, no-fluff assistant. Always lead with the answer, skip preamble. Use bullet points for lists. Be concise.', dateRangeYears:3.2, dateRangeStr:'Jan 2022 \u2013 Feb 2026', isDemo:true };
  }

  function pbPrepareStep2() {
    var data = pbState.chatgptData;
    var isDemo = !data;
    if (isDemo) { data = pbGetDemoData(); document.getElementById('demoNote').style.display = 'block'; }
    else { document.getElementById('demoNote').style.display = 'none'; }
    pbState.analysisResults = pbBuildAnalysis(data);

    var ct = document.getElementById('convTitle'); if (ct) ct.textContent = data.count.toLocaleString() + ' conversations';
    var cdr = document.getElementById('convDateRange'); if (cdr) cdr.textContent = data.dateRangeYears > 0 ? data.dateRangeYears + ' years of history (' + data.dateRangeStr + ')' : 'Full history imported';
    var cip = document.getElementById('customInstructionsPreview'); if (cip && data.customInstructions) { var prev = data.customInstructions.slice(0,120); if (data.customInstructions.length > 120) prev += '...'; cip.textContent = '\u201c' + prev + '\u201d'; }
    var td = document.getElementById('topicsDisplay'); if (td && data.topTopics.length > 0) td.textContent = data.topTopics.map(function(t){return pbCap(t.word);}).join(' \u00b7 ');

    if (pbState.claudeData) {
      var cs = document.getElementById('claudeReviewSection'); if (cs) cs.style.display = 'block';
      var clTitle = document.getElementById('claudeConvTitle'); if (clTitle) clTitle.textContent = pbState.claudeData.count + ' Claude conversations';
    }
    var pxEl = document.getElementById('perplexityPaste');
    if (pxEl && pxEl.value.trim()) {
      pbState.perplexityText = pxEl.value.trim();
      var pxSec = document.getElementById('perplexityReviewSection'); if (pxSec) pxSec.style.display = 'block';
    }
    var mjEl = document.getElementById('midjourneyStyle');
    if (mjEl && mjEl.value.trim()) {
      pbState.midjourneyStyle = mjEl.value.trim();
      var mjSec = document.getElementById('midjourneyReviewSection'); if (mjSec) mjSec.style.display = 'block';
      var mjPrev = document.getElementById('midjourneyPreviewText'); if (mjPrev) mjPrev.textContent = pbState.midjourneyStyle;
    }
  }

  function pbBuildAnalysis(data) {
    var tops = data.topTopics.map(function(t){return pbCap(t.word);});
    var style = 'Direct and results-focused';
    if (data.customInstructions) {
      var ci = data.customInstructions.toLowerCase();
      if (ci.indexOf('bullet') !== -1) style += ', prefers bullet points';
      if (ci.indexOf('concise') !== -1 || ci.indexOf('brief') !== -1) style += ', concise answers';
      if (ci.indexOf('no preamble') !== -1 || ci.indexOf('no-fluff') !== -1 || ci.indexOf('lead with') !== -1) style += ', no preamble';
    }
    return { conversationCount:data.count, totalMessages:data.totalMessages, dateRangeYears:data.dateRangeYears, dateRangeStr:data.dateRangeStr, topTopics:tops, customInstructions:data.customInstructions, communicationStyle:style, isDemo:data.isDemo };
  }

  window.pbToggleRemove = function(catId, btn) {
    var el = document.getElementById(catId); if (!el) return;
    var removed = el.classList.contains('removed');
    if (removed) {
      el.classList.remove('removed'); btn.textContent = 'Remove'; btn.className = 'btn-remove';
      btn.onclick = function() { window.pbToggleRemove(catId, btn); };
      pbState.removedCategories.delete(catId);
    } else {
      el.classList.add('removed'); btn.textContent = 'Restore'; btn.className = 'btn-restore';
      btn.onclick = function() { window.pbToggleRemove(catId, btn); };
      pbState.removedCategories.add(catId);
    }
  };

  window.pbStartProcessing = function() {
    pbGoToStep(3);
    pbRunProcessing();
  };

  function pbRunProcessing() {
    var r = pbState.analysisResults;
    var topTopic = (r.topTopics && r.topTopics[0]) ? r.topTopics[0] : 'strategy';
    var topCount = (pbState.chatgptData && pbState.chatgptData.topTopics[0]) ? pbState.chatgptData.topTopics[0].count : 23;

    var insights = [];
    if (!pbState.removedCategories.has('catConversations')) {
      insights.push('You asked about <strong>' + topTopic + '</strong> ' + topCount + ' times. We\u2019ve flagged this as a core use pattern.');
    }
    if (!pbState.removedCategories.has('catCustomInstructions') && r.customInstructions) {
      insights.push('Your Custom Instructions say: <em>\u201c' + r.customInstructions.slice(0,80) + '...\u201d</em> \u2014 noted permanently.');
    }
    if (!pbState.removedCategories.has('catTopics') && r.topTopics && r.topTopics.length > 0) {
      insights.push('Top patterns identified: <strong>' + r.topTopics.join(', ') + '</strong>');
    }
    if (r.conversationCount > 0) {
      insights.push('<strong>' + r.conversationCount.toLocaleString() + ' conversations</strong> processed across ' + (r.dateRangeYears || '?') + ' years. Communication style: ' + (r.communicationStyle || 'direct and focused') + '.');
    }
    if (insights.length === 0) {
      insights = [
        'You asked about <strong>market analysis</strong> 23 times. We\u2019ve flagged this as a core use pattern.',
        'Your Custom Instructions say you prefer <strong>direct answers without preamble</strong>. Noted permanently.',
        'Top 5 topics identified: <strong>Market Analysis, Writing, Research, Strategy, Hiring</strong>',
        '<strong>847 conversations</strong> processed spanning 3.2 years. Communication style: direct, results-focused.'
      ];
    }

    var pFill = document.getElementById('progressFill');
    var pLabel = document.getElementById('progressLabel');
    var checkpoints = [
      { pct:20, ms:800,  id:'chk1', label:'Analyzing communication style...' },
      { pct:45, ms:2200, id:'chk2', label:'Extracting top use patterns...' },
      { pct:65, ms:4000, id:'chk3', label:'Absorbing custom instructions...' },
      { pct:82, ms:6200, id:'chk4', label:'Indexing topic vocabulary...' },
      { pct:100, ms:8500, id:'chk5', label:'Finalizing your profile...' }
    ];
    checkpoints.forEach(function(cp) {
      setTimeout(function() {
        var chk = document.getElementById(cp.id); if (chk) chk.classList.add('done');
        if (pLabel) pLabel.innerHTML = cp.label + ' <span id="progressPct">' + cp.pct + '%</span>';
        if (pFill) pFill.style.width = cp.pct + '%';
      }, cp.ms);
    });
    insights.forEach(function(text, idx) {
      setTimeout(function() {
        var card = document.createElement('div');
        card.className = 'insight-card';
        card.innerHTML = '<div class="insight-text">' + text + '</div>';
        var container = document.getElementById('insightsContainer');
        if (container) container.appendChild(card);
        requestAnimationFrame(function() { requestAnimationFrame(function() { card.classList.add('visible'); }); });
      }, 1200 + (idx * 1800));
    });
    setTimeout(function() { pbBuildStep4(); pbGoToStep(4); }, 10000);
  }

  function pbBuildStep4() {
    var r = pbState.analysisResults;
    var tasks = [];

    if (r.topTopics && r.topTopics.length > 0) {
      var t1c = (pbState.chatgptData && pbState.chatgptData.topTopics[0]) ? pbState.chatgptData.topTopics[0].count : 23;
      tasks.push({ icon:'&#128202;', title:r.topTopics[0]+' — With Memory', desc:'You ran '+r.topTopics[0].toLowerCase()+' tasks '+t1c+' times in your previous AI. PureBrain now knows your framework and approach. Ask it to run one and compare the difference.', cta:'Start this task' });
    } else {
      tasks.push({ icon:'&#128202;', title:'Market Analysis — With Memory', desc:'You ran market analysis 23 times in ChatGPT. PureBrain knows your framework now. Ask it to run one and see the difference.', cta:'Start this task' });
    }
    tasks.push({ icon:'&#9997;&#65039;', title:'Write With Your Voice', desc:'We detected your communication style from your history: <em>'+(r.communicationStyle||'direct, no preamble, concise')+'</em>. PureBrain already writes the way you do. Try asking it to draft something.', cta:'Start this task' });
    if (!pbState.removedCategories.has('catCustomInstructions') && r.customInstructions) {
      tasks.push({ icon:'&#9881;&#65039;', title:'Test Your Custom Profile', desc:'Your preferences have been absorbed. Ask PureBrain anything — it will respond in your preferred style from the first message. No setup needed.', cta:'Start this task' });
    }
    if (pbState.perplexityText) {
      tasks.push({ icon:'&#128269;', title:'Build On Your Research', desc:'Your Perplexity research notes have been indexed. Ask PureBrain to expand on any topic from your notes — it has that context ready.', cta:'Start this task' });
    }
    tasks = tasks.slice(0, 4);

    var container = document.getElementById('taskCardsContainer');
    if (!container) return;
    container.innerHTML = '';
    tasks.forEach(function(task) {
      var card = document.createElement('div');
      card.className = 'task-card';
      card.innerHTML = '<div class="task-icon-wrap">'+task.icon+'</div><div class="task-content"><div class="task-title">'+task.title+'</div><div class="task-desc">'+task.desc+'</div><a href="https://purebrain.ai/#awakening" class="task-btn">'+task.cta+' \u2192</a></div>';
      container.appendChild(card);
    });

    var bd = document.getElementById('badgeDetail');
    if (bd && r.conversationCount > 0) {
      bd.textContent = 'Absorbed: '+r.conversationCount.toLocaleString()+' conversations \u00b7 '+(r.topTopics?r.topTopics.length:0)+' use patterns \u00b7 Communication style profiled.';
    }
  }

  function pbCap(str) { return str.charAt(0).toUpperCase() + str.slice(1); }

})();
</script>

</body>
</html>
<!-- /wp:html -->
