Documentation=file:///home/jared/projects/AI-CIV/aether/tools/boop_group_runner.sh
Documentation=file:///home/jared/projects/AI-CIV/aether/.claude/memory/agent-learnings/devops-engineer/2026-02-23--autonomous-boop-scheduling-system.md
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=jared
WorkingDirectory=/home/jared/projects/AI-CIV/aether
Environment="PATH=/home/jared/.local/bin:/home/jared/.nvm/versions/node/v22.14.0/bin:/usr/local/bin:/usr/bin:/bin"
