# /etc/recovery-agent/allowlist.txt
#
# Container names that recovery-agent is allowed to restart. One per line.
# Lines starting with # are comments. Whitespace stripped.
#
# IMPORTANT: every entry MUST also appear in /etc/sudoers.d/recovery-agent
# as a DOCKER_RESTART_<UPPER> Cmnd_Alias. Mismatches make sudo refuse and
# the daemon returns 500.
#
