{
  "notes": "Maps frequency groups to BOOP names for systemd timer-based autonomous execution. boop_rules added 2026-05-16 per ADR-001 (constitutional fairness lane). Constitutional set is exactly [engineering-flow-check, delegation-enforcer] per CTO verdict Amendment 1.",
  "last_updated": "2026-05-16",
  "boop_rules": {
    "constitutional_tasks": [
      "engineering-flow-check",
      "delegation-enforcer"
    ],
    "constitutional_reserved_slots": 1,
    "constitutional_starvation_multiplier": 2.0,
    "constitutional_watchdog_max_age_seconds": 2700,
    "constitutional_dedup_window_ratio": 0.5,
    "portal_alarm_rate_limit_seconds": 1800,
    "notes": "ADR-001 constitutional fairness lane. constitutional_tasks bypass MAX_BOOPS_PER_WINDOW and MAX_CONCURRENT_BOOP_AGENTS up to constitutional_reserved_slots. Watchdog kills constitutional agent PIDs older than constitutional_watchdog_max_age_seconds. Starvation alarm fires when elapsed > constitutional_starvation_multiplier * interval. Dedup suppresses if elapsed_since_last < interval * constitutional_dedup_window_ratio. Portal alarm rate-limited to 1 per task per portal_alarm_rate_limit_seconds. NO TELEGRAM."
  },
  "groups": {
    "30min": {
      "description": "Every 30 minutes",
      "systemd_oncalendar": "*:0/30",
      "boops": [
        "engineering-flow-check",
        "delegation-enforcer",
        "telegram-health-boop"
      ]
    },
    "60min": {
      "description": "Every 60 minutes",
      "systemd_oncalendar": "*:0/60",
      "boops": [
        "email-check-boop",
        "bsky-presence-boop"
      ]
    },
    "2hr": {
      "description": "Every 2 hours",
      "systemd_oncalendar": "00/2:00",
      "boops": [
        "memory-write-boop",
        "content-pipeline-boop",
        "sales-pulse-boop",
        "context-window-boop"
      ]
    },
    "4hr": {
      "description": "Every 4 hours",
      "systemd_oncalendar": "00/4:00",
      "boops": [
        "sister-collective-boop",
        "security-posture-boop",
        "agent-utilization-boop"
      ]
    },
    "daily": {
      "description": "Once daily at 09:00",
      "systemd_oncalendar": "*-*-* 09:00:00",
      "boops": [
        "morning-consolidation-boop",
        "intel-scan-boop",
        "jared-ping-boop",
        "integration-audit-boop",
        "linkedin-pipeline-boop",
        "paper-scan",
        "purebrain-metrics-boop",
        "capability-gap-analysis",
        "nightly-site-improvement",
        "calculator-tool-discovery"
      ]
    },
    "weekly": {
      "description": "Once weekly on Monday at 09:30",
      "systemd_oncalendar": "Mon *-*-* 09:30:00",
      "boops": [
        "paper-digest-boop",
        "strategic-alignment-boop",
        "agent-performance-review"
      ]
    }
  }
}
