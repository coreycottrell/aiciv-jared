{
  "notes": "Maps frequency groups to BOOP names for systemd timer-based autonomous execution.",
  "last_updated": "2026-02-23",
  "groups": {
    "30min": {
      "description": "Every 30 minutes",
      "systemd_oncalendar": "*:0/30",
      "boops": [
        "engineering-flow-check",
        "delegation-enforcer",
        "telegram-health-boop"
      ]
    },
    "60min": {
      "description": "Every 60 minutes",
