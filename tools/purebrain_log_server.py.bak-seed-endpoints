                           ELSE payment_status
                       END,
                       updated_at = ?
                       WHERE email = ? COLLATE NOCASE""",
                    (pt_order, _now_pt, pt_email)
                )
                _updated_pt = _cur_pt.rowcount
                _conn_pt.commit()
                _conn_pt.close()
                if _updated_pt > 0:
                    logger.info(f'[pay-test] Subscription ID {pt_order} linked to client {pt_email} via onboarding flow')
