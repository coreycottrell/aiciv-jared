                _cur_pt = _conn_pt.cursor()
                _cur_pt.execute(
                    """UPDATE clients SET
                       paypal_subscription_id = CASE
                           WHEN paypal_subscription_id = '' OR paypal_subscription_id IS NULL THEN ?
                           ELSE paypal_subscription_id
                       END,
                       payment_status = CASE
