# Seed-per-email dedup: tracks which email addresses have already had a seed forwarded.
# Prevents double-firing when flow:complete fires after questionnaire:complete for same session.
# Key: normalized email (lowercased). Value: epoch timestamp of first forward.
# Entries expire after 24 hours (sessions don't last longer than that).
_seed_forwarded_emails: dict = {}
_seed_forwarded_lock = threading.Lock()
_SEED_EMAIL_DEDUP_TTL = 86400  # 24 hours

# Sandbox/test page URLs — seeds from these pages get a TEST marker in the email subject/body
