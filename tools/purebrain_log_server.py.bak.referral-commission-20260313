        #   isSandbox:true — flag sent by pay-test-sandbox-3 page
        #
        # NOTE: I-* prefix is NO LONGER filtered — real subscriptions use this format.
        order_id = data.get('orderId', '')
        is_sandbox_payload = bool(data.get('isSandbox', False))
