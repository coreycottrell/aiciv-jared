    # Reads from .magic-links.json populated by agentmail_monitor.py
    # Chatbox JS polls this every 5s after flow completion

    MAGIC_LINKS_FILE = os.path.join(
        os.path.dirname(os.path.dirname(os.path.abspath(__file__))),
        '.magic-links.json'
    )
    _magic_links_file_lock = __import__('threading').Lock()

    def _load_magic_links() -> dict:
        """Load magic links store. Thread-safe."""
        with _magic_links_file_lock:
            try:
                if os.path.exists(MAGIC_LINKS_FILE):
                    with open(MAGIC_LINKS_FILE) as _f:
                        return __import__('json').load(_f)
            except Exception as _e:
                logger.warning(f'Failed to load magic links: {_e}')
            return {}

    @app.route('/api/magic-link/<uuid_val>', methods=['GET', 'OPTIONS'])
    def magic_link_lookup(uuid_val):
        """
        Poll endpoint: returns magic link status for a given session UUID.
        Called by chatbox JS every 5 seconds after flow completion.

        Returns:
          {"status": "pending"}                     — link not yet received
          {"status": "ready", "magic_link": "...",
           "ai_name": "...", "human_name": "..."}   — link received from Witness
        """
        if request.method == 'OPTIONS':
            return _cors_preflight()

        # Validate UUID format (security: prevent path traversal / injection)
        import re as _re_uuid
        # Accept standard UUID format OR email-based fallback keys
        uuid_val_clean = uuid_val.strip()
        if not uuid_val_clean or len(uuid_val_clean) > 128:
            return jsonify({'error': 'Invalid UUID'}), 400

        # Standard UUID pattern or email-fallback (email:...) or ts-fallback
        is_valid = bool(_re_uuid.match(
            r'^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$',
            uuid_val_clean, _re_uuid.IGNORECASE
        ))
        if not is_valid:
            return jsonify({'error': 'Invalid UUID format'}), 400

        links = _load_magic_links()

        if uuid_val_clean not in links:
            return jsonify({'status': 'pending'}), 200

        entry = links[uuid_val_clean]
        return jsonify({
            'status': 'ready',
            'magic_link': entry.get('magic_link', ''),
            'ai_name': entry.get('ai_name', ''),
            'human_name': entry.get('human_name', ''),
            'container': entry.get('container', ''),
            'received_at': entry.get('received_at', ''),
        }), 200

