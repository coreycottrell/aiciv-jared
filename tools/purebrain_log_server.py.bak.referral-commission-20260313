    @app.route('/api/zoom/callback', methods=['GET'])
    def zoom_callback():
        """
        Zoom OAuth callback endpoint.

        Receives ?code=XXXX from Zoom after user authorizes the app.
        Exchanges the code for access_token + refresh_token.
        Saves tokens to .credentials/zoom_tokens.json.
        """
        code = request.args.get('code')
        error = request.args.get('error')

        if error:
            logger.error(f'Zoom OAuth error: {error}')
            return f"""<!DOCTYPE html>
<html><head><title>Zoom Auth Error</title></head>
<body style="font-family:sans-serif;text-align:center;padding:60px;">
  <h2 style="color:#e74c3c;">Authorization Failed</h2>
  <p>Zoom returned error: <strong>{error}</strong></p>
</body></html>""", 400

        if not code:
            return 'Missing code parameter', 400

        client_id = os.environ.get('ZOOM_CLIENT_ID', '')
        client_secret = os.environ.get('ZOOM_CLIENT_SECRET', '')
        redirect_uri = 'https://89.167.19.20:8443/api/zoom/callback'

        if not client_id or not client_secret:
            logger.error('ZOOM_CLIENT_ID or ZOOM_CLIENT_SECRET not set in environment')
            return 'Server misconfiguration: Zoom credentials missing', 500

        # Exchange code for tokens
        token_url = 'https://zoom.us/oauth/token'
        credentials = base64.b64encode(f'{client_id}:{client_secret}'.encode()).decode()
        headers = {
            'Authorization': f'Basic {credentials}',
            'Content-Type': 'application/x-www-form-urlencoded',
        }
        data = {
            'grant_type': 'authorization_code',
            'code': code,
            'redirect_uri': redirect_uri,
        }

        try:
            resp = http_requests.post(token_url, headers=headers, data=data, timeout=15)
            resp.raise_for_status()
            tokens = resp.json()
        except Exception as e:
            logger.error(f'Zoom token exchange failed: {e}')
            return f"""<!DOCTYPE html>
<html><head><title>Zoom Auth Error</title></head>
<body style="font-family:sans-serif;text-align:center;padding:60px;">
  <h2 style="color:#e74c3c;">Token Exchange Failed</h2>
  <p>{str(e)}</p>
</body></html>""", 500

        # Save tokens
        tokens_path = Path('/home/jared/projects/AI-CIV/aether/.credentials/zoom_tokens.json')
        tokens_path.parent.mkdir(parents=True, exist_ok=True)
        tokens['saved_at'] = datetime.now(timezone.utc).isoformat()
        tokens['client_id'] = client_id
        with open(tokens_path, 'w') as f:
            json.dump(tokens, f, indent=2)

        logger.info(f'Zoom tokens saved to {tokens_path}')

        # Notify Jared
        tg_msg = (
            f"Zoom OAuth COMPLETE\n"
            f"access_token saved to .credentials/zoom_tokens.json\n"
            f"token_type: {tokens.get('token_type')}\n"
            f"expires_in: {tokens.get('expires_in')}s\n"
            f"scope: {tokens.get('scope', 'N/A')}"
        )
        try:
            threading.Thread(target=_send_telegram_notification, args=(tg_msg,), daemon=True).start()
        except Exception:
            pass

        return """<!DOCTYPE html>
<html><head><title>Zoom Authorization Successful</title></head>
<body style="font-family:sans-serif;text-align:center;padding:60px;background:#0d1117;color:#e6edf3;">
  <h2 style="color:#3fb950;">Authorization Successful</h2>
  <p>Zoom tokens have been saved. You can close this window.</p>
</body></html>"""


