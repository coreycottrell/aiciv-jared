def _is_sandbox_seed(seed_data: dict) -> bool:
    """Return True if this seed came from a sandbox/test page."""
    page_url = seed_data.get('page_url', '') or ''
    for sandbox_url in SANDBOX_PAGE_URLS:
        if sandbox_url in page_url:
            return True
    # Also check order_id prefixes that indicate sandbox/test
    order_id = seed_data.get('orderId', '') or ''
    sandbox_prefixes = ('SANDBOX-TEST', 'E2E-', 'test-')
    return any(order_id.startswith(p) for p in sandbox_prefixes)


def _check_and_mark_seed_email(email: str) -> bool:
    """Return True if this email has NOT been forwarded yet (first time).
    Marks it as forwarded. Thread-safe. Entries expire after 24 hours.
    Returns False if already forwarded (caller should skip sending).
    """
    if not email or '@' not in email:
        return True  # no valid email — allow through (Witness will handle)
    norm_email = email.strip().lower()
    now = time.time()
    with _seed_forwarded_lock:
        # Purge expired entries
        expired = [k for k, v in _seed_forwarded_emails.items() if now - v > _SEED_EMAIL_DEDUP_TTL]
        for k in expired:
            del _seed_forwarded_emails[k]
        if norm_email in _seed_forwarded_emails:
            return False  # already forwarded — skip
        _seed_forwarded_emails[norm_email] = now
        return True  # first time — allow


def generate_self_signed_cert():
    """
    Generate self-signed SSL certificate if it doesn't exist.

    Creates a certificate valid for 365 days with SANs for the server IP.
    """
    os.makedirs(SSL_CERT_DIR, exist_ok=True)

    if os.path.exists(SSL_CERT_FILE) and os.path.exists(SSL_KEY_FILE):
        logger.info('SSL certificates already exist')
        return True

    logger.info('Generating self-signed SSL certificate...')

    # OpenSSL config for SAN (Subject Alternative Names)
    openssl_config = f"""
[req]
default_bits = 2048
prompt = no
default_md = sha256
distinguished_name = dn
x509_extensions = v3_req

[dn]
C = US
ST = State
L = City
O = PureBrain
OU = LogServer
CN = 89.167.19.20

[v3_req]
subjectAltName = @alt_names
basicConstraints = CA:FALSE
keyUsage = digitalSignature, keyEncipherment

[alt_names]
IP.1 = 89.167.19.20
DNS.1 = localhost
IP.2 = 127.0.0.1
"""

    config_file = os.path.join(SSL_CERT_DIR, 'openssl.cnf')
    with open(config_file, 'w') as f:
        f.write(openssl_config)

    # Generate certificate using OpenSSL
    cmd = [
        'openssl', 'req', '-x509', '-nodes',
        '-days', '365',
        '-newkey', 'rsa:2048',
        '-keyout', SSL_KEY_FILE,
        '-out', SSL_CERT_FILE,
        '-config', config_file
    ]

    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
        if result.returncode == 0:
            logger.info(f'SSL certificate generated: {SSL_CERT_FILE}')
            return True
        else:
            logger.error(f'Failed to generate SSL cert: {result.stderr}')
            return False
    except Exception as e:
        logger.error(f'Error generating SSL cert: {e}')
        return False


def forward_to_acgee(log_entry: Dict[str, Any]) -> None:
    """
    Forward a conversation log entry to the A-C-Gee shared landing-chat endpoint.

    Sends the full message history so conversations are saved to sage.db on
    the Sage & Weaver VPS. Uses retry logic for 500 errors (may be rate limits).

    Args:
        log_entry: The conversation log entry dictionary (same shape as local JSONL).
    """
    session_id = log_entry.get('session_id', 'unknown')

    # Build the payload for the landing-chat API
    # Include metadata so Witness capture watcher can filter by event_type
    metadata = log_entry.get('metadata', {})
    if isinstance(metadata, dict):
        # For post-payment flows, set event_type to "conversation_complete"
        # so Witness capture watcher processes the seed
        source = log_entry.get('source', '')
        meta_event = metadata.get('event', '')
        if source == 'purebrain-post-payment' or meta_event in ('questionnaire:complete', 'flow:complete'):
            metadata = {**metadata, 'event_type': 'conversation_complete'}

    payload = {
        'messages': log_entry.get('messages', []),
        'system': log_entry.get('system', ''),
        'session_id': session_id,
        'source': 'purebrain',
        'metadata': metadata,
        'aiName': log_entry.get('aiName', ''),
        'userName': log_entry.get('userName', ''),
        'userTier': log_entry.get('userTier', ''),
    }

    payload_bytes = json.dumps(payload).encode('utf-8')

    for attempt in range(1, ACGEE_MAX_RETRIES + 1):
        try:
            req = urllib.request.Request(
                ACGEE_LANDING_CHAT_URL,
                data=payload_bytes,
                headers={
                    'Content-Type': 'application/json',
                    'User-Agent': 'Aether-PureBrain-LogServer/1.0',
                },
                method='POST'
            )

            with urllib.request.urlopen(req, timeout=30) as resp:
                status = resp.getcode()
                body = resp.read().decode('utf-8')

            if status == 200:
                logger.info(
                    f'A-C-Gee forward success: session={session_id} attempt={attempt}'
                )
                return  # Success - stop retrying

            logger.warning(
                f'A-C-Gee forward unexpected status {status} for session={session_id}'
            )
            return  # Non-500 non-200 - don't retry

        except urllib.error.HTTPError as e:
            if e.code == 500:
                logger.warning(
                    f'A-C-Gee 500 error (attempt {attempt}/{ACGEE_MAX_RETRIES}) '
                    f'session={session_id} - retrying in {ACGEE_RETRY_DELAY_SECONDS}s'
                )
                if attempt < ACGEE_MAX_RETRIES:
                    time.sleep(ACGEE_RETRY_DELAY_SECONDS)
            else:
                logger.warning(
                    f'A-C-Gee HTTP error {e.code} for session={session_id}: {e.reason}'
                )
                return  # Non-500 HTTP error - don't retry

        except urllib.error.URLError as e:
            logger.warning(
                f'A-C-Gee network error (attempt {attempt}/{ACGEE_MAX_RETRIES}) '
                f'session={session_id}: {e.reason}'
            )
            if attempt < ACGEE_MAX_RETRIES:
                time.sleep(ACGEE_RETRY_DELAY_SECONDS)

        except Exception as e:
            logger.warning(f'A-C-Gee unexpected error for session={session_id}: {e}')
            return  # Unknown error - don't retry

    logger.error(
        f'A-C-Gee forward failed after {ACGEE_MAX_RETRIES} attempts for session={session_id}'
    )


def forward_to_hub(log_entry: Dict[str, Any], hub_room: str = DEFAULT_HUB_ROOM) -> None:
    """
    Forward a conversation log entry to the AICIV comms hub.

    This function runs the hub_cli.py send command to post a message
    to the specified room. Designed to be called asynchronously
    from a background thread.

    Args:
        log_entry: The conversation log entry dictionary.
        hub_room: The hub room to post to (default: 'operations').
    """
    try:
        # Build summary from conversation
        session_id = log_entry.get('session_id', 'unknown')
        messages = log_entry.get('messages', [])
        message_count = len(messages)

        # Get first user message as preview
        first_user_msg = ''
        for msg in messages:
            if msg.get('role') == 'user':
                first_user_msg = msg.get('content', '')[:100]
                break

        summary = f"Pure Brain conversation: {session_id} ({message_count} messages)"

        # Build body with conversation details
        body_lines = [
            f"Session ID: {session_id}",
            f"Messages: {message_count}",
            f"Timestamp: {log_entry.get('server_timestamp', 'unknown')}",
        ]

        if log_entry.get('page_url'):
            body_lines.append(f"Page: {log_entry['page_url']}")

        if first_user_msg:
            body_lines.append(f"First query: {first_user_msg}...")

        body = '\n'.join(body_lines)

        # Set up environment for hub_cli
        env = os.environ.copy()
        env['HUB_REPO_URL'] = env.get('HUB_REPO_URL', 'git@github-interciv:coreycottrell/aiciv-comms-hub.git')
        env['HUB_LOCAL_PATH'] = env.get('HUB_LOCAL_PATH', DEFAULT_HUB_LOCAL_PATH)
        env['HUB_AGENT_ID'] = env.get('HUB_AGENT_ID', 'aether-purebrain')
        env['HUB_AGENT_DISPLAY'] = env.get('HUB_AGENT_DISPLAY', 'Pure Brain Log Server')
        env['GIT_AUTHOR_NAME'] = env.get('GIT_AUTHOR_NAME', 'Aether Pure Brain')
        env['GIT_AUTHOR_EMAIL'] = env.get('GIT_AUTHOR_EMAIL', 'purebrain@ai-civ.local')

        # Run hub_cli send command
        cmd = [
            'python3', HUB_CLI_PATH,
            'send',
            '--room', hub_room,
            '--type', 'status',
            '--summary', summary,
            '--body', body
        ]

        result = subprocess.run(
            cmd,
            env=env,
            capture_output=True,
            text=True,
            timeout=60  # 60 second timeout for git operations
        )

        if result.returncode == 0:
            logger.info(f'Forwarded to hub: {session_id} -> {hub_room}')
        else:
            logger.warning(f'Hub forwarding failed: {result.stderr}')

    except subprocess.TimeoutExpired:
        logger.warning(f'Hub forwarding timed out for session: {session_id}')
    except Exception as e:
        logger.warning(f'Hub forwarding error: {e}')


def _send_google_smtp(to_list, cc_list, subject, html_body, reply_to=None):
    """Send email via Google Workspace SMTP (purebrain@puremarketing.ai).
    Shows in Sent folder. Falls back to Brevo if SMTP fails."""
    from dotenv import load_dotenv
    load_dotenv('/home/jared/projects/AI-CIV/aether/.env')
    app_password = os.environ.get('GOOGLE_APP_PASSWORD', '')
    if not app_password:
        return False, 'GOOGLE_APP_PASSWORD not set'
    try:
        msg = MIMEMultipart('alternative')
        msg['From'] = 'Aether — PureBrain AI <purebrain@puremarketing.ai>'
        msg['To'] = ', '.join(to_list)
        if cc_list:
            msg['Cc'] = ', '.join(cc_list)
        msg['Subject'] = subject
        if reply_to:
            msg['Reply-To'] = reply_to
        msg.attach(MIMEText(html_body, 'html'))
        all_recipients = to_list + (cc_list or [])
        server = smtplib.SMTP('smtp.gmail.com', 587)
        server.starttls()
        server.login('purebrain@puremarketing.ai', app_password)
        server.sendmail('purebrain@puremarketing.ai', all_recipients, msg.as_string())
        server.quit()
        return True, 'sent via Google SMTP'
    except Exception as e:
        return False, str(e)


def create_app(
    log_dir: Optional[str] = None,
    enable_hub_forwarding: bool = True,
    hub_room: Optional[str] = None,
    enable_acgee_forwarding: bool = True,
) -> Flask:
    """
    Create and configure Flask application.

    Args:
        log_dir: Directory for log files. Defaults to DEFAULT_LOG_DIR.
        enable_hub_forwarding: Whether to forward conversations to AICIV hub.
        hub_room: Hub room for forwarding (default: 'operations').
        enable_acgee_forwarding: Whether to forward conversations to A-C-Gee shared DB.

    Returns:
        Configured Flask application.
    """
    app = Flask(__name__)

    # Configure log directory
    log_dir = log_dir or DEFAULT_LOG_DIR
    app.config['LOG_DIR'] = log_dir
    app.config['LOG_FILE'] = os.path.join(log_dir, DEFAULT_LOG_FILE)

    # Configure hub forwarding
    app.config['ENABLE_HUB_FORWARDING'] = enable_hub_forwarding
    app.config['HUB_ROOM'] = hub_room or DEFAULT_HUB_ROOM

    # Configure A-C-Gee forwarding
    app.config['ENABLE_ACGEE_FORWARDING'] = enable_acgee_forwarding

    # Ensure log directory exists
    os.makedirs(log_dir, exist_ok=True)

    # Enable CORS for all routes (required for cross-origin HTTPS requests)
    CORS(app, resources={r"/api/*": {"origins": "*"}})

    # Register routes
    register_routes(app)

    return app


def _compile_full_seed_md(seed_data: dict) -> str:
    """Compile a full seed report as Markdown from seed_data + conversation logs.

    Pulls naming ceremony conversation from web_conversations JSONL and
    combines with questionnaire/learn-more data from pay_test JSONL.
    Returns the full .md content string.
    """
    ai_name = seed_data.get('aiName', 'N/A')
    human_name = seed_data.get('name', 'N/A')
    email = seed_data.get('email', 'N/A')
    company = seed_data.get('company', 'N/A')
    role = seed_data.get('role', 'N/A')
    goal = seed_data.get('primaryGoal', 'N/A')
    tier = seed_data.get('tier', 'unknown')
    order_id = seed_data.get('orderId', 'N/A')
    session_uuid = seed_data.get('session_uuid', 'N/A')
    timestamp = seed_data.get('server_timestamp', 'N/A')
    paypal_sub = seed_data.get('paypalSubscriptionId', order_id)
    goes_by = seed_data.get('goesBy', human_name)
    learn_more = seed_data.get('learnMoreAnswers', {})

    # Parse learn-more into standard kv_pairs
    lm_kv = []
    if learn_more:
        if isinstance(learn_more, list):
            lm_kv = [
                (item.get('question', item.get('field', '?')), item.get('answer', item.get('value', '')))
                for item in learn_more if isinstance(item, dict)
            ]
        elif isinstance(learn_more, dict):
            lm_kv = list(learn_more.items())

    # Try to pull naming ceremony conversation from web_conversations JSONL
    naming_section = ''
    try:
        conv_log = Path(DEFAULT_LOG_DIR) / 'purebrain_web_conversations.jsonl'
        if conv_log.exists() and session_uuid and session_uuid != 'N/A':
            naming_msgs = []
            with open(conv_log, 'r') as f:
                for line in f:
                    try:
                        entry = json.loads(line.strip())
                        if entry.get('session_uuid') == session_uuid or \
                           entry.get('sessionId', '').endswith(session_uuid[:8]):
                            msgs = entry.get('messages', [])
                            if msgs:
                                naming_msgs.extend(msgs)
                    except json.JSONDecodeError:
                        continue
            if naming_msgs:
                naming_section = '\n## NAMING CEREMONY CONVERSATION\n\n'
                for msg in naming_msgs:
                    role_label = msg.get('role', 'unknown')
                    text = msg.get('text', msg.get('content', ''))
                    if role_label == 'assistant':
                        naming_section += f'- **{ai_name}**: "{text}"\n'
                    elif role_label == 'user':
                        naming_section += f'- **{goes_by}**: "{text}"\n'
    except Exception as e:
        logger.debug(f'Could not pull naming ceremony for seed .md: {e}')

    # Try to pull full pay-test conversation timeline
    timeline_lines = []
    try:
        pt_log = Path(DEFAULT_LOG_DIR) / 'purebrain_pay_test.jsonl'
        if pt_log.exists() and session_uuid and session_uuid != 'N/A':
            with open(pt_log, 'r') as f:
                for line in f:
                    try:
                        entry = json.loads(line.strip())
                        if entry.get('session_uuid') == session_uuid:
                            event = entry.get('event', entry.get('type', ''))
                            ts = entry.get('server_timestamp', entry.get('timestamp', ''))
                            detail = event
                            if entry.get('aiName'):
                                detail += f" (AI: {entry['aiName']})"
                            timeline_lines.append(f'| {ts} | {detail} |')
                    except json.JSONDecodeError:
                        continue
    except Exception as e:
        logger.debug(f'Could not pull timeline for seed .md: {e}')

    now_str = datetime.now(timezone.utc).strftime('%Y-%m-%d %H:%M UTC')

    md = f"""# {human_name.upper()} ({goes_by.upper()}) — {ai_name.upper()} — FULL SEED REPORT

**Generated**: {now_str}
**Session UUID**: {session_uuid}

---

## 1. CUSTOMER PROFILE

| Field | Value |
|-------|-------|
| **Name** | {human_name} |
| **Goes By** | {goes_by} |
| **Email** | {email} |
| **Company** | {company} |
| **Role** | {role} |
| **AI Name** | {ai_name} |
| **Tier** | {tier} |
| **Primary Goal** | {goal} |
| **Order ID** | {order_id} |
| **PayPal Subscription** | {paypal_sub} |

---
{naming_section}
---

## QUESTIONNAIRE ANSWERS

| # | Question | Answer |
|---|----------|--------|
| 1 | Name | {human_name} |
| 2 | Email | {email} |
| 3 | Company | {company} |
| 4 | Role | {role} |
| 5 | Primary Goal | {goal} |

---
"""

    if lm_kv:
        md += "\n## LEARN-MORE DEEP QUESTIONS\n\n"
        md += "| # | Question | Answer |\n|---|----------|--------|\n"
        for i, (k, v) in enumerate(lm_kv, 1):
            md += f"| {i} | {k} | {v} |\n"
        md += "\n---\n"

    if timeline_lines:
        md += "\n## FLOW TIMELINE\n\n"
        md += "| Timestamp | Event |\n|-----------|-------|\n"
        md += '\n'.join(timeline_lines)
        md += "\n\n---\n"

    md += f"""
## CUSTOMER PROFILE SUMMARY

{human_name} ({goes_by}) chose **{ai_name}** as their AI partner on the **{tier}** tier.
Their primary goal: {goal}

---

*Report auto-compiled by PureBrain Log Server on seed completion.*
"""
    return md


def _forward_seed_to_witness(seed_data: dict) -> None:
    """Forward a completed seed to Witness via email + comms hub (best-effort, non-blocking).

    Called from a background thread after every seed completion event.
    Compiles full .md seed report, emails to witness-aiciv@agentmail.to WITH .md attachment,
    CC's jared@puretechnology.nyc, saves .md to exports/, and posts summary to comms hub.

    Dedup rule (2026-03-13): fires at most ONCE per email address per 24-hour window.
    Test pages: email subject/body prefixed with THIS IS A SEED TEST marker.
    UUID always appears as the first element in the email body.
    """
    try:
        # --- DEDUP: one seed per email address (Jared rule 2026-03-13) ---
        raw_email_for_dedup = seed_data.get('email', '') or ''
        if not _check_and_mark_seed_email(raw_email_for_dedup):
            logger.info(f'_forward_seed_to_witness: seed already sent for {raw_email_for_dedup} — skipping duplicate')
            return

        # --- Test page detection (Jared rule 2026-03-13) ---
        is_sandbox = _is_sandbox_seed(seed_data)

        # Build human-readable seed summary
        ai_name = seed_data.get('aiName', 'N/A')
        human_name = seed_data.get('name', 'N/A')
        email = seed_data.get('email', 'N/A')
        company = seed_data.get('company', 'N/A')
        role = seed_data.get('role', 'N/A')
        goal = seed_data.get('primaryGoal', 'N/A')
        tier = seed_data.get('tier', 'unknown')
        order_id = seed_data.get('orderId', 'N/A')
        timestamp = seed_data.get('server_timestamp', 'N/A')
        session_uuid = seed_data.get('session_uuid', 'N/A')
        learn_more = seed_data.get('learnMoreAnswers', {})

        learn_more_html = ''
        learn_more_text = ''
        if learn_more:
            # Handle both list and dict formats
            if isinstance(learn_more, list):
                kv_pairs = [
                    (item.get('question', item.get('field', '?')), item.get('answer', item.get('value', '')))
                    for item in learn_more if isinstance(item, dict)
                ]
            elif isinstance(learn_more, dict):
