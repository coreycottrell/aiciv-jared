    # ── Seed Intake Proxy (with UUID deduplication) ──────────────────────────

    _seed_seen = {}        # {uuid: timestamp} — tracks already-forwarded seeds
    _seed_seen_lock = threading.Lock()
    _SEED_DEDUP_TTL = 3600  # Keep UUIDs for 1 hour, then forget

    def _seed_cleanup():
        """Purge expired entries from _seed_seen."""
        now = time.time()
        expired = [k for k, v in _seed_seen.items() if now - v > _SEED_DEDUP_TTL]
        for k in expired:
            del _seed_seen[k]

    @app.route('/api/intake/seed', methods=['POST', 'OPTIONS'])
    def seed_intake_proxy():
        """Proxy POST /api/intake/seed to Witness awakening VPS.
        Deduplicates by UUID — Witness gets hit exactly ONCE per payment.
        Client must include a 'uuid' field in the JSON body.
        If no uuid provided, we generate one from the payload hash.
        """
        if request.method == 'OPTIONS':
            return _cors_preflight()

        payload = request.get_json(silent=True) or {}

        # Extract or generate a dedup key
        seed_uuid = payload.get('uuid') or payload.get('seed_uuid')
        if not seed_uuid:
            # Build stable dedup key from orderId + stage (ignores timestamp)
            meta = payload.get('metadata', {})
            order_id = meta.get('orderId', '')
            stage = str(meta.get('stage', ''))
            session_id = payload.get('session_id', '')
            stable_key = f'{order_id}:{stage}:{session_id}'
            if order_id or session_id:
                seed_uuid = hashlib.sha256(stable_key.encode()).hexdigest()[:32]
            else:
                # Last resort: hash full payload minus timestamp
                payload_copy = {k: v for k, v in payload.items() if k != 'timestamp'}
                canonical = json.dumps(payload_copy, sort_keys=True, default=str)
                seed_uuid = hashlib.sha256(canonical.encode()).hexdigest()[:32]

        with _seed_seen_lock:
            _seed_cleanup()
            if seed_uuid in _seed_seen:
                logger.warning(f'Seed intake DUPLICATE blocked: uuid={seed_uuid}')
                return jsonify({
                    'status': 'duplicate',
                    'message': 'Seed already forwarded to Witness',
                    'uuid': seed_uuid,
                }), 200
            _seed_seen[seed_uuid] = time.time()

        try:
            resp = http_requests.post(
                f'{WITNESS_SEED_INTAKE_URL}/intake/seed',
                json=payload,
                timeout=15,
            )
            logger.info(f'Seed intake proxy: uuid={seed_uuid} status={resp.status_code}')
            return (resp.content, resp.status_code, {'Content-Type': 'application/json'})
        except http_requests.ConnectionError:
            return jsonify({'error': 'Seed intake unavailable'}), 503
        except http_requests.Timeout:
            return jsonify({'error': 'Seed intake timeout'}), 504

    def _cors_preflight():
        """Return CORS preflight response for proxy endpoints."""
        resp = jsonify({'ok': True})
        resp.headers['Access-Control-Allow-Origin'] = request.headers.get('Origin', '*')
        resp.headers['Access-Control-Allow-Methods'] = 'POST, GET, OPTIONS'
        resp.headers['Access-Control-Allow-Headers'] = 'Content-Type, Authorization, X-Witness-Signature, X-Witness-Secret'
        resp.headers['Access-Control-Max-Age'] = '3600'
        return resp

